---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';

import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const { title, description = "Student developer and economics enthusiast. Software, markets, and a camera.", fullWidth = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<!-- transition:animate="none" disables the native View-Transition root animation so
     it can't render in the browser top layer over the GSAP page-turn curtain below. -->
<html lang="en" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f6f1e7" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />

    <ClientRouter />
    <Analytics />

    <!-- Set a class before paint so first-load reveal states can hide without FOUC -->
    <script is:inline>document.documentElement.classList.add('gsap-ready');</script>

    <!-- Fonts: Bricolage Grotesque (display) + Hanken Grotesk (body) + Spline Sans Mono (figures/code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,300..700&family=Hanken+Grotesk:wght@300;400;500;600;700&family=Spline+Sans+Mono:wght@400;500&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Per-page head injections (e.g. LCP image preload, KaTeX only on posts that need it) -->
    <slot name="head" />

    <title>{title}</title>
    <style is:global>
      /* ============================================================
         GALLERY — warm-paper Swiss catalogue design system
         ============================================================ */

      :root {
        /* Paper (warm ivory). Never #fff. Tinted toward the brand hue. */
        --paper:      oklch(0.965 0.013 83);
        --paper-sink: oklch(0.945 0.016 82);
        --paper-edge: oklch(0.918 0.018 81);

        /* Ink (warm near-black). Never #000. */
        --ink:        oklch(0.225 0.014 70);
        --ink-soft:   oklch(0.405 0.014 68);
        --ink-faint:  oklch(0.520 0.012 70);  /* AA small-text on paper (~5:1); carries .label/.tag */
        --ink-ghost:  oklch(0.590 0.010 72);  /* faintest tier, decorative/large only (~3.6:1) */

        /* Accent — a single burnt ochre, used sparingly */
        --ochre:       oklch(0.585 0.130 56);
        --ochre-deep:  oklch(0.500 0.120 50);
        --ochre-soft:  oklch(0.585 0.130 56 / 0.15);
        --ochre-faint: oklch(0.585 0.130 56 / 0.34);

        /* Hairlines */
        --line:        oklch(0.225 0.014 70 / 0.14);
        --line-strong: oklch(0.225 0.014 70 / 0.30);

        /* Surfaces */
        --panel:       oklch(0.945 0.016 82);
        --panel-hover: oklch(0.928 0.017 81);
        --code-bg:     oklch(0.258 0.016 74);

        /* Warm elevation — one ink-tinted shadow color, layered as a tight contact
           plus a soft ambient so a lifted plate reads off the paper the way a real
           print sits in a mount. One scale replaces the ad-hoc per-page drop shadows
           so every plate shares the same material. */
        --shadow-tint:  40 30 18;  /* warm espresso ink (never neutral black) */
        --shadow-2:     0 2px 6px -3px rgb(var(--shadow-tint) / 0.16), 0 14px 30px -18px rgb(var(--shadow-tint) / 0.50);
        --shadow-3:     0 4px 10px -5px rgb(var(--shadow-tint) / 0.15), 0 24px 48px -28px rgb(var(--shadow-tint) / 0.50);
        --shadow-4:     0 8px 18px -8px rgb(var(--shadow-tint) / 0.15), 0 36px 70px -34px rgb(var(--shadow-tint) / 0.50);
        --shadow-panel: -2px 0 8px -4px rgb(var(--shadow-tint) / 0.14), -30px 0 60px -40px rgb(var(--shadow-tint) / 0.50);

        /* Semantic (tuned for light paper) */
        --ok:   oklch(0.520 0.130 150);
        --err:  oklch(0.530 0.180 28);
        --info: oklch(0.520 0.120 250);

        /* Type scale (fluid, >=1.25 ratio between steps) */
        --step--1: clamp(0.78rem, 0.76rem + 0.10vw, 0.86rem);
        --step-0:  clamp(1rem, 0.97rem + 0.16vw, 1.0625rem);
        --step-1:  clamp(1.2rem, 1.12rem + 0.42vw, 1.45rem);
        --step-2:  clamp(1.5rem, 1.3rem + 1vw, 2.1rem);
        --step-3:  clamp(1.9rem, 1.5rem + 1.9vw, 3rem);
        --step-4:  clamp(2.4rem, 1.8rem + 3vw, 4.5rem);
        --step-5:  clamp(3rem, 2rem + 5vw, 7rem);
        --step-6:  clamp(3.4rem, 1.4rem + 10.5vw, 11rem);

        /* Spacing / layout */
        --gutter: clamp(1.25rem, 0.8rem + 2.2vw, 3rem);
        --container: 84rem;
        --container-text: 46rem;
        --radius: 0.125rem;

        /* Motion */
        --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
        --t-fast: 150ms;
        --t-base: 240ms;
        --t-slow: 560ms;
        --focus-ring: 0 0 0 2px var(--paper), 0 0 0 4px var(--ochre);
      }

      *, *::before, *::after { box-sizing: border-box; }

      html {
        font-family: 'Hanken Grotesk', system-ui, sans-serif;
        background-color: var(--paper);
        color: var(--ink);
        -webkit-text-size-adjust: 100%;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-size: var(--step-0);
        line-height: 1.6;
        color: var(--ink-soft);
        background: var(--paper);
        font-feature-settings: "ss01", "cv01";
      }

      /* Whisper-fine paper tooth (tactility, not costume) */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.025;
        mix-blend-mode: multiply;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 220px 220px;
      }

      /* -------- Typography -------- */
      h1, h2, h3, h4, h5, h6 {
        font-family: 'Bricolage Grotesque', Georgia, serif;
        color: var(--ink);
        line-height: 1.04;
        font-weight: 500;
        letter-spacing: -0.022em;
        margin: 0;
        text-wrap: balance;
      }
      h1 { font-size: var(--step-4); }
      h2 { font-size: var(--step-3); }
      h3 { font-size: var(--step-2); }
      h4 { font-size: var(--step-1); }

      /* SplitText targets must wrap normally; `balance` interferes with line splitting */
      [data-reveal-lines], [data-hero] [data-hero-headline] { text-wrap: wrap; }

      /* Body copy gets prettier rag: pretty avoids orphans/widows and short last
         lines. Display headings keep `balance` (set above); SplitText / reveal-lines
         targets are overridden to `wrap` below, so this never fights line splitting. */
      p { margin: 0; text-wrap: pretty; }
      a { color: inherit; text-decoration: none; transition: color var(--t-fast) ease; }

      code, pre, .mono { font-family: 'Spline Sans Mono', ui-monospace, monospace; }

      ::selection { background: var(--ochre); color: var(--paper); }

      .katex { color: var(--ink); }

      img { max-width: 100%; height: auto; display: block; }

      /* -------- Reusable type/layout utilities -------- */
      .font-display { font-family: 'Bricolage Grotesque', Georgia, serif; }
      .font-mono { font-family: 'Spline Sans Mono', ui-monospace, monospace; }

      .label {
        font-family: 'Spline Sans Mono', ui-monospace, monospace;
        font-size: var(--step--1);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-faint);
        font-weight: 400;
      }
      .index-num {
        font-family: 'Spline Sans Mono', ui-monospace, monospace;
        font-size: var(--step--1);
        letter-spacing: 0.1em;
        color: var(--ochre);
      }

      .container {
        width: 100%;
        max-width: var(--container);
        margin-inline: auto;
        padding-inline: var(--gutter);
      }
      .container-text { max-width: var(--container-text); }

      .gallery-main {
        width: 100%;
        max-width: var(--container);
        margin-inline: auto;
        padding-inline: var(--gutter);
        padding-block: clamp(3rem, 2rem + 5vw, 7rem);
      }

      /* Full-bleed hairline rule */
      .rule {
        border: none;
        border-top: 1px solid var(--line);
        margin: 0;
      }
      .rule-strong { border-top-color: var(--line-strong); }

      /* ---- Shared page scaffolding (global so every page stays coherent) ---- */
      .section { padding-block: clamp(3.5rem, 2.5rem + 5vw, 8rem); }
      .section-sm { padding-block: clamp(2.5rem, 2rem + 3vw, 5rem); }
      .section-head { display: flex; align-items: baseline; gap: 1rem; margin-bottom: clamp(1.5rem, 1rem + 2vw, 3rem); }
      .section-head--split { justify-content: space-between; align-items: flex-end; flex-wrap: wrap; }
      .section-title { font-size: var(--step-3); margin-top: 0.4rem; }
      .section-link { font-size: 0.9rem; color: var(--ink-soft); white-space: nowrap; transition: color var(--t-base) ease; }
      .section-link:hover { color: var(--ochre); }

      /* Page intro block (sub-pages: kicker + big title + lead) */
      .page-head { padding-top: clamp(1.5rem, 1rem + 3vw, 3.5rem); }
      .page-title { font-size: var(--step-5); line-height: 0.92; letter-spacing: -0.03em; }
      .page-lead { font-size: var(--step-1); color: var(--ink-soft); max-width: 48ch; line-height: 1.5; }

      /* Tech / category pills */
      .tag-list { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; padding: 0; margin: 0; }
      .tag {
        font-family: 'Spline Sans Mono', ui-monospace, monospace;
        font-size: 0.7rem; letter-spacing: 0.03em; color: var(--ink-faint);
        border: 1px solid var(--line); border-radius: 999px; padding: 0.22rem 0.7rem;
        transition: color var(--t-base) ease, border-color var(--t-base) ease;
      }

      /* Bordered surface card */
      .card {
        display: block; border: 1px solid var(--line); border-radius: var(--radius);
        padding: clamp(1.5rem, 1rem + 2vw, 2.5rem);
        transition: border-color var(--t-base) ease, background-color var(--t-base) ease;
      }
      .card:hover { border-color: var(--line-strong); background: var(--panel); }

      /* Wall label (gallery-style caption tag, sits on .media-frame) */
      .wall-label {
        position: absolute; left: 0; bottom: 0;
        display: inline-flex; align-items: center; gap: 0.85rem;
        padding: 0.5rem 0.9rem;
        background: var(--paper);
        border-top: 1px solid var(--line); border-right: 1px solid var(--line);
        border-top-right-radius: 2px;
        font-family: 'Spline Sans Mono', ui-monospace, monospace;
        font-size: 0.68rem; letter-spacing: 0.04em; color: var(--ink);
      }
      .wall-label--hover { transform: translateY(101%); transition: transform var(--t-base) var(--ease-out); }
      .media-frame:hover .wall-label--hover { transform: translateY(0); }

      /* Editorial media frame: clips, holds aspect, hosts parallax/zoom */
      .media-frame {
        position: relative;
        overflow: hidden;
        background: var(--paper-edge);
        border-radius: var(--radius);
      }
      .media-frame img { width: 100%; height: 100%; object-fit: cover; }
      .media-frame [data-parallax] { height: 116%; width: 100%; object-fit: cover; }
      /* <picture> generates no box, so the <img> stays a layout child of the frame
         (its percentage height still resolves against the aspect-ratio box). */
      .media-frame picture { display: contents; }

      /* Link with animated underline */
      .link-underline {
        position: relative;
        color: var(--ink);
        padding-bottom: 1px;
        background-image: linear-gradient(var(--ochre), var(--ochre));
        background-size: 0% 1px;
        background-position: 0 100%;
        background-repeat: no-repeat;
        transition: background-size var(--t-base) var(--ease-out), color var(--t-base) ease;
      }
      .link-underline:hover { background-size: 100% 1px; color: var(--ochre); }

      /* Ochre text link */
      .link-ochre { color: var(--ochre); }
      .link-ochre:hover { color: var(--ochre-deep); }

      /* Button (editorial pill / boxed) */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5em;
        font-family: 'Hanken Grotesk', sans-serif;
        font-size: var(--step-0);
        font-weight: 500;
        line-height: 1;
        padding: 0.95em 1.5em;
        border-radius: 999px;
        border: 1px solid var(--ink);
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: color 340ms var(--ease-out), background-color 340ms var(--ease-out), border-color 340ms var(--ease-out), transform 140ms var(--ease-out);
      }
      /* Outline by default fills with ink; primary is filled and inverts to paper.
         A smooth ink/paper cross-fade, no color jump, no cursor-follow. */
      .btn:hover { background: var(--ink); color: var(--paper); }
      .btn-primary { background: var(--ink); color: var(--paper); }
      .btn-primary:hover { background: var(--paper); color: var(--ink); border-color: var(--ink); }
      .btn-ghost { border-color: var(--line-strong); }
      .btn-ghost:hover { background: var(--ink); color: var(--paper); border-color: var(--ink); }
      .btn-arrow { display: inline-block; will-change: transform; transition: transform 340ms var(--ease-out); }
      .btn:hover .btn-arrow { transform: translateX(4px); }
      /* Tactile press: the button takes a small physical step down when pushed.
         (Magnetic CTAs own their transform via GSAP inline styles, so this no-ops
         there without conflict, and the global reduced-motion reset makes it instant.) */
      .btn:active { transform: translateY(1px); }

      /* -------- Accessibility -------- */
      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
      }
      :focus-visible { outline: none; box-shadow: var(--focus-ring); border-radius: 2px; }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* -------- Motion: first-paint hidden states (only when motion is welcome) -------- */
      @media (prefers-reduced-motion: no-preference) {
        html.gsap-ready [data-reveal] { opacity: 0; }
        html.gsap-ready [data-reveal-lines] { visibility: hidden; }
        html.gsap-ready [data-hero] [data-hero-item] { opacity: 0; }
        html.gsap-ready [data-hero] [data-hero-headline] { visibility: hidden; }
        html.gsap-ready [data-hero-media] { clip-path: inset(0 0 100% 0); }
        html.gsap-ready [data-reveal-clip] { clip-path: inset(0 0 100% 0); }
        html.gsap-ready [data-stagger] > * { opacity: 0; }
      }
      /* will-change is applied just-in-time by the reveal tweens and cleared on
         completion (see buildScrollMotion / buildLineMotion), so settled elements
         don't keep permanent GPU layers. Promotion at animation start is still wanted;
         permanent retention is not. */

      /* Self-drawing hairlines (global primitive): a structural rule strokes itself
         left-to-right as its element enters. JS adds .rule-armed (hides) then .is-drawn
         (draws); without JS or under reduced-motion the ::before stays at its default
         scaleX(1), statically visible, so no separator ever vanishes. */
      [data-draw-rule] { position: relative; }
      [data-draw-rule]::before {
        content: '';
        position: absolute; left: 0; right: 0; top: 0;
        height: 1px; background: var(--line);
        transform-origin: left;
        transition: transform 0.7s var(--ease-out);
      }
      [data-draw-rule].rule-armed::before { transform: scaleX(0); }
      [data-draw-rule].rule-armed.is-drawn::before { transform: scaleX(1); }

      /* Kinetic variable type (driven in buildLineMotion → setupFluxFor).
         Resting --wght:500 matches the headings' normal weight and opsz stays
         auto, so static / touch / reduced-motion render identically; only the
         live weight field on fine pointers changes the var. */
      .flux-char {
        display: inline-block;
        font-variation-settings: 'wght' var(--wght, 500);
        font-optical-sizing: auto;
        /* No permanent will-change: font-variation-settings isn't a compositor
           property, so a per-glyph layer costs memory without buying smoothness. */
      }

      /* WebGL "developing plate" canvas, layered over the hero photo. */
      .halftone-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
      /* WebGL darkroom-loupe canvas, layered over the contact-sheet proof. */
      .loupe-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
      /* Three.js press-finale canvas, layered under the closing plate's content
         (the section's text container carries z-index above it). */
      .press-canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; pointer-events: none; }

      /* Print misregistration on chapter titles: the ochre plate runs in a hair
         out of register (--misreg 1 -> 0 on the chapter entrance timeline) and
         snaps in as the lines land. Global because SplitText creates .split-line
         at runtime (scoped page styles can never match it); default 0 keeps
         perfect register without JS / under reduced-motion. */
      .chapter__title .split-line {
        text-shadow: calc(var(--misreg, 0) * 0.05em) calc(var(--misreg, 0) * -0.04em) 0 var(--ochre);
      }

      /* Cursor image-trail: mounted prints that flick out along the pointer. */
      .trail-layer { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 5; }
      .trail-plate {
        position: absolute; top: 0; left: 0;
        width: clamp(8.5rem, 11vw, 12rem);
        padding: 0.4rem; background: var(--paper);
        border: 1px solid var(--line); border-radius: var(--radius);
        box-shadow: var(--shadow-2);
        opacity: 0; will-change: transform, opacity;
      }
      .trail-plate img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; display: block; border-radius: 1px; }

      /* -------- Scroll progress -------- */
      #scroll-progress {
        position: fixed;
        top: 0; left: 0;
        height: 2px;
        width: 100%;
        background: var(--ochre);
        transform: scaleX(0);
        transform-origin: left;
        z-index: 9998;
        pointer-events: none;
      }

      /* -------- Page-turn curtain -------- */
      /* A warm-paper plate with ochre edges that sweeps up over the page during a
         ClientRouter navigation. Parked one viewport below when idle; GSAP drives it
         (yPercent). No-JS / reduced-motion never move it, so it stays out of the way. */
      .page-curtain {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background: var(--paper-sink);
        border-block: 2px solid var(--ochre);
        transform: translateY(100%);
        will-change: transform;
        /* auto (not none): while covering it blocks stray clicks on the page beneath;
           parked off-screen when idle, so it intercepts nothing between navigations. */
        pointer-events: auto;
        display: flex;
        align-items: flex-end;
        padding: var(--gutter);
      }
      /* The destination reads as a quiet catalogue wall-label, not a loader heading. */
      .page-curtain__label {
        font-family: 'Spline Sans Mono', ui-monospace, monospace;
        font-size: var(--step-0);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-faint);
        opacity: 0;
      }
      @media (prefers-reduced-motion: reduce) {
        .page-curtain { display: none; }
      }

      /* -------- Marquee -------- */
      .marquee { overflow: hidden; width: 100%; }
      .marquee__track { display: inline-flex; width: max-content; will-change: transform; }

      /* -------- Code copy button -------- */
      pre { position: relative; }
      .copy-btn {
        position: absolute; top: 0.6rem; right: 0.6rem;
        font-family: 'Spline Sans Mono', monospace; font-size: 0.7rem;
        color: #c9c2b1; background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12); border-radius: 0.2rem;
        padding: 0.25rem 0.5rem; cursor: pointer; opacity: 0;
        transition: opacity var(--t-base) ease, color var(--t-base) ease;
      }
      pre:hover .copy-btn, .copy-btn:focus { opacity: 1; }
      .copy-btn.copied { color: #8fdca6; }

      .table-container {
        width: 100%; overflow-x: auto; margin: 2rem 0;
        border: 1px solid var(--line); border-radius: var(--radius);
      }

      /* A block display equation (rehype-katex MathML output) can render wider than
         the reading column. Let it use its natural width up to the viewport (so on
         desktop it shows in full, breathing into the wide right margin like before),
         and only become a horizontal scroll box when even that won't fit, instead of
         clipping under body{overflow-x:hidden} and silently losing terms on narrow
         screens. Scoped to block math so inline math is untouched. */
      .post-body .katex:has(math[display="block"]) {
        display: block;
        width: max-content;
        max-width: calc(100vw - 2 * var(--gutter));
        overflow-x: auto;
        overflow-y: hidden;
      }

      /* Contents-index offset: a jump from the index lands the heading clear of the
         persistent masthead instead of tucked behind it. */
      .post-body :is(h2, h3, h4) { scroll-margin-top: 5.85rem; }
      /* setupToc moves focus to the jumped-to heading for keyboard continuity; that
         is programmatic, so suppress the focus ring (the heading is already framed). */
      .post-body :is(h2, h3, h4)[tabindex="-1"]:focus { outline: none; }

      /* When the contents rail occupies the right margin (desktop article layout),
         block equations can no longer breathe into it: keep them inside the reading
         column and let the existing overflow-x give wide ones a scroll box instead. */
      @media (min-width: 70rem) {
        .post-layout .post-body .katex:has(math[display="block"]) { max-width: 100%; }
      }
    </style>
  </head>
  <body class="gallery-shell">
    <!-- Page-turn curtain: a warm-paper plate that sweeps up over the page during a
         ClientRouter navigation, holds while the swap happens hidden, then lifts to
         reveal the new page. transition:persist keeps this node (and its GSAP state)
         across the swap; driven from the script below. Parked off-screen when idle. -->
    <div class="page-curtain" aria-hidden="true" transition:persist="page-curtain">
      <span class="page-curtain__label mono" data-curtain-label></span>
    </div>
    <div id="scroll-progress" aria-hidden="true"></div>
    <Header />
    <CommandPalette />
    <main id="main-content" class:list={['grow w-full', !fullWidth && 'gallery-main']} tabindex="-1">
      <slot />
    </main>
    <Footer />
    <SpeedInsights />

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import { SplitText } from 'gsap/SplitText';
      import { ScrambleTextPlugin } from 'gsap/ScrambleTextPlugin';
      import { DrawSVGPlugin } from 'gsap/DrawSVGPlugin';

      gsap.registerPlugin(ScrollTrigger, SplitText, ScrambleTextPlugin, DrawSVGPlugin);
      // Debug hook (harmless): inspect live ScrollTrigger instances from the console.
      (window as any).__ST = ScrollTrigger;

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      const fine = window.matchMedia('(pointer: fine)');

      let splits: any[] = [];
      let cleanups: Array<() => void> = [];
      let heroTl: gsap.core.Timeline | null = null;
      let initToken = 0;

      // Kinetic-type ("flux") state — see setupFluxFor / fluxTick below.
      type FluxReg = { el: HTMLElement; chars: HTMLElement[]; cx: number[]; cy: number[]; cur: number[]; radius: number };
      let fluxRegs: FluxReg[] = [];
      // Marquee tweens, registered so the scroll-velocity trigger can surge their
      // speed (buildVelocitySkew); `hovered` parks a track at reading speed.
      let marqueeRegs: Array<{ tw: gsap.core.Tween; hovered: boolean }> = [];
      let fluxRunning = false;
      let fluxAtRest = true;
      let scrollFlux = 0;
      const fluxPointer = { x: -9999, y: -9999, active: false };
      const FLUX_BASE = 500, FLUX_PEAK = 200, FLUX_SCROLL = 28;

      function clearMotion() {
        initToken++;
        ScrollTrigger.getAll().forEach((t) => t.kill());
        splits.forEach((s) => { try { s.revert(); } catch (e) {} });
        splits = [];
        cleanups.forEach((fn) => { try { fn(); } catch (e) {} });
        cleanups = [];
        fluxRegs = [];
        marqueeRegs = [];
        fluxAtRest = true;
        scrollFlux = 0;
        fluxPointer.active = false;
        if (heroTl) { heroTl.kill(); heroTl = null; }
      }

      function showEverything() {
        gsap.set('[data-reveal], [data-reveal-lines], [data-hero] [data-hero-item], [data-stagger] > *, [data-reveal-clip]', {
          clearProps: 'all', opacity: 1, visibility: 'visible', y: 0,
        });
        document.querySelectorAll<HTMLElement>('[data-count]').forEach((el) => {
          el.textContent = el.dataset.count || el.textContent;
        });
      }

      function buildScrollMotion() {
        // Individual reveals (fade + rise), batched and staggered as they enter
        ScrollTrigger.batch('[data-reveal]', {
          start: 'top 88%',
          once: true,
          onEnter: (batch) => {
            gsap.set(batch, { visibility: 'visible', willChange: 'transform, opacity' });
            gsap.to(batch, {
              opacity: 1, y: 0, duration: 0.95, ease: 'power3.out',
              stagger: 0.08, overwrite: true,
              onComplete: () => gsap.set(batch, { willChange: 'auto' }),
            });
          },
        });
        gsap.set('[data-reveal]', { y: 36 });

        // Stagger groups: children animate together when the group enters
        gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((group) => {
          const items = group.querySelectorAll<HTMLElement>(':scope > *');
          gsap.set(items, { y: 32 });
          ScrollTrigger.create({
            trigger: group, start: 'top 84%', once: true,
            onEnter: () => {
              gsap.set(items, { visibility: 'visible', willChange: 'transform, opacity' });
              gsap.to(items, { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', stagger: 0.085,
                onComplete: () => gsap.set(items, { willChange: 'auto' }) });
            },
          });
        });

        // Parallax inside .media-frame
        gsap.utils.toArray<HTMLElement>('[data-parallax]').forEach((el) => {
          const amt = parseFloat(el.dataset.parallax || '') || 7;
          gsap.fromTo(el, { yPercent: -amt }, {
            yPercent: amt, ease: 'none',
            scrollTrigger: {
              trigger: el.closest('.media-frame') || el,
              start: 'top bottom', end: 'bottom top', scrub: true,
            },
          });
        });

        // Clip-path "uncover": a print is slid into view top-to-bottom as it
        // enters, like a plate drawn from a portfolio sleeve. Composes with the
        // frame's [data-zoom] / [data-tilt] (those own transform; this owns
        // clip-path). CSS pre-hides [data-reveal-clip]; reduced-motion clears it
        // via showEverything. Works on touch too (not a hover/fine-pointer gate).
        gsap.utils.toArray<HTMLElement>('[data-reveal-clip]').forEach((el) => {
          gsap.set(el, { clipPath: 'inset(0 0 100% 0)' });
          ScrollTrigger.create({
            trigger: el, start: 'top 88%', once: true,
            onEnter: () => {
              gsap.set(el, { willChange: 'clip-path' });
              gsap.to(el, { clipPath: 'inset(0 0 0% 0)', duration: 1.1, ease: 'power3.inOut',
                onComplete: () => gsap.set(el, { willChange: 'auto' }) });
            },
          });
          cleanups.push(() => gsap.set(el, { clearProps: 'clipPath,willChange' }));
        });

        // Number counters
        gsap.utils.toArray<HTMLElement>('[data-count]').forEach((el) => {
          const end = parseFloat(el.dataset.count || '0');
          const decimals = (el.dataset.count || '').includes('.') ? 1 : 0;
          const obj = { v: 0 };
          ScrollTrigger.create({
            trigger: el, start: 'top 92%', once: true,
            onEnter: () => gsap.to(obj, {
              v: end, duration: 1.7, ease: 'power2.out',
              onUpdate: () => { el.textContent = obj.v.toFixed(decimals); },
            }),
          });
        });

        // Catalogue chrome decode: mono index numbers + kickers scramble from
        // glyphs to their final value as they scroll in (printshop type-setting).
        // Monospace marks (mono digits/labels) so there is no layout reflow.
        gsap.utils.toArray<HTMLElement>('[data-scramble]').forEach((el) => {
          const finalText = (el.textContent || '').trim();
          if (!finalText) return;
          const numeric = /^[\d.\s]+$/.test(finalText);
          ScrollTrigger.create({
            trigger: el, start: 'top 90%', once: true,
            onEnter: () => gsap.to(el, {
              duration: 0.9, ease: 'none',
              scrambleText: { text: finalText, chars: numeric ? '0123456789' : 'upperCase', speed: 0.55, revealDelay: 0.12 },
            }),
          });
        });

        // Self-drawing hairlines: structural rules stroke themselves left-to-right
        // as their section arrives. JS arms (hides) then draws, so no-JS and
        // reduced-motion keep the rule statically visible (the CSS ::before default).
        gsap.utils.toArray<HTMLElement>('[data-draw-rule]').forEach((el) => {
          el.classList.add('rule-armed');
          ScrollTrigger.create({
            trigger: el, start: 'top 88%', once: true,
            onEnter: () => el.classList.add('is-drawn'),
          });
          cleanups.push(() => el.classList.remove('rule-armed', 'is-drawn'));
        });

        // DrawSVG signature stroke: an inline SVG path draws itself on enter. JS
        // arms it to 0% then draws to 100%; no-JS / reduced-motion keep it full.
        gsap.utils.toArray<SVGPathElement>('[data-draw-svg]').forEach((path) => {
          gsap.set(path, { drawSVG: '0%' });
          ScrollTrigger.create({
            trigger: (path.closest('svg') as Element) || path, start: 'top 88%', once: true,
            onEnter: () => gsap.to(path, { drawSVG: '100%', duration: 1.15, ease: 'power2.inOut' }),
          });
          cleanups.push(() => gsap.set(path, { clearProps: 'all' }));
        });

        // Hover zoom for editorial media (works alongside parallax: GSAP merges transforms)
        if (fine.matches) {
          gsap.utils.toArray<HTMLElement>('[data-zoom]').forEach((el) => {
            const enter = () => gsap.to(el, { scale: 1.05, duration: 0.9, ease: 'power3.out' });
            const leave = () => gsap.to(el, { scale: 1, duration: 0.9, ease: 'power3.out' });
            el.addEventListener('mouseenter', enter);
            el.addEventListener('mouseleave', leave);
            cleanups.push(() => { el.removeEventListener('mouseenter', enter); el.removeEventListener('mouseleave', leave); });
          });
        }

        // Marquee: track must contain its content twice for a seamless -50% loop.
        // Each tween registers in marqueeRegs so scroll velocity can surge its
        // speed (buildVelocitySkew); `hovered` stays true until the return tween
        // completes, so hover reading-speed never fights the velocity writes.
        gsap.utils.toArray<HTMLElement>('[data-marquee]').forEach((track) => {
          const dur = parseFloat(track.dataset.marquee || '') || 34;
          const tw = gsap.to(track, { xPercent: -50, duration: dur, ease: 'none', repeat: -1 });
          const reg = { tw, hovered: false };
          marqueeRegs.push(reg);
          const slow = () => { reg.hovered = true; gsap.to(tw, { timeScale: 0.15, duration: 0.5 }); };
          const fast = () => gsap.to(tw, { timeScale: 1, duration: 0.5, onComplete: () => { reg.hovered = false; } });
          track.addEventListener('mouseenter', slow);
          track.addEventListener('mouseleave', fast);
          cleanups.push(() => { tw.kill(); track.removeEventListener('mouseenter', slow); track.removeEventListener('mouseleave', fast); });
        });

        // Magnetic pull (fine pointers only)
        if (fine.matches) {
          gsap.utils.toArray<HTMLElement>('[data-magnetic]').forEach((el) => {
            const strength = parseFloat(el.dataset.magnetic || '') || 0.32;
            const xTo = gsap.quickTo(el, 'x', { duration: 0.5, ease: 'power3' });
            const yTo = gsap.quickTo(el, 'y', { duration: 0.5, ease: 'power3' });
            const move = (e: MouseEvent) => {
              const r = el.getBoundingClientRect();
              xTo((e.clientX - (r.left + r.width / 2)) * strength);
              yTo((e.clientY - (r.top + r.height / 2)) * strength);
            };
            const reset = () => { xTo(0); yTo(0); };
            el.addEventListener('mousemove', move);
            el.addEventListener('mouseleave', reset);
            cleanups.push(() => { el.removeEventListener('mousemove', move); el.removeEventListener('mouseleave', reset); gsap.set(el, { x: 0, y: 0 }); });
          });
        }

        // Scroll progress bar
        const prog = document.getElementById('scroll-progress');
        if (prog) {
          gsap.set(prog, { scaleX: 0 });
          ScrollTrigger.create({
            start: 0, end: 'max',
            onUpdate: (self) => gsap.set(prog, { scaleX: self.progress }),
          });
        }

        // Hero plate "settles": a gentle scrub scale on the cover as it scrolls away,
        // so the developed plate recedes into the catalogue. The figure's transform is
        // unowned (clip-path and the inner img's parallax are separate properties).
        const heroMedia = document.querySelector<HTMLElement>('[data-hero] [data-hero-media]');
        if (heroMedia) {
          gsap.fromTo(heroMedia, { scale: 1 }, {
            scale: 1.06, ease: 'none',
            scrollTrigger: { trigger: heroMedia, start: 'top top', end: 'bottom top', scrub: true },
          });
          cleanups.push(() => gsap.set(heroMedia, { clearProps: 'scale' }));
        }

        buildImageTrail();
        buildPinGallery();
        // depth sheets AFTER the pin: ScrollTriggers refresh in creation order,
        // so triggers below the filmstrip only see its pin-spacer offset if the
        // pin exists first (else every lower sheet's window lands ~3200px high)
        buildDepth();
        buildWorkShowpiece();
        buildVelocitySkew();
        buildMovementIndex();
        buildTilt();
        buildRegistration();
        buildLoupe();
        buildPressFinale();
      }

      // ---- Depth sheets: scroll-rate layering (data-depth) ----
      // A unitless rate relative to page scroll: r < 1 = a farther sheet (it
      // enters the viewport early, lags downward, exits late), r > 1 = a
      // nearer sheet that sweeps past faster. y reads exactly 0 when the
      // scope's centre crosses the viewport centre, so the layout is true
      // while you look at it. Elements sharing one scope ancestor drift as a
      // single rigid sheet (the contact regmarks). Owns ONLY the y px channel:
      // composes with owners of scale (hero settle), clip-path, xPercent /
      // yPercent (img parallax, split lines), skewX (velocity), rotation
      // (tilt), CSS vars and textContent. Never tag a node whose y a tween
      // owns (data-reveal, stagger children, data-hero-item), and never
      // inside the pinned filmstrip (guarded here).
      function buildDepth() {
        const els = gsap.utils
          .toArray<HTMLElement>('[data-depth]')
          .filter((el) => !el.closest('[data-pin-section]'));
        if (!els.length) return;
        const mm = gsap.matchMedia();
        mm.add('(min-width: 1024px) and (prefers-reduced-motion: no-preference)', () => {
          const tws = els.map((el) => {
            const r = parseFloat(el.dataset.depth || '') || 0.96;
            // figure-first scoping: tagged figures / bands / the marquee strip
            // self-scope (their own transit is the sheet's transit); loose
            // marks scope to their section so siblings share one trigger.
            const scope = (el.closest('figure, aside, .strip, section') as HTMLElement) || el;
            const drift = () => (1 - r) * (window.innerHeight + scope.offsetHeight) * 0.5;
            return gsap.fromTo(el, { y: () => -drift() }, {
              y: () => drift(),
              ease: 'none',
              scrollTrigger: {
                trigger: scope, start: 'top bottom', end: 'bottom top',
                scrub: true, invalidateOnRefresh: true,
              },
            });
          });
          return () => {
            tws.forEach((t) => { t.scrollTrigger?.kill(); t.kill(); });
            gsap.set(els, { clearProps: 'y' });
          };
        });
        cleanups.push(() => mm.revert());
      }

      // ---- Press finale: the catalogue goes to press (movement 06) ----
      // The cover photograph's halftone dots hang loose in 3D over the closing
      // plate and settle into register on scroll; the pointer stirs them like
      // loose ink (see src/scripts/press-finale.ts). three.js ships as its own
      // lazy chunk, fetched only when the finale approaches on desktop
      // fine-pointer motion-welcome visits; everyone else gets the section
      // exactly as authored. Reduced motion never reaches here (initMotion bails).
      function buildPressFinale() {
        if (!fine.matches) return;
        if (!window.matchMedia('(min-width: 1024px)').matches) return;
        const section = document.querySelector<HTMLElement>('[data-press-finale]');
        if (!section || !section.dataset.pressSrc) return;
        // Probe WebGL before paying for the chunk download; release the probe
        // context immediately so it never counts against the browser's budget.
        const probe = document.createElement('canvas');
        const probeGl = probe.getContext('webgl2') || probe.getContext('webgl');
        if (!probeGl) return;
        (probeGl as WebGLRenderingContext).getExtension('WEBGL_lose_context')?.loseContext();

        const myToken = initToken;
        let disposed = false;
        let dispose: (() => void) | null = null;
        const io = new IntersectionObserver(async (ents) => {
          if (!ents.some((en) => en.isIntersecting)) return;
          io.disconnect();
          let mod: any = null;
          try { mod = await import('../scripts/press-finale'); } catch (e) { return; }
          // The page may have swapped while the chunk loaded; never mount a
          // live renderer into a dead page (same token pattern as runLines).
          if (disposed || myToken !== initToken) return;
          const inst = mod.createPressFinale(section, {
            src: section.dataset.pressSrc!,
            ink: readColor('--ink', [0.17, 0.155, 0.14]),
            ochre: readColor('--ochre', [0.72, 0.47, 0.26]),
          });
          if (inst) dispose = inst.dispose;
        }, { rootMargin: '900px 0px' });
        io.observe(section);
        cleanups.push(() => { disposed = true; io.disconnect(); if (dispose) dispose(); dispose = null; });
      }

      // ---- Print registration: the closing plate "goes to press" ----
      // Four corner registration crosses draw into register as the finale enters (timed
      // with the hand-drawn swoosh's own enter). NOT pointer-gated, so the payoff reaches
      // touch. Static full crosses without JS / under reduced-motion (CSS default --reg:1),
      // so the framing never vanishes. New mark elements own their own transform.
      function buildRegistration() {
        const contact = document.querySelector<HTMLElement>('.contact');
        if (!contact) return;
        const marks = gsap.utils.toArray<HTMLElement>('.contact__regmark', contact);
        if (!marks.length) return;
        gsap.set(marks, { '--reg': 0 });
        const st = ScrollTrigger.create({
          trigger: contact, start: 'top 72%', once: true,
          onEnter: () => gsap.to(marks, { '--reg': 1, duration: 0.7, ease: 'power3.out', stagger: 0.07 }),
        });
        cleanups.push(() => { st.kill(); gsap.set(marks, { clearProps: '--reg' }); });
      }

      // ---- Darkroom loupe: inspect the printed contact-sheet proof ----
      // The whole sheet renders as an ochre+ink halftone screen (the unexposed proof,
      // developed in on enter); a cursor-following circular loupe resolves a window of
      // true colour with a faint ochre rim and a slight magnify. Reuses the hero's
      // halftone math at sheet scale. Fine pointers only; reduced-motion never reaches
      // here (initMotion bails). If WebGL is unavailable, the static colour <img> shows.
      function buildLoupe() {
        if (!fine.matches) return;
        const fig = document.querySelector<HTMLElement>('[data-loupe]');
        if (!fig) return;
        const img = fig.querySelector('img') as HTMLImageElement | null;
        if (!img) return;
        const canvas = document.createElement('canvas');
        const gl = (canvas.getContext('webgl', { antialias: true, premultipliedAlpha: false })
          || canvas.getContext('experimental-webgl')) as WebGLRenderingContext | null;
        if (!gl) return; // static colour proof shows

        const VERT = `attribute vec2 aPos; varying vec2 vUv;
          void main(){ vUv = aPos*0.5+0.5; gl_Position = vec4(aPos,0.0,1.0); }`;
        const FRAG = `
          #ifdef GL_FRAGMENT_PRECISION_HIGH
          precision highp float;
          #else
          precision mediump float;
          #endif
          varying vec2 vUv;
          uniform sampler2D uTex;
          uniform float uTime, uCells, uAspect, uImgAspect, uReveal, uLoupeR, uActive;
          uniform vec2 uLoupe;
          uniform vec3 uPaper, uInk, uOchre;
          float hash(vec2 p){ return fract(sin(dot(p, vec2(127.1,311.7)))*43758.5453); }
          vec2 coverUv(vec2 uv){
            vec2 s = vec2(1.0);
            if (uAspect > uImgAspect) s.y = uImgAspect/uAspect; else s.x = uAspect/uImgAspect;
            return (uv-0.5)*s + 0.5;
          }
          void main(){
            vec2 asp = vec2(uAspect, 1.0);
            float d = length((vUv - uLoupe) * asp);
            float inside = smoothstep(uLoupeR, uLoupeR-0.012, d) * uActive;
            vec2 mag = mix(vUv, uLoupe + (vUv - uLoupe)/1.08, inside); // gentle glass bulge
            vec3 photo = texture2D(uTex, clamp(coverUv(mag),0.0,1.0)).rgb;
            vec3 screenSample = texture2D(uTex, clamp(coverUv(vUv),0.0,1.0)).rgb;
            float lum = dot(screenSample, vec3(0.299,0.587,0.114));
            vec2 gv = vUv * asp * uCells;
            vec2 cell = fract(gv) - 0.5;
            float radius = sqrt(clamp(1.0-lum,0.0,1.0)) * 0.60;
            float dotv = smoothstep(radius, radius-0.06, length(cell));
            vec3 dotCol = mix(uOchre, uInk, smoothstep(0.35,0.78,1.0-lum));
            vec3 halftone = mix(uPaper, dotCol, dotv);
            halftone = mix(uPaper, halftone, uReveal); // develop the proof in on enter
            vec3 col = mix(halftone, photo, inside);    // true colour inside the lens
            float rim = smoothstep(uLoupeR, uLoupeR-0.006, d) - smoothstep(uLoupeR-0.012, uLoupeR-0.018, d);
            col = mix(col, uOchre, clamp(rim,0.0,1.0) * 0.7 * uActive);
            col += (hash(vUv*(1.0+uTime*0.0006))-0.5)*0.012;
            gl_FragColor = vec4(col,1.0);
          }`;

        function compile(type: number, src: string) {
          const sh = gl!.createShader(type)!; gl!.shaderSource(sh, src); gl!.compileShader(sh);
          if (!gl!.getShaderParameter(sh, gl!.COMPILE_STATUS)) { gl!.deleteShader(sh); return null; }
          return sh;
        }
        const vs = compile(gl.VERTEX_SHADER, VERT);
        const fs = compile(gl.FRAGMENT_SHADER, FRAG);
        if (!vs || !fs) return;
        const prog = gl.createProgram()!;
        gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
        if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return;
        gl.useProgram(prog);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
        const aPos = gl.getAttribLocation(prog, 'aPos');
        gl.enableVertexAttribArray(aPos);
        gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

        const u = (n: string) => gl!.getUniformLocation(prog, n);
        const uTex = u('uTex'), uTime = u('uTime'), uCells = u('uCells'), uAspect = u('uAspect'),
          uImgAspect = u('uImgAspect'), uReveal = u('uReveal'), uLoupeR = u('uLoupeR'), uActive = u('uActive'),
          uLoupe = u('uLoupe'), uPaper = u('uPaper'), uInk = u('uInk'), uOchre = u('uOchre');

        const paper = readColor('--paper', [0.965, 0.945, 0.906]);
        const ink = readColor('--ink', [0.17, 0.155, 0.14]);
        const ochre = readColor('--ochre', [0.72, 0.47, 0.26]);

        const tex = gl.createTexture();
        gl.bindTexture(gl.TEXTURE_2D, tex);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, new Uint8Array([238, 233, 224, 255]));

        const ctrl: any = { reveal: 0, _t: 0, _imgAspect: 1.54, _ready: false, _cells: 80,
          lx: 0.5, ly: 0.5, tx: 0.5, ty: 0.5, act: 0, actT: 0 };

        function uploadTexture() {
          if (!img!.naturalWidth) return;
          gl!.bindTexture(gl!.TEXTURE_2D, tex);
          gl!.pixelStorei(gl!.UNPACK_FLIP_Y_WEBGL, true);
          try { gl!.texImage2D(gl!.TEXTURE_2D, 0, gl!.RGBA, gl!.RGBA, gl!.UNSIGNED_BYTE, img!); } catch (e) { return; }
          ctrl._imgAspect = img!.naturalWidth / img!.naturalHeight;
          ctrl._ready = true;
        }
        if (img.complete && img.naturalWidth) uploadTexture();
        else img.addEventListener('load', uploadTexture, { once: true });

        let cssW = 0, cssH = 0;
        function resize() {
          const dpr = Math.min(1.5, window.devicePixelRatio || 1); // capped below the hero's 2
          const rect = fig.getBoundingClientRect();
          cssW = rect.width; cssH = rect.height;
          canvas.width = Math.max(1, Math.round(cssW * dpr));
          canvas.height = Math.max(1, Math.round(cssH * dpr));
          gl!.viewport(0, 0, canvas.width, canvas.height);
          ctrl._cells = Math.max(40, Math.min(96, Math.round(cssH / 9)));
        }

        function render() {
          if (!cssW) resize();
          ctrl.lx += (ctrl.tx - ctrl.lx) * 0.18;
          ctrl.ly += (ctrl.ty - ctrl.ly) * 0.18;
          ctrl.act += (ctrl.actT - ctrl.act) * 0.14;
          gl!.useProgram(prog);
          gl!.activeTexture(gl!.TEXTURE0);
          gl!.bindTexture(gl!.TEXTURE_2D, tex);
          gl!.uniform1i(uTex, 0);
          gl!.uniform1f(uTime, ctrl._t);
          gl!.uniform1f(uCells, ctrl._cells);
          gl!.uniform1f(uAspect, cssW / Math.max(1, cssH));
          gl!.uniform1f(uImgAspect, ctrl._ready ? ctrl._imgAspect : cssW / Math.max(1, cssH));
          gl!.uniform1f(uReveal, ctrl.reveal);
          gl!.uniform1f(uLoupeR, 0.13);
          gl!.uniform1f(uActive, ctrl.act);
          gl!.uniform2f(uLoupe, ctrl.lx, ctrl.ly);
          gl!.uniform3f(uPaper, paper[0], paper[1], paper[2]);
          gl!.uniform3f(uInk, ink[0], ink[1], ink[2]);
          gl!.uniform3f(uOchre, ochre[0], ochre[1], ochre[2]);
          gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
        }

        canvas.className = 'loupe-canvas';
        canvas.setAttribute('aria-hidden', 'true');
        fig.insertBefore(canvas, fig.firstChild);
        resize();

        const startT = performance.now();
        let running = false, onScreen = false, painted = false, lastWake = 0;
        let wd: number | undefined;
        function frame() {
          ctrl._t = performance.now() - startT;
          render();
          if (!painted && ctrl._ready) { painted = true; img!.style.opacity = '0'; if (wd) clearTimeout(wd); }
          // self-park once the proof has developed and the lens is idle and faded out
          if (performance.now() - lastWake > 1400 && ctrl.reveal > 0.999 && ctrl.act < 0.01) pause();
        }
        function play() { if (!running) { running = true; gsap.ticker.add(frame); } }
        function pause() { if (running) { running = false; gsap.ticker.remove(frame); } }
        function wake() { lastWake = performance.now(); if (onScreen) play(); }

        // Develop the proof in (paper -> halftone) when it scrolls into view.
        const revealST = ScrollTrigger.create({
          trigger: fig, start: 'top 80%', once: true,
          onEnter: () => { wake(); gsap.to(ctrl, { reveal: 1, duration: 1.4, ease: 'power2.inOut' }); },
        });

        let io: IntersectionObserver | null = null;
        if (typeof IntersectionObserver !== 'undefined') {
          io = new IntersectionObserver((ents) => { onScreen = ents[0].isIntersecting; if (onScreen) wake(); else pause(); }, { rootMargin: '120px' });
          io.observe(fig);
        }
        wake();
        wd = window.setTimeout(() => { if (!painted) img!.style.opacity = ''; }, 1500);

        function onMove(e: PointerEvent) {
          const rect = fig.getBoundingClientRect();
          ctrl.tx = (e.clientX - rect.left) / Math.max(1, rect.width);
          ctrl.ty = 1 - (e.clientY - rect.top) / Math.max(1, rect.height);
          ctrl.actT = 1; wake();
        }
        function onEnter() { ctrl.actT = 1; wake(); }
        function onLeave() { ctrl.actT = 0; wake(); }
        fig.addEventListener('pointermove', onMove, { passive: true });
        fig.addEventListener('pointerenter', onEnter, { passive: true });
        fig.addEventListener('pointerleave', onLeave, { passive: true });

        const onWinResize = () => resize();
        window.addEventListener('resize', onWinResize);

        cleanups.push(() => {
          pause();
          if (wd) clearTimeout(wd);
          revealST.kill();
          if (io) io.disconnect();
          window.removeEventListener('resize', onWinResize);
          fig.removeEventListener('pointermove', onMove);
          fig.removeEventListener('pointerenter', onEnter);
          fig.removeEventListener('pointerleave', onLeave);
          img!.style.opacity = '';
          try { canvas.remove(); } catch (e) {}
          const lose = gl!.getExtension('WEBGL_lose_context'); if (lose) lose.loseContext();
        });
      }

      // A masked line-reveal wraps each line in an overflow:hidden box so the
      // text can slide up from behind it. That mask is only needed *during* the
      // slide; once the line settles at yPercent:0 it still clips anything past
      // the (tight) line box — notably the "g" descender on the hero title.
      // Restore overflow on the wrappers when the reveal finishes.
      function unmaskLines(split: any) {
        split.lines.forEach((line: HTMLElement) => {
          const mask = line.parentElement;
          if (mask) mask.style.overflow = 'visible';
          line.style.willChange = 'auto'; // drop the GPU layer once the line has settled
        });
      }

      // ---- Kinetic variable type: glyph weight follows the cursor ----
      // Each split character carries a --wght var; one rAF loop eases every
      // glyph toward a target set by its distance to the pointer (smooth
      // falloff), plus a faint global breath driven by scroll velocity.
      // Fine pointers only; reduced-motion never reaches here. Centres are
      // measured once the reveal has settled, so they're read at rest.
      function setupFluxFor(el: HTMLElement, split: any) {
        const chars: HTMLElement[] = Array.from(split.chars || []);
        if (!chars.length) return;
        const base = el.getBoundingClientRect();
        const fontSize = parseFloat(getComputedStyle(el).fontSize) || 48;
        const radius = Math.min(360, Math.max(150, fontSize * 2));
        const cx: number[] = [], cy: number[] = [], cur: number[] = [];
        chars.forEach((c) => {
          const r = c.getBoundingClientRect();
          cx.push(r.left - base.left + r.width / 2);
          cy.push(r.top - base.top + r.height / 2);
          cur.push(FLUX_BASE);
        });
        fluxRegs.push({ el, chars, cx, cy, cur, radius });
        ensureFluxRunning();
      }

      function fluxTick() {
        scrollFlux *= 0.9;
        if (scrollFlux < 0.001) scrollFlux = 0;
        if (!fluxPointer.active && scrollFlux === 0 && fluxAtRest) return;
        const vh = window.innerHeight;
        const rects = fluxRegs.map((reg) => reg.el.getBoundingClientRect());
        let allRest = true;
        for (let r = 0; r < fluxRegs.length; r++) {
          const reg = fluxRegs[r];
          const box = rects[r];
          const onscreen = box.bottom > -120 && box.top < vh + 120;
          for (let i = 0; i < reg.chars.length; i++) {
            let boost = scrollFlux * FLUX_SCROLL;
            if (onscreen && fluxPointer.active) {
              const dx = fluxPointer.x - (box.left + reg.cx[i]);
              const dy = fluxPointer.y - (box.top + reg.cy[i]);
              const f = 1 - Math.min(1, Math.hypot(dx, dy) / reg.radius);
              if (f > 0) boost += f * f * FLUX_PEAK;
            }
            const target = FLUX_BASE + boost;
            const next = reg.cur[i] + (target - reg.cur[i]) * 0.18;
            if (Math.abs(next - reg.cur[i]) > 0.05) {
              reg.cur[i] = next;
              reg.chars[i].style.setProperty('--wght', next.toFixed(1));
              allRest = false;
            } else if (Math.abs(next - FLUX_BASE) > 0.05) {
              allRest = false;
            }
          }
        }
        fluxAtRest = !fluxPointer.active && scrollFlux === 0 && allRest;
      }

      function onFluxMove(e: PointerEvent) { fluxPointer.x = e.clientX; fluxPointer.y = e.clientY; fluxPointer.active = true; fluxAtRest = false; }
      function onFluxLeave() { fluxPointer.active = false; }
      let fluxResizeT: number | undefined;
      function remeasureFlux() {
        for (const reg of fluxRegs) {
          const base = reg.el.getBoundingClientRect();
          reg.chars.forEach((c, i) => {
            const r = c.getBoundingClientRect();
            reg.cx[i] = r.left - base.left + r.width / 2;
            reg.cy[i] = r.top - base.top + r.height / 2;
          });
        }
      }
      function onFluxResize() {
        clearTimeout(fluxResizeT);
        fluxResizeT = window.setTimeout(remeasureFlux, 200);
      }

      function ensureFluxRunning() {
        if (fluxRunning) return;
        fluxRunning = true;
        window.addEventListener('pointermove', onFluxMove, { passive: true });
        document.addEventListener('pointerleave', onFluxLeave);
        // Scroll "breath" reads velocity from GSAP's own scroll machinery rather than a
        // separate scroll listener (one source of truth; idiomatic ScrollTrigger).
        const fluxST = ScrollTrigger.create({
          onUpdate: (self) => {
            const v = Math.min(1, Math.abs(self.getVelocity()) / 5000);
            if (v > scrollFlux) { scrollFlux = v; fluxAtRest = false; }
          },
        });
        window.addEventListener('resize', onFluxResize);
        gsap.ticker.add(fluxTick);
        if (document.fonts && document.fonts.ready) document.fonts.ready.then(remeasureFlux).catch(() => {});
        cleanups.push(() => {
          gsap.ticker.remove(fluxTick);
          window.removeEventListener('pointermove', onFluxMove);
          document.removeEventListener('pointerleave', onFluxLeave);
          fluxST.kill();
          window.removeEventListener('resize', onFluxResize);
          clearTimeout(fluxResizeT);
          fluxRunning = false;
        });
      }

      // ---- "Developing plate": WebGL halftone reveal for the hero photo ----
      // The image loads as an ochre+ink halftone dot screen and "develops" into
      // the full photograph as progress eases 0→1 on the hero timeline, with a
      // faint living grain and a soft cursor ripple. Pure GPU; returns null if
      // WebGL is unavailable so the caller keeps the clip-path reveal. Reduced
      // motion never reaches here, so the plain <img> shows.
      function readColor(prop: string, fb: number[]): number[] {
        try {
          const v = getComputedStyle(document.documentElement).getPropertyValue(prop).trim();
          if (!v) return fb;
          const c = document.createElement('canvas'); c.width = c.height = 1;
          const ctx = c.getContext('2d'); if (!ctx) return fb;
          ctx.fillStyle = '#000'; ctx.fillStyle = v; ctx.fillRect(0, 0, 1, 1);
          const d = ctx.getImageData(0, 0, 1, 1).data;
          if (d[0] === 0 && d[1] === 0 && d[2] === 0) return fb; // colour failed to parse
          return [d[0] / 255, d[1] / 255, d[2] / 255];
        } catch (e) { return fb; }
      }

      function setupHalftone(media: HTMLElement): any {
        const img = media.querySelector('img') as HTMLImageElement | null;
        if (!img) return null;
        const canvas = document.createElement('canvas');
        const gl = (canvas.getContext('webgl', { antialias: true, premultipliedAlpha: false })
          || canvas.getContext('experimental-webgl')) as WebGLRenderingContext | null;
        if (!gl) return null;

        const VERT = `attribute vec2 aPos; varying vec2 vUv;
          void main(){ vUv = aPos * 0.5 + 0.5; gl_Position = vec4(aPos, 0.0, 1.0); }`;
        const FRAG = `
          #ifdef GL_FRAGMENT_PRECISION_HIGH
          precision highp float;
          #else
          precision mediump float;
          #endif
          varying vec2 vUv;
          uniform sampler2D uTex;
          uniform float uProgress, uTime, uCells, uAspect, uImgAspect;
          uniform vec3 uPaper, uInk, uOchre;
          #define NPTS 14
          uniform vec3 uPts[NPTS]; // xy = uv position, z = strength (decays)
          float hash(vec2 p){ return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453); }
          vec2 coverUv(vec2 uv){
            vec2 s = vec2(1.0);
            if (uAspect > uImgAspect) s.y = uImgAspect / uAspect; else s.x = uAspect / uImgAspect;
            return (uv - 0.5) * s + 0.5;
          }
          void main(){
            vec2 asp = vec2(uAspect, 1.0);
            // Fluid ink wake: sum decaying pushes from recent cursor samples.
            vec2 disp = vec2(0.0);
            float stir = 0.0;
            for (int i = 0; i < NPTS; i++) {
              vec3 p = uPts[i];
              vec2 diff = (vUv - p.xy) * asp;
              float d = length(diff) + 1e-4;
              float infl = p.z * exp(-d * 8.0);
              vec2 dir = diff / d;
              disp += dir * infl * 0.06;                                 // outward push
              disp += dir * sin(d * 26.0 - uTime * 0.006) * infl * 0.007; // ripple ring
              stir += infl;
            }
            stir = clamp(stir, 0.0, 1.0);

            vec2 iuv = coverUv(vUv + disp);
            vec3 photo = texture2D(uTex, clamp(iuv, 0.0, 1.0)).rgb;
            float lum = dot(photo, vec3(0.299, 0.587, 0.114));
            vec2 gv = (vUv + disp) * asp * uCells;
            vec2 cell = fract(gv) - 0.5;
            float radius = sqrt(clamp(1.0 - lum, 0.0, 1.0)) * 0.60;
            float inside = smoothstep(radius, radius - 0.06, length(cell));
            vec3 dotCol = mix(uOchre, uInk, smoothstep(0.35, 0.78, 1.0 - lum));
            vec3 halftone = mix(uPaper, dotCol, inside);
            float raw = 0.60 * (1.0 - lum) + 0.25 * hash(floor(gv)) + 0.15 * (1.0 - vUv.y);
            float phase = 0.24 + 0.64 * clamp(raw, 0.0, 1.0);
            float t = smoothstep(phase - 0.22, phase + 0.10, uProgress);
            vec3 col = mix(halftone, photo, t);
            // cursor stirs up dense ochre-ink dots (visible over any brightness), settling as strength decays
            float wakeInside = smoothstep(0.46, 0.30, length(cell));
            vec3 wakeCol = mix(uPaper, mix(uOchre, uInk, 0.55), wakeInside);
            col = mix(col, wakeCol, clamp(stir, 0.0, 1.0) * 0.8);
            col += (hash(vUv * (1.0 + uTime * 0.0007)) - 0.5) * 0.016;
            gl_FragColor = vec4(col, 1.0);
          }`;

        function compile(type: number, src: string) {
          const sh = gl!.createShader(type)!; gl!.shaderSource(sh, src); gl!.compileShader(sh);
          if (!gl!.getShaderParameter(sh, gl!.COMPILE_STATUS)) { gl!.deleteShader(sh); return null; }
          return sh;
        }
        const vs = compile(gl.VERTEX_SHADER, VERT);
        const fs = compile(gl.FRAGMENT_SHADER, FRAG);
        if (!vs || !fs) return null;
        const prog = gl.createProgram()!;
        gl.attachShader(prog, vs); gl.attachShader(prog, fs); gl.linkProgram(prog);
        if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return null;
        gl.useProgram(prog);

        const buf = gl.createBuffer();
        gl.bindBuffer(gl.ARRAY_BUFFER, buf);
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);
        const aPos = gl.getAttribLocation(prog, 'aPos');
        gl.enableVertexAttribArray(aPos);
        gl.vertexAttribPointer(aPos, 2, gl.FLOAT, false, 0, 0);

        const u = (n: string) => gl!.getUniformLocation(prog, n);
        const uTex = u('uTex'), uProgress = u('uProgress'), uTime = u('uTime'), uCells = u('uCells'),
          uAspect = u('uAspect'), uImgAspect = u('uImgAspect'), uPts = u('uPts'),
          uPaper = u('uPaper'), uInk = u('uInk'), uOchre = u('uOchre');

        const paper = readColor('--paper', [0.965, 0.945, 0.906]);
        const ink = readColor('--ink', [0.17, 0.155, 0.14]);
        const ochre = readColor('--ochre', [0.72, 0.47, 0.26]);

        const tex = gl.createTexture();
        gl.bindTexture(gl.TEXTURE_2D, tex);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, new Uint8Array([205, 195, 175, 255]));

        const ctrl: any = { progress: 0, _t: 0, _imgAspect: 1, _ready: false, _cells: 80 };
        // Ring buffer of recent cursor samples driving the fluid wake (xy uv + strength).
        const HPTS = 14;
        const pts = new Float32Array(HPTS * 3);
        let ptHead = 0;

        function uploadTexture() {
          if (!img!.naturalWidth) return;
          gl!.bindTexture(gl!.TEXTURE_2D, tex);
          gl!.pixelStorei(gl!.UNPACK_FLIP_Y_WEBGL, true);
          try { gl!.texImage2D(gl!.TEXTURE_2D, 0, gl!.RGBA, gl!.RGBA, gl!.UNSIGNED_BYTE, img!); } catch (e) { return; }
          ctrl._imgAspect = img!.naturalWidth / img!.naturalHeight;
          ctrl._ready = true;
        }
        if (img.complete && img.naturalWidth) uploadTexture();
        else img.addEventListener('load', uploadTexture, { once: true });

        let cssW = 0, cssH = 0;
        function resize() {
          const dpr = Math.min(2, window.devicePixelRatio || 1);
          const rect = media.getBoundingClientRect();
          cssW = rect.width; cssH = rect.height;
          canvas.width = Math.max(1, Math.round(cssW * dpr));
          canvas.height = Math.max(1, Math.round(cssH * dpr));
          gl!.viewport(0, 0, canvas.width, canvas.height);
          ctrl._cells = Math.max(28, Math.min(80, Math.round(cssH / 11)));
        }

        function render() {
          if (!cssW) resize();
          gl!.useProgram(prog);
          gl!.activeTexture(gl!.TEXTURE0);
          gl!.bindTexture(gl!.TEXTURE_2D, tex);
          gl!.uniform1i(uTex, 0);
          gl!.uniform1f(uProgress, ctrl.progress);
          gl!.uniform1f(uTime, ctrl._t);
          gl!.uniform1f(uCells, ctrl._cells);
          gl!.uniform1f(uAspect, cssW / Math.max(1, cssH));
          gl!.uniform1f(uImgAspect, ctrl._ready ? ctrl._imgAspect : cssW / Math.max(1, cssH));
          for (let i = 2; i < pts.length; i += 3) pts[i] *= 0.9; // decay sample strengths
          gl!.uniform3fv(uPts, pts);
          gl!.uniform3f(uPaper, paper[0], paper[1], paper[2]);
          gl!.uniform3f(uInk, ink[0], ink[1], ink[2]);
          gl!.uniform3f(uOchre, ochre[0], ochre[1], ochre[2]);
          gl!.drawArrays(gl!.TRIANGLE_STRIP, 0, 4);
        }

        canvas.className = 'halftone-canvas';
        canvas.setAttribute('aria-hidden', 'true');
        media.insertBefore(canvas, media.firstChild);
        // Don't hide the photo up front. If WebGL initialises but never paints
        // (blacklisted/software GPU, lost context), an opaque-but-blank canvas would
        // leave the hero empty. Keep the <img> until a real-texture frame is confirmed
        // (the opaque canvas covers it while it develops, so no flash when GL works),
        // and a watchdog restores the photo if that frame never lands.
        resize();

        const startT = performance.now();
        let running = false, painted = false;
        let wd: number | undefined;
        function frame() {
          ctrl._t = performance.now() - startT; render();
          if (!painted && ctrl._ready) { painted = true; img.style.opacity = '0'; if (wd) clearTimeout(wd); }
        }
        function play() { if (!running) { running = true; gsap.ticker.add(frame); } }
        function pause() { if (running) { running = false; gsap.ticker.remove(frame); } }

        let io: IntersectionObserver | null = null;
        if (typeof IntersectionObserver !== 'undefined') {
          io = new IntersectionObserver((ents) => { if (ents[0].isIntersecting) play(); else pause(); }, { rootMargin: '140px' });
          io.observe(media);
        }
        play();
        // Safety net: if no real-texture frame paints within 1.5s, reveal the photo.
        wd = window.setTimeout(() => { if (!painted) img.style.opacity = ''; }, 1500);

        const onWinResize = () => resize();
        window.addEventListener('resize', onWinResize);

        function onMove(e: MouseEvent) {
          const rect = media.getBoundingClientRect();
          const mx = (e.clientX - rect.left) / Math.max(1, rect.width);
          const my = 1 - (e.clientY - rect.top) / Math.max(1, rect.height);
          pts[ptHead * 3] = mx; pts[ptHead * 3 + 1] = my; pts[ptHead * 3 + 2] = 1.0;
          ptHead = (ptHead + 1) % HPTS;
        }
        if (fine.matches) media.addEventListener('mousemove', onMove);

        cleanups.push(() => {
          pause();
          if (wd) clearTimeout(wd);
          if (io) io.disconnect();
          window.removeEventListener('resize', onWinResize);
          media.removeEventListener('mousemove', onMove);
          img.style.opacity = '';
          try { canvas.remove(); } catch (e) {}
          const lose = gl!.getExtension('WEBGL_lose_context'); if (lose) lose.loseContext();
        });

        return ctrl;
      }

      // ---- Cursor image-trail: gallery prints flick out along the pointer ----
      // As the cursor sweeps the hero, real gallery frames spawn from a small
      // recycled pool and animate in/out like prints spread across a table.
      // Fine pointers only; never built under reduced-motion.
      function buildImageTrail() {
        if (!fine.matches) return;
        const host = document.querySelector<HTMLElement>('[data-image-trail]');
        if (!host) return;
        let images: string[] = [];
        try { images = JSON.parse(host.dataset.trailImages || '[]'); } catch (e) { images = []; }
        if (!images.length) return;

        const layer = document.createElement('div');
        layer.className = 'trail-layer';
        layer.setAttribute('aria-hidden', 'true');
        host.appendChild(layer);

        const POOL = 12;
        const plates: HTMLElement[] = [];
        for (let i = 0; i < POOL; i++) {
          const fig = document.createElement('div');
          fig.className = 'trail-plate';
          const im = document.createElement('img');
          im.decoding = 'async'; im.alt = '';
          fig.appendChild(im);
          layer.appendChild(fig);
          plates.push(fig);
        }
        images.forEach((src) => { const p = new Image(); p.src = src; }); // warm the cache

        // The hero photo is the fluid-ink zone; don't spawn prints over it.
        const photoEl = host.querySelector<HTMLElement>('[data-hero-media]');
        let imgIdx = 0, poolIdx = 0, lastX = 0, lastY = 0, primed = false;
        const STEP2 = 92 * 92; // min px² travelled between spawns

        function spawn(x: number, y: number) {
          const fig = plates[poolIdx % POOL]; poolIdx++;
          const im = fig.querySelector('img') as HTMLImageElement;
          im.src = images[imgIdx % images.length]; imgIdx++;
          const rot = (Math.random() * 2 - 1) * 7;
          gsap.killTweensOf(fig);
          gsap.set(fig, { left: x, top: y, xPercent: -50, yPercent: -50, rotate: rot, scale: 0.7, y: 0, opacity: 0, zIndex: poolIdx });
          gsap.timeline()
            .to(fig, { scale: 1, opacity: 1, duration: 0.38, ease: 'power3.out' })
            .to(fig, { opacity: 0, scale: 1.06, y: 28, duration: 0.72, ease: 'power2.in' }, 0.42);
        }

        function onMove(e: PointerEvent) {
          const rect = layer.getBoundingClientRect();
          const x = e.clientX - rect.left, y = e.clientY - rect.top;
          if (!primed) { lastX = x; lastY = y; primed = true; return; }
          const dx = x - lastX, dy = y - lastY;
          if (dx * dx + dy * dy >= STEP2) {
            lastX = x; lastY = y;
            if (photoEl) {
              const pr = photoEl.getBoundingClientRect();
              if (e.clientX >= pr.left && e.clientX <= pr.right && e.clientY >= pr.top && e.clientY <= pr.bottom) return;
            }
            spawn(x, y);
          }
        }
        function onLeave() { primed = false; }

        host.addEventListener('pointermove', onMove);
        host.addEventListener('pointerleave', onLeave);

        cleanups.push(() => {
          host.removeEventListener('pointermove', onMove);
          host.removeEventListener('pointerleave', onLeave);
          plates.forEach((p) => gsap.killTweensOf(p));
          try { layer.remove(); } catch (e) {}
        });
      }

      // ---- Pinned horizontal filmstrip (ScrollTrigger pin + scrub) ----
      // Desktop + motion only (gsap.matchMedia); below 1024px or reduced-motion
      // it stays a normal CSS swipe strip. matchMedia reverts the pin + its
      // ScrollTrigger cleanly when the query stops matching or on page swap.
      function buildPinGallery() {
        const section = document.querySelector<HTMLElement>('[data-pin-section]');
        const track = section ? section.querySelector<HTMLElement>('[data-pin-track]') : null;
        if (!section || !track) return;
        const mm = gsap.matchMedia();
        mm.add('(min-width: 1024px) and (prefers-reduced-motion: no-preference)', () => {
          section.classList.add('is-pinned');
          const distance = () => Math.max(0, track.scrollWidth - section.clientWidth);

          // Guided gallery walk: a fixed caption tracks which plate is "current" and the
          // current plate is lit/lifted (CSS .is-current). The index is driven from the
          // pin tween's own progress, so it walks evenly 01 -> 08 and lights the first and
          // last plates (edge plates never physically reach dead-centre, so a per-plate
          // centre trigger would skip them).
          const plates = gsap.utils.toArray<HTMLElement>('.filmstrip__plate', track);
          const curEl = section.querySelector<HTMLElement>('[data-strip-cur]');
          const placeEl = section.querySelector<HTMLElement>('[data-strip-place]');
          let curIdx = -1;
          const setCurrent = (i: number) => {
            if (i === curIdx || i < 0 || i >= plates.length) return;
            curIdx = i;
            plates.forEach((p, j) => p.classList.toggle('is-current', j === i));
            if (curEl) curEl.textContent = String(i + 1).padStart(2, '0');
            if (placeEl) placeEl.textContent = plates[i]?.dataset.place || '';
          };

          // "The contact sheet develops": the plates clip-reveal (top-down, the site's
          // reveal-clip vocabulary) and their wall-labels fade in over the FIRST ~35% of
          // the pin, so the wall is hung plate by plate as the walk begins underneath.
          // Driven from this same tween's progress (no second ScrollTrigger). Writes only
          // the --develop var (CSS maps it to clip-path on .media-frame + wall-label
          // opacity); never plate transform/opacity, so it composes with tilt + the
          // lit/dim current state. CSS default --develop:1 keeps everything shown without JS.
          const N = plates.length;
          const devSet = plates.map((p) => (v: number) => p.style.setProperty('--develop', String(v)));
          devSet.forEach((set) => set(0));
          const clamp01 = gsap.utils.clamp(0, 1);
          const develop = (progress: number) => {
            for (let i = 0; i < N; i++) devSet[i](clamp01(progress / 0.35 * N - i));
          };

          gsap.to(track, {
            x: () => -distance(),
            ease: 'none',
            scrollTrigger: {
              trigger: section,
              start: 'top top',
              end: () => '+=' + distance(),
              pin: true,
              scrub: 0.6,
              // Settle on whole plates: a flick ends with one frame centred in the
              // walk instead of paused between two. Snap points coincide with
              // setCurrent's rounding, so the HUD always rests on its own number.
              snap: {
                snapTo: 1 / (N - 1),
                duration: { min: 0.2, max: 0.6 },
                ease: 'power2.inOut',
                delay: 0.1,
                directional: true,
              },
              anticipatePin: 1,
              invalidateOnRefresh: true,
              onUpdate: (self) => { setCurrent(Math.round(self.progress * (N - 1))); develop(self.progress); },
            },
          });
          setCurrent(0); // lit before the first scroll frame, so the strip never reads all-dimmed

          return () => {
            plates.forEach((p) => { p.classList.remove('is-current'); p.style.removeProperty('--develop'); });
            section.classList.remove('is-pinned');
            gsap.set(track, { clearProps: 'transform' });
          };
        });
        cleanups.push(() => mm.revert());
      }

      // ---- Selected-work showpiece: each row is a developing catalogue plate ----
      // On approach the oversized index numeral (the projects have no photograph,
      // so the number IS the plate) fades up, scales in and drifts with the cursor
      // for parallax depth; the ochre rule draws across and the row warms (CSS).
      // Fine pointers only; never built under reduced-motion (initMotion bails).
      function buildWorkShowpiece() {
        if (!fine.matches) return;
        const list = document.querySelector<HTMLElement>('[data-work-list]');
        if (!list) return;
        gsap.utils.toArray<HTMLElement>('.work-row', list).forEach((row) => {
          const ghost = row.querySelector<HTMLElement>('.work-row__ghost');
          const title = row.querySelector<HTMLElement>('.work-row__title');
          if (!ghost) return;
          // Rest-state print-through: the numeral shows faintly behind the row
          // (a back sheet through the paper); hover pulls that sheet forward.
          gsap.set(ghost, { scale: 0.95, autoAlpha: 0.22 });
          const gx = gsap.quickTo(ghost, 'x', { duration: 0.8, ease: 'power3' });
          const gy = gsap.quickTo(ghost, 'y', { duration: 0.8, ease: 'power3' });
          const tx = title ? gsap.quickTo(title, 'x', { duration: 0.6, ease: 'power3' }) : null;
          const enter = () => gsap.to(ghost, { autoAlpha: 1, scale: 1, duration: 0.6, ease: 'power3.out' });
          const move = (e: MouseEvent) => {
            const r = row.getBoundingClientRect();
            const nx = (e.clientX - (r.left + r.width / 2)) / r.width;
            const ny = (e.clientY - (r.top + r.height / 2)) / r.height;
            gx(nx * 48); gy(ny * 24);
            if (tx) tx(nx * 10);
          };
          const leave = () => {
            gsap.to(ghost, { autoAlpha: 0.22, scale: 0.95, duration: 0.5, ease: 'power2.out' });
            gx(0); gy(0); if (tx) tx(0);
          };
          row.addEventListener('mouseenter', enter);
          row.addEventListener('mousemove', move);
          row.addEventListener('mouseleave', leave);
          cleanups.push(() => {
            row.removeEventListener('mouseenter', enter);
            row.removeEventListener('mousemove', move);
            row.removeEventListener('mouseleave', leave);
            gsap.set(ghost, { clearProps: 'all' });
            if (title) gsap.set(title, { clearProps: 'transform' });
          });
        });
      }

      // ---- Scroll-velocity skew: targets lean a few degrees with scroll speed and
      // spring back to upright (the classic GSAP "scroll has weight" flourish).
      // Applied to the marquee words and filmstrip plates (NOT their animated
      // tracks, to avoid transform conflicts). Never built under reduced-motion.
      function buildVelocitySkew() {
        const targets = gsap.utils.toArray<HTMLElement>('[data-velocity-skew]');
        if (!targets.length && !marqueeRegs.length) return;
        const setSkew = targets.length ? gsap.quickSetter(targets, 'skewX', 'deg') : null;
        const clamp = gsap.utils.clamp(-9, 9);
        // One velocity reader drives both flourishes: the lean on tagged elements
        // and a speed surge on the keyword marquee (fast scroll spins the press;
        // both spring back to rest on the same decay tween).
        const proxy = { skew: 0, boost: 0 };
        const apply = () => {
          if (setSkew) setSkew(proxy.skew);
          for (const r of marqueeRegs) if (!r.hovered) r.tw.timeScale(1 + proxy.boost);
        };
        const st = ScrollTrigger.create({
          onUpdate: (self) => {
            const raw = self.getVelocity();
            const v = clamp(raw / -260);
            const b = Math.min(2.5, Math.abs(raw) / 1200);
            if (Math.abs(v) > Math.abs(proxy.skew) || b > proxy.boost) {
              if (Math.abs(v) > Math.abs(proxy.skew)) proxy.skew = v;
              if (b > proxy.boost) proxy.boost = b;
              gsap.to(proxy, { skew: 0, boost: 0, duration: 0.7, ease: 'power3', overwrite: true, onUpdate: apply });
            }
          },
        });
        cleanups.push(() => {
          st.kill();
          if (targets.length) gsap.set(targets, { clearProps: 'skewX' });
          for (const r of marqueeRegs) r.tw.timeScale(1);
        });
      }

      // ---- Catalogue movement indicator: a fixed "you are here" tab tracking which
      // of the six movements (01-06) is in view, with a tick rail. Homepage only
      // (no-ops where [data-movement-index] is absent); shown on desktop via CSS.
      function buildMovementIndex() {
        const hud = document.querySelector<HTMLElement>('[data-movement-index]');
        if (!hud) return;
        const sections = gsap.utils.toArray<HTMLElement>('[data-movement]');
        if (!sections.length) return;
        const curEl = hud.querySelector<HTMLElement>('[data-movement-cur]');
        const nameEl = hud.querySelector<HTMLElement>('[data-movement-name]');
        const ticks = Array.from(hud.querySelectorAll<HTMLElement>('.movement-index__tick'));
        let active = -1;
        const setActive = (i: number) => {
          if (i === active || i < 0 || i >= sections.length) return;
          active = i;
          if (curEl) curEl.textContent = String(i + 1).padStart(2, '0');
          if (nameEl) nameEl.textContent = sections[i].dataset.movement || '';
          ticks.forEach((t, j) => t.classList.toggle('is-active', j === i));
        };
        sections.forEach((sec, i) => {
          ScrollTrigger.create({
            trigger: sec, start: 'top 55%', end: 'bottom 55%',
            onToggle: (self) => { if (self.isActive) setActive(i); },
          });
        });
        const vis = ScrollTrigger.create({
          trigger: sections[0], start: 'top 85%',
          endTrigger: sections[sections.length - 1], end: 'bottom 60%',
          onToggle: (self) => hud.classList.toggle('is-visible', self.isActive),
        });
        cleanups.push(() => { vis.kill(); hud.classList.remove('is-visible'); ticks.forEach((t) => t.classList.remove('is-active')); });
      }

      // ---- 3D pointer tilt (fine pointers): an element rotates toward the cursor
      // in perspective. On the filmstrip plate media-frames; composes with the
      // plate's velocity-skew (li) and the image hover-zoom (img) as separate
      // transform owners. Pointer-driven, so it does not jitter during the pin. ----
      function buildTilt() {
        if (!fine.matches) return;
        const clamp = gsap.utils.clamp(-1, 1);
        gsap.utils.toArray<HTMLElement>('[data-tilt]').forEach((el) => {
          const max = parseFloat(el.dataset.tilt || '') || 8;
          const rx = gsap.quickTo(el, 'rotationX', { duration: 0.5, ease: 'power3' });
          const ry = gsap.quickTo(el, 'rotationY', { duration: 0.5, ease: 'power3' });
          const move = (e: MouseEvent) => {
            const r = el.getBoundingClientRect();
            const nx = clamp((e.clientX - (r.left + r.width / 2)) / (r.width / 2));
            const ny = clamp((e.clientY - (r.top + r.height / 2)) / (r.height / 2));
            ry(nx * max); rx(ny * -max);
          };
          const leave = () => { rx(0); ry(0); };
          el.addEventListener('mousemove', move);
          el.addEventListener('mouseleave', leave);
          cleanups.push(() => { el.removeEventListener('mousemove', move); el.removeEventListener('mouseleave', leave); gsap.set(el, { clearProps: 'rotationX,rotationY' }); });
        });
      }

      function buildLineMotion() {
        // Hero load timeline
        const hero = document.querySelector<HTMLElement>('[data-hero]');
        if (hero) {
          heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
          const headline = hero.querySelector<HTMLElement>('[data-hero-headline]');
          if (headline) {
            const flux = headline.hasAttribute('data-flux') && fine.matches;
            const split = SplitText.create(headline, { type: flux ? 'lines,chars' : 'lines', mask: 'lines', linesClass: 'split-line', charsClass: 'flux-char', autoSplit: false });
            splits.push(split);
            gsap.set(headline, { visibility: 'visible' });
            gsap.set(split.lines, { willChange: 'transform' });
            heroTl.from(split.lines, {
              yPercent: 118, duration: 1.15, stagger: 0.09, ease: 'power4.out',
              onComplete: () => { unmaskLines(split); if (flux) setupFluxFor(headline, split); },
            }, 0.1);
          }
          const media = hero.querySelector<HTMLElement>('[data-hero-media]');
          if (media) {
            const ht = media.hasAttribute('data-halftone') ? setupHalftone(media) : null;
            if (ht) {
              // The halftone "develop" IS the reveal — skip the clip-path wipe.
              // A longer develop makes the signature plate read as a slower exposure.
              gsap.set(media, { clipPath: 'inset(0 0 0% 0)' });
              heroTl.fromTo(ht, { progress: 0 }, { progress: 1, duration: 2.6, ease: 'power2.inOut' }, 0.2);
            } else {
              gsap.set(media, { clipPath: 'inset(0 0 100% 0)' });
              heroTl.to(media, { clipPath: 'inset(0 0 0% 0)', duration: 1.25, ease: 'power4.out' }, 0.25);
            }
          }
          const items = hero.querySelectorAll<HTMLElement>('[data-hero-item]');
          if (items.length) {
            gsap.set(items, { visibility: 'visible', willChange: 'transform, opacity' });
            // fromTo (not from): CSS pre-hides these to opacity:0, so .from would
            // animate 0 -> current(0) and they'd stay invisible for motion users.
            heroTl.fromTo(items, { y: 26, opacity: 0 }, { y: 0, opacity: 1, duration: 0.95, stagger: 0.08,
              onComplete: () => gsap.set(items, { willChange: 'auto' }) }, 0.45);
          }
        }

        // Scroll-triggered line reveals for section headlines
        gsap.utils.toArray<HTMLElement>('[data-reveal-lines]').forEach((el) => {
          const flux = el.hasAttribute('data-flux') && fine.matches;
          const split = SplitText.create(el, { type: flux ? 'lines,chars' : 'lines', mask: 'lines', linesClass: 'split-line', charsClass: 'flux-char', autoSplit: false });
          splits.push(split);
          gsap.set(el, { visibility: 'visible' });
          gsap.set(split.lines, { yPercent: 118 });
          ScrollTrigger.create({
            trigger: el, start: 'top 86%', once: true,
            onEnter: () => {
              gsap.set(split.lines, { willChange: 'transform' });
              gsap.to(split.lines, {
                yPercent: 0, duration: 1.0, ease: 'power4.out', stagger: 0.08,
                onComplete: () => { unmaskLines(split); if (flux) setupFluxFor(el, split); },
              });
            },
          });
        });

        // Chapter dividers: a choreographed entrance when each band scrolls in.
        // The giant ghost numeral scales + slides + fades in, the kicker rises,
        // and the title mask-reveals line by line. SplitText here (in buildLineMotion)
        // so line breaks use final font metrics. Not built under reduced-motion, so
        // the parts stay at their visible CSS defaults.
        gsap.utils.toArray<HTMLElement>('[data-chapter]').forEach((ch) => {
          const ghost = ch.querySelector<HTMLElement>('.chapter__ghost');
          const kicker = ch.querySelector<HTMLElement>('.chapter__kicker');
          const title = ch.querySelector<HTMLElement>('.chapter__title');
          let split: any = null;
          if (title) {
            split = SplitText.create(title, { type: 'lines', mask: 'lines', linesClass: 'split-line', autoSplit: false });
            splits.push(split);
            gsap.set(split.lines, { yPercent: 120 });
            // Arm the misregistration: the ochre plate starts a hair off-register
            // (CSS maps --misreg to a text-shadow offset on the lines) and snaps
            // in at the end of the entrance. Without JS the CSS default 0 holds.
            gsap.set(title, { '--misreg': 1 });
          }
          if (ghost) gsap.set(ghost, { autoAlpha: 0, scale: 1.16, xPercent: 8, transformOrigin: 'right center' });
          if (kicker) gsap.set(kicker, { autoAlpha: 0, y: 22 });
          ScrollTrigger.create({
            trigger: ch, start: 'top 80%', once: true,
            onEnter: () => {
              if (ghost) gsap.set(ghost, { willChange: 'transform, opacity' });
              if (kicker) gsap.set(kicker, { willChange: 'transform, opacity' });
              if (split) gsap.set(split.lines, { willChange: 'transform' });
              const tl = gsap.timeline({ onComplete: () => {
                if (ghost) gsap.set(ghost, { willChange: 'auto' });
                if (kicker) gsap.set(kicker, { willChange: 'auto' });
              } });
              if (ghost) tl.to(ghost, { autoAlpha: 1, scale: 1, xPercent: 0, duration: 1.2, ease: 'power3.out' }, 0);
              if (kicker) tl.to(kicker, { autoAlpha: 1, y: 0, duration: 0.7, ease: 'power3.out' }, 0.12);
              if (split) tl.to(split.lines, { yPercent: 0, duration: 1.0, ease: 'power4.out', stagger: 0.08, onComplete: () => unmaskLines(split) }, 0.2);
              // The ochre plate snaps into register just as the last line lands.
              if (split && title) tl.to(title, { '--misreg': 0, duration: 0.35, ease: 'power3.in' }, 0.75);
            },
          });
        });

        ScrollTrigger.refresh();
      }

      function initMotion() {
        clearMotion();
        if (reduce.matches) { showEverything(); return; }
        const myToken = initToken;
        buildScrollMotion();
        // SplitText wants final font metrics for correct line breaks, but content must
        // never stay hidden if fonts hang. Run on fonts-ready OR an 800ms hard fallback,
        // whichever comes first, and bail if the page was swapped meanwhile.
        let ran = false;
        const runLines = () => {
          if (ran || myToken !== initToken) return;
          ran = true;
          buildLineMotion();
        };
        const fontsReady = (document.fonts && document.fonts.ready) ? document.fonts.ready : Promise.resolve();
        fontsReady.then(runLines).catch(runLines);
        setTimeout(runLines, 800);
      }

      // ---- Astro ClientRouter lifecycle ----
      document.addEventListener('astro:page-load', initMotion);
      document.addEventListener('astro:before-swap', clearMotion);

      // ---- Page-turn curtain: GSAP transition choreography over ClientRouter swaps ----
      // The warm-paper plate sweeps up to cover the page (loading the next page in
      // parallel via the overridden loader), holds while the swap happens hidden, then
      // lifts to reveal the new page. The lift waits for the same fonts.ready / 800ms
      // gate buildLineMotion uses, so the destination headline is revealed before the
      // panel clears it (no flash). Skipped under reduced motion (the CSS also hides the
      // curtain there) and for same-page navigations that don't swap.
      const curtainEl = () => document.querySelector<HTMLElement>('.page-curtain');
      const mainEl = () => document.getElementById('main-content');
      function curtainLabelFor(path: string): string {
        const p = (path || '/').replace(/\/+$/, '') || '/';
        if (p === '/') return 'Home';
        if (p === '/projects') return 'Projects';
        if (p === '/gallery') return 'Gallery';
        if (p === '/about') return 'About';
        if (p === '/awards') return 'Awards';
        if (p === '/blog' || p.startsWith('/blog/')) return 'Blog';
        return '';
      }

      // coverShown tracks whether the plate is raised, so curtainLift() is idempotent and
      // safe from any recovery path (page-load, post-loader fallback, watchdog) and never
      // sweeps an already-parked curtain. navSeq tags each navigation so a superseded
      // nav's timers no-op.
      let coverShown = false;
      let navSeq = 0;
      let curtainTimer: number | undefined;

      function curtainCoverIn(label: string) {
        const c = curtainEl();
        if (!c) return Promise.resolve();
        const lbl = c.querySelector<HTMLElement>('[data-curtain-label]');
        gsap.killTweensOf(c);
        // y:0 zeroes the baseline GSAP reads from the CSS translateY(100%) (stored as
        // y:900px, otherwise stacked onto yPercent). Re-park to yPercent:100 only when
        // starting from rest; if a prior cover is still up (rapid re-nav) continue from
        // the current position instead of snapping down first.
        if (coverShown) gsap.set(c, { y: 0 });
        else gsap.set(c, { y: 0, yPercent: 100 });
        coverShown = true;
        const m = mainEl(); if (m) (m as any).inert = true; // block interaction with the covered page
        if (lbl) { gsap.killTweensOf(lbl); lbl.textContent = label ? '→ ' + label : ''; gsap.set(lbl, { opacity: 0, y: 12 }); }
        const tl = gsap.timeline();
        tl.to(c, { yPercent: 0, duration: 0.5, ease: 'power3.inOut' });
        if (lbl) tl.to(lbl, { opacity: 1, y: 0, duration: 0.3, ease: 'power2.out' }, 0.22);
        return tl;
      }
      function curtainLift() {
        const c = curtainEl();
        if (!c || !coverShown) return;
        coverShown = false;
        const m = mainEl(); if (m) (m as any).inert = false;
        const lbl = c.querySelector<HTMLElement>('[data-curtain-label]');
        gsap.killTweensOf(c);
        const tl = gsap.timeline();
        if (lbl) { gsap.killTweensOf(lbl); tl.to(lbl, { opacity: 0, y: -10, duration: 0.25, ease: 'power2.in' }, 0); }
        tl.to(c, { yPercent: -100, duration: 0.6, ease: 'power4.out' }, 0.1);
        tl.set(c, { y: 0, yPercent: 100 });
      }

      // Astro's router does NOT guarantee that every astro:before-preparation is followed
      // by astro:page-load: an aborted nav (e.g. a same-page hash jump interrupting a
      // cross-page nav) fires neither swap nor page-load. So the lift can't rely on
      // page-load alone — it's driven by whichever signal reaches us first (page-load, a
      // short post-loader fallback for aborted navs, or an absolute backstop), all guarded
      // by coverShown (idempotent) and navSeq (a superseding nav makes older timers no-op).
      document.addEventListener('astro:before-preparation', (e: any) => {
        if (reduce.matches) return;
        // Mirror the router's samePage (pathname + search): only those early-return
        // without swapping, so only those skip the curtain. A query-only change still
        // swaps and still gets the page-turn.
        const to = e.to as URL | undefined;
        if (to && to.pathname === location.pathname && to.search === location.search) return;
        const seq = ++navSeq;
        const original = e.loader;
        const label = curtainLabelFor((to && to.pathname) || location.pathname);
        e.loader = async () => {
          try { await Promise.all([curtainCoverIn(label), original()]); }
          catch (err) { /* aborted/failed load: recovered by the fallback below */ }
          // Loader settled. A successful nav swaps next -> astro:page-load lifts. An
          // aborted nav won't swap; recover here if nothing lifts shortly. Current nav only.
          if (navSeq === seq) {
            clearTimeout(curtainTimer);
            curtainTimer = window.setTimeout(() => { if (navSeq === seq && coverShown) curtainLift(); }, 1200);
          }
        };
        // Absolute backstop in case the loader itself never settles.
        clearTimeout(curtainTimer);
        curtainTimer = window.setTimeout(() => { if (navSeq === seq && coverShown) curtainLift(); }, 8000);
      });
      document.addEventListener('astro:page-load', () => {
        clearTimeout(curtainTimer);
        if (!coverShown) return;
        // Gate the lift on the same fonts.ready / 800ms condition buildLineMotion uses,
        // so the destination headline is up before the panel clears it (no flash).
        let done = false;
        const go = () => { if (done) return; done = true; curtainLift(); };
        const fontsReady = (document.fonts && document.fonts.ready) ? document.fonts.ready : Promise.resolve();
        fontsReady.then(go).catch(go);
        setTimeout(go, 850);
      });

      // The sticky header is transition:persist (it stays a fixed frame while page
      // content cross-fades beneath it), so its server-rendered active state is
      // frozen at first paint. Re-apply is-active / aria-current to the nav after
      // each swap based on the new pathname.
      function updateActiveNav() {
        const path = location.pathname;
        const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
        document.querySelectorAll<HTMLAnchorElement>('.nav-link, .mobile-link').forEach((a) => {
          const href = a.getAttribute('href');
          if (!href) return;
          const active = isActive(href);
          a.classList.toggle('is-active', active);
          if (active) a.setAttribute('aria-current', 'page');
          else a.removeAttribute('aria-current');
        });
      }
      document.addEventListener('astro:after-swap', updateActiveNav);

      // ============================================================
      // Article contents index (scroll-spy + breakpoint collapse)
      // ============================================================
      // Lives here, not in the page, because all behaviour is centralised in the
      // Layout (the design system forbids per-page scripts). No-ops on any page
      // without a [data-toc] index. Uses IntersectionObserver, never a scroll
      // listener. Re-runs idempotently per astro:page-load; torn down on swap.
      let tocCleanup: (() => void) | null = null;
      function setupToc() {
        tocCleanup?.();
        tocCleanup = null;

        const toc = document.querySelector<HTMLDetailsElement>('[data-toc]');
        const body = document.querySelector<HTMLElement>('.post-body');
        if (!toc || !body) return;

        const links = Array.from(toc.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]'));
        if (!links.length) return;
        const linkBySlug = new Map<string, HTMLAnchorElement>();
        links.forEach((a) => {
          const id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
          if (id) linkBySlug.set(id, a);
        });

        const heads = Array.from(body.querySelectorAll<HTMLElement>('h2[id], h3[id]'))
          .filter((h) => linkBySlug.has(h.id));
        if (!heads.length) return;

        const deskMQ = window.matchMedia('(min-width: 70rem)');
        const scroller = toc.querySelector<HTMLElement>('.post-toc__scroll');
        const cleanups: Array<() => void> = [];
        let activeId: string | null = null;

        function keepVisible(a: HTMLAnchorElement) {
          // Scroll the rail (never the window) so the current link stays in view.
          if (!scroller || scroller.scrollHeight <= scroller.clientHeight + 1) return;
          const ar = a.getBoundingClientRect();
          const sr = scroller.getBoundingClientRect();
          if (ar.top < sr.top) scroller.scrollTop -= sr.top - ar.top + 8;
          else if (ar.bottom > sr.bottom) scroller.scrollTop += ar.bottom - sr.bottom + 8;
        }
        function setActive(id: string) {
          if (id === activeId) return;
          activeId = id;
          links.forEach((a) => {
            const on = linkBySlug.get(id) === a;
            a.classList.toggle('is-current', on);
            if (on) { a.setAttribute('aria-current', 'location'); keepVisible(a); }
            else a.removeAttribute('aria-current');
          });
        }

        // ---- Scroll-spy via ScrollTrigger (mirrors the #scroll-progress bar) ----
        // One batched, single-handler trigger over the whole scroll; onUpdate reads
        // LIVE heading rects each frame, so it is immune to layout shifts (font swap,
        // math, reveal) that would stale-out per-heading start positions, and it stays
        // correct when the page jumps past several headings at once (anchor / flick).
        const off = () => parseFloat(getComputedStyle(heads[0]).scrollMarginTop) || 94;
        function spy() {
          const line = off() + 1;
          let current = heads[0];
          for (const h of heads) {
            if (h.getBoundingClientRect().top <= line) current = h;
            else break;
          }
          const doc = document.documentElement;
          if (window.scrollY + window.innerHeight >= doc.scrollHeight - 2) {
            current = heads[heads.length - 1]; // pin the last section at the very bottom
          }
          setActive(current.id);
        }
        const spyST = ScrollTrigger.create({ start: 0, end: 'max', onUpdate: spy });
        cleanups.push(() => spyST.kill());
        spy();

        // ---- Offset-aware jump + focus (reduced-motion safe) ----
        const onLinkClick = (e: MouseEvent) => {
          const a = e.currentTarget as HTMLAnchorElement;
          const id = decodeURIComponent((a.getAttribute('href') || '').slice(1));
          const target = id ? document.getElementById(id) : null;
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: reduce.matches ? 'auto' : 'smooth', block: 'start' });
          target.setAttribute('tabindex', '-1');
          target.focus({ preventScroll: true });
          history.replaceState(history.state, '', `#${id}`);
          if (!deskMQ.matches) toc.open = false; // collapse the mobile disclosure
        };
        links.forEach((a) => a.addEventListener('click', onLinkClick));
        cleanups.push(() => links.forEach((a) => a.removeEventListener('click', onLinkClick)));

        // ---- Disclosure: static-open rail on desktop, collapsible on mobile ----
        const summary = toc.querySelector<HTMLElement>('.post-toc__summary');
        const applyMode = () => { toc.open = deskMQ.matches; };
        const onSummaryClick = (e: Event) => { if (deskMQ.matches) e.preventDefault(); };
        summary?.addEventListener('click', onSummaryClick);
        deskMQ.addEventListener('change', applyMode);
        applyMode();
        cleanups.push(() => {
          summary?.removeEventListener('click', onSummaryClick);
          deskMQ.removeEventListener('change', applyMode);
        });

        tocCleanup = () => { cleanups.forEach((fn) => fn()); tocCleanup = null; };
      }
      document.addEventListener('astro:before-swap', () => { tocCleanup?.(); });

      // ============================================================
      // Non-motion page chrome (mobile menu, copy buttons)
      // ============================================================
      function setupChrome() {
        // Mobile menu
        const menuToggle = document.getElementById('menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuToggle && mobileMenu) {
          const fresh = menuToggle.cloneNode(true) as HTMLElement;
          menuToggle.parentNode?.replaceChild(fresh, menuToggle);
          const openIcon = fresh.querySelector('.menu-open');
          const closeIcon = fresh.querySelector('.menu-close');
          fresh.addEventListener('click', () => {
            const open = mobileMenu.classList.toggle('is-open');
            fresh.setAttribute('aria-expanded', open ? 'true' : 'false');
            openIcon?.classList.toggle('hidden', open);
            closeIcon?.classList.toggle('hidden', !open);
          });
        }
        const onOutside = (e: Event) => {
          const mm = document.getElementById('mobile-menu');
          const mt = document.getElementById('menu-toggle');
          if (mm && mm.classList.contains('is-open') && !mm.contains(e.target as Node) && !mt?.contains(e.target as Node)) {
            mm.classList.remove('is-open');
          }
        };
        document.removeEventListener('click', onOutside);
        document.addEventListener('click', onOutside);

        // Copy-code buttons
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.querySelector('.copy-btn')) return;
          const btn = document.createElement('button');
          btn.className = 'copy-btn';
          btn.textContent = 'Copy';
          btn.setAttribute('aria-label', 'Copy code');
          btn.addEventListener('click', async () => {
            const code = pre.querySelector('code')?.textContent || pre.textContent || '';
            try {
              await navigator.clipboard.writeText(code);
              btn.textContent = 'Copied';
              btn.classList.add('copied');
              setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1800);
            } catch (err) { /* clipboard unavailable */ }
          });
          pre.appendChild(btn);
        });

        setupToc();
      }
      document.addEventListener('astro:page-load', setupChrome);
    </script>
  </body>
</html>
