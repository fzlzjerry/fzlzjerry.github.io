---
const links = [
  { href: '/', text: 'Home', num: '01' },
  { href: '/projects', text: 'Projects', num: '02' },
  { href: '/gallery', text: 'Gallery', num: '03' },
  { href: '/blog', text: 'Blog', num: '04' },
  { href: '/awards', text: 'Awards', num: '05' },
  { href: '/about', text: 'About', num: '06' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-[100] focus:px-4 focus:py-2 focus:bg-ink focus:text-paper focus:text-sm focus:font-medium focus:rounded-sm">
  Skip to main content
</a>

<header class="site-header sticky top-0 z-50 w-full bg-paper border-b border-border-subtle" transition:persist>
  <nav class="container h-[4.25rem] flex items-center justify-between" aria-label="Main navigation">
    <!-- Wordmark -->
    <a href="/" class="font-display text-[1.4rem] leading-none font-medium tracking-tight text-ink hover:text-accent transition-colors" aria-label="Morax Cheng, home">
      Morax<span class="text-accent">.</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-7" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={["nav-link", isActive(link.href) && "is-active"]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            <span class="nav-link__num">{link.num}</span>
            <span class="nav-link__text">{link.text}</span>
          </a>
        </li>
      ))}
      <li>
        <button
          aria-label="Open command palette"
          class="search-pill"
          onclick="document.dispatchEvent(new CustomEvent('open-command-palette'))"
        >
          <i class="fa-solid fa-magnifying-glass text-[0.7rem]" aria-hidden="true"></i>
          <span class="hidden lg:inline">Search</span>
          <kbd class="hidden lg:inline">⌘K</kbd>
        </button>
      </li>
    </ul>

    <!-- Mobile toggle -->
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-11 h-11 -mr-2 text-ink rounded-sm"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 6h18M3 12h18M3 18h18"></path>
        <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile drawer scrim: warm veil behind the panel; tap to close -->
  <div id="mobile-scrim" class="mobile-scrim md:hidden" aria-hidden="true"></div>

  <!-- Mobile panel -->
  <div id="mobile-menu" class="mobile-panel md:hidden" role="dialog" aria-label="Mobile navigation" aria-modal="true">
    <div class="flex items-center justify-between px-6 h-[4.25rem] border-b border-border-subtle">
      <span class="label">Index</span>
      <button
        class="text-ink-faint hover:text-ink transition-colors w-11 h-11 -mr-2 flex items-center justify-center"
        data-menu-close
        aria-label="Close menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
    <ul class="flex flex-col" role="list">
      {links.map((link) => (
        <li class="border-b border-border-subtle">
          <a
            href={link.href}
            class:list={["mobile-link", isActive(link.href) && "is-active"]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            <span class="index-num">{link.num}</span>
            <span>{link.text}</span>
          </a>
        </li>
      ))}
      <li>
        <button
          class="mobile-link w-full text-left"
          data-menu-search
        >
          <span class="index-num">⌘</span>
          <span>Search</span>
        </button>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: 'Spline Sans Mono', ui-monospace, monospace;
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    transition: color var(--t-base) ease;
  }
  .nav-link__num { font-size: 0.62rem; color: var(--ink-faint); transition: color var(--t-base) ease; }
  .nav-link__text {
    background-image: linear-gradient(var(--ochre), var(--ochre));
    background-size: 0% 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    padding-bottom: 2px;
    transition: background-size var(--t-base) var(--ease-out);
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link:hover .nav-link__text { background-size: 100% 1px; }
  .nav-link.is-active { color: var(--ochre); }
  .nav-link.is-active .nav-link__num { color: var(--ochre); }

  .search-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Spline Sans Mono', monospace;
    font-size: 0.72rem;
    color: var(--ink-faint);
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    transition: color var(--t-base) ease, border-color var(--t-base) ease;
    cursor: pointer;
  }
  .search-pill:hover { color: var(--ink); border-color: var(--line-strong); }
  .search-pill kbd {
    font-family: 'Spline Sans Mono', monospace;
    font-size: 0.64rem;
    color: var(--ink-faint);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.05rem 0.3rem;
  }

  .mobile-scrim {
    position: fixed;
    inset: 0;
    z-index: 55;
    background: var(--scrim-soft);
    opacity: 0;
    visibility: hidden;
    transition: opacity 420ms var(--ease-out), visibility 0s linear 420ms;
  }
  .mobile-scrim.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity 420ms var(--ease-out), visibility 0s;
  }

  .mobile-panel {
    position: fixed;
    top: 0; right: 0;
    height: 100dvh;
    width: min(82vw, 20rem);
    background: var(--paper);
    border-left: 1px solid var(--line);
    box-shadow: var(--shadow-panel);
    z-index: 60;
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 420ms var(--ease-out), visibility 0s linear 420ms;
  }
  .mobile-panel.is-open {
    transform: translateX(0);
    visibility: visible;
    transition: transform 420ms var(--ease-out), visibility 0s;
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-scrim { transition: opacity 0.01ms; }
  }
  .mobile-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    font-family: 'Bricolage Grotesque', serif;
    font-size: 1.25rem;
    color: var(--ink);
    transition: background-color var(--t-base) ease, color var(--t-base) ease;
  }
  .mobile-link:hover { background: var(--panel); }
  .mobile-link.is-active { color: var(--ochre); }

  @media (prefers-reduced-motion: reduce) {
    .mobile-panel { transition: none; }
  }
</style>
