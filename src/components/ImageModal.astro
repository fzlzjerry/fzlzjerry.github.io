---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  id={id}
  class="modal fixed inset-0 z-50 hidden items-center justify-center p-4"
  style="background-color: oklch(0.2 0.01 70 / 0.86);"
  onclick="if (event.target === this) { this.classList.add('hidden'); this.classList.remove('flex'); }"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${id}-title`}
>
  <div class="modal-content w-full max-w-4xl">
    <div class="relative bg-paper border border-border-strong rounded-card overflow-hidden">
      <button
        onclick="this.closest('.modal').classList.add('hidden'); this.closest('.modal').classList.remove('flex');"
        class="close-btn absolute top-3 right-3 z-10 flex items-center justify-center w-10 h-10 rounded-card bg-paper border border-border-strong text-ink-faint transition-colors hover:text-accent hover:border-accent"
        aria-label="Close"
        tabindex="0"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <img
        src=""
        alt="Certificate"
        class="block w-full h-auto"
        id={`${id}-image`}
      />
      <figcaption id={`${id}-title`} class="modal-caption font-mono">
        <span class="modal-caption__index">Pl.</span>
        <span class="modal-caption__text" id={`${id}-caption`}>Certificate</span>
      </figcaption>
    </div>
  </div>
</div>

<style>
  .modal {
    animation: fadeIn var(--t-base) ease-out;
  }

  .modal-content {
    animation: scaleIn 300ms var(--ease-out);
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes scaleIn {
    from {
      transform: scale(0.96);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .modal-caption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--line);
    background: var(--paper);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--ink);
  }
  .modal-caption__index {
    color: var(--ochre);
  }
  .modal-caption__text {
    color: var(--ink-soft);
  }

  .close-btn:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  @media (prefers-reduced-motion: reduce) {
    .modal,
    .modal-content {
      animation: none;
    }
  }
</style>

<script define:vars={{ id }}>
document.querySelectorAll(`[data-modal="${id}"]`).forEach(trigger => {
  trigger.addEventListener('click', (e) => {
    e.preventDefault();
    const modal = document.getElementById(id);
    const modalImg = document.getElementById(`${id}-image`);
    const modalCaption = document.getElementById(`${id}-caption`);
    modalImg.src = trigger.getAttribute('href');
    const label = trigger.getAttribute('aria-label');
    if (modalCaption && label) {
      modalCaption.textContent = label.replace(/^View\s+/i, '').replace(/,?\s*full size$/i, '');
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');

    const focusableElements = modal.querySelectorAll('button, [href], [tabindex]:not([tabindex="-1"])');
    const firstElement = focusableElements[0];
    const lastElement = focusableElements[focusableElements.length - 1];

    setTimeout(() => firstElement?.focus(), 100);

    const trapFocus = (e) => {
      if (e.key === 'Tab') {
        if (e.shiftKey) {
          if (document.activeElement === firstElement) {
            e.preventDefault();
            lastElement?.focus();
          }
        } else {
          if (document.activeElement === lastElement) {
            e.preventDefault();
            firstElement?.focus();
          }
        }
      }
    };

    modal.addEventListener('keydown', trapFocus);
    modal._trapFocus = trapFocus;
  });
});

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    const modal = document.getElementById(id);
    if (modal && !modal.classList.contains('hidden')) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      if (modal._trapFocus) {
        modal.removeEventListener('keydown', modal._trapFocus);
      }
    }
  }
});
</script>
