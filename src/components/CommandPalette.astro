---
import { getCollection } from 'astro:content';

// Fetch content for indexing
const posts = await getCollection('blog');
const searchItems = [
  // Pages
  { title: 'Home', href: '/', type: 'Page' },
  { title: 'Projects', href: '/projects', type: 'Page' },
  { title: 'Gallery', href: '/gallery', type: 'Page' },
  { title: 'Blog', href: '/blog', type: 'Page' },
  { title: 'Awards', href: '/awards', type: 'Page' },
  { title: 'About', href: '/about', type: 'Page' },
  // Blog Posts
  ...posts.map(post => ({
    title: post.data.title,
    href: `/blog/${post.slug}`,
    type: 'Blog',
    description: post.data.excerpt
  }))
];
---

<div id="command-palette-container" class="hidden relative z-[100]" role="dialog" aria-modal="true" aria-label="Command palette">
  <!-- Backdrop: warm dark scrim -->
  <div id="palette-backdrop" class="palette-scrim fixed inset-0 transition-opacity duration-base opacity-0"></div>

  <!-- Modal Positioner -->
  <div class="fixed inset-0 z-[100] overflow-y-auto p-4 sm:p-6 md:p-20">
    <!-- Modal Panel: paper -->
    <div
      id="palette-panel"
      class="palette-panel mx-auto max-w-xl transform overflow-hidden bg-paper transition-all duration-base ease-out-custom scale-95 opacity-0"
    >
      <!-- Search field -->
      <div class="palette-field relative">
        <span class="palette-mark absolute top-0 left-[var(--gutter-x)] flex h-full items-center text-accent font-mono select-none" aria-hidden="true">/</span>
        <input
          type="text"
          id="palette-input"
          class="palette-input h-14 w-full border-0 bg-transparent pr-4 text-ink placeholder:text-ink-faint focus:ring-0 focus-visible:shadow-none"
          placeholder="Search pages and posts"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          spellcheck="false"
          role="combobox"
          aria-expanded="false"
          aria-controls="palette-results"
          aria-label="Search pages and posts"
        />
        <div class="absolute top-0 right-[var(--gutter-x)] flex h-full items-center">
          <kbd class="palette-kbd hidden sm:inline-block">ESC</kbd>
        </div>
      </div>

      <ul
        id="palette-results"
        class="palette-results max-h-80 scroll-py-2 overflow-y-auto"
        role="listbox"
        aria-label="Search results"
      >
        <!-- Results injected here -->
      </ul>

      <div id="palette-empty" class="palette-empty hidden py-14 px-6 text-center">
        <p class="label">No results found</p>
        <p class="mt-3 text-sm text-ink-faint">We couldn't find anything with that term. Please try again.</p>
      </div>

      <!-- Footer hints -->
      <div class="palette-foot flex items-center justify-between gap-3">
        <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
          <span class="flex items-center gap-1.5"><kbd class="palette-kbd">&uarr;</kbd><kbd class="palette-kbd">&darr;</kbd><span class="palette-hint">navigate</span></span>
          <span class="flex items-center gap-1.5"><kbd class="palette-kbd">&crarr;</kbd><span class="palette-hint">select</span></span>
        </div>
        <span class="palette-hint">Index, Morax Cheng</span>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ searchItems }}>
  // Core Logic
  let isOpen = false;
  let query = '';
  let selectedIndex = 0;
  let filteredItems = searchItems || [];

  // Helpers
  function getElements() {
    return {
      container: document.getElementById('command-palette-container'),
      backdrop: document.getElementById('palette-backdrop'),
      panel: document.getElementById('palette-panel'),
      input: document.getElementById('palette-input'),
      resultsList: document.getElementById('palette-results'),
      emptyState: document.getElementById('palette-empty')
    };
  }

  function isPaletteOpen() {
    const { container } = getElements();
    return container && !container.classList.contains('hidden');
  }

  function openPalette() {
    const { container, backdrop, panel, input } = getElements();
    if (!container || isPaletteOpen()) return;

    container.classList.remove('hidden');

    requestAnimationFrame(() => {
      backdrop.classList.remove('opacity-0');
      panel.classList.remove('scale-95', 'opacity-0');
    });

    if (input) {
      input.value = '';
      input.focus();
    }
    query = '';
    filterItems('');
    document.body.style.overflow = 'hidden';
  }

  function closePalette() {
    const { container, backdrop, panel } = getElements();
    if (!container || !isPaletteOpen()) return;

    backdrop.classList.add('opacity-0');
    panel.classList.add('scale-95', 'opacity-0');

    setTimeout(() => {
      container.classList.add('hidden');
      document.body.style.overflow = '';
    }, 200);
  }

  function filterItems(q) {
    query = q ? q.toLowerCase() : '';
    if (!query) {
      filteredItems = searchItems.slice(0, 8);
    } else {
      filteredItems = searchItems.filter(item =>
        item.title.toLowerCase().includes(query) ||
        (item.description && item.description.toLowerCase().includes(query))
      ).slice(0, 10);
    }

    selectedIndex = 0;
    renderResults();
  }

  // Catalogue labels per type
  function typeLabel(type) {
    return type === 'Blog' ? 'Post' : 'Page';
  }

  function renderResults() {
    const { resultsList, emptyState } = getElements();
    if (!resultsList) return;

    resultsList.innerHTML = '';

    if (!filteredItems || filteredItems.length === 0) {
      resultsList.classList.add('hidden');
      if (emptyState) emptyState.classList.remove('hidden');
      return;
    }

    resultsList.classList.remove('hidden');
    if (emptyState) emptyState.classList.add('hidden');

    filteredItems.forEach((item, index) => {
      const li = document.createElement('li');
      li.role = 'option';
      li.setAttribute('aria-selected', index === selectedIndex ? 'true' : 'false');
      li.className = `palette-option${index === selectedIndex ? ' is-active' : ''}`;
      li.innerHTML = `
        <span class="palette-option__marker" aria-hidden="true"></span>
        <span class="palette-option__index font-mono">${String(index + 1).padStart(2, '0')}</span>
        <span class="palette-option__body">
          <span class="palette-option__title">${item.title}</span>
          ${item.description ? `<span class="palette-option__desc">${item.description}</span>` : ``}
        </span>
        <span class="palette-option__type label">${typeLabel(item.type)}</span>
      `;

      li.addEventListener('click', () => {
        window.location.href = item.href;
        closePalette();
      });

      li.addEventListener('mouseenter', () => {
        selectedIndex = index;
        updateSelection();
      });

      resultsList.appendChild(li);
    });
  }

  function updateSelection() {
    const { resultsList } = getElements();
    if (!resultsList) return;

    const items = resultsList.children;
    for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const isSelected = i === selectedIndex;
        item.className = `palette-option${isSelected ? ' is-active' : ''}`;
        item.setAttribute('aria-selected', isSelected ? 'true' : 'false');
    }
  }

  function handleKeydown(e) {
    if (e.key === 'k' && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      if (isPaletteOpen()) closePalette();
      else openPalette();
    }

    if (e.key === 'Escape') {
      closePalette();
    }

    if (!isPaletteOpen()) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = (selectedIndex + 1) % filteredItems.length;
      updateSelection();
      scrollSelectedIntoView();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = (selectedIndex - 1 + filteredItems.length) % filteredItems.length;
      updateSelection();
      scrollSelectedIntoView();
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (filteredItems[selectedIndex]) {
        window.location.href = filteredItems[selectedIndex].href;
        closePalette();
      }
    }
  }

  function scrollSelectedIntoView() {
    const { resultsList } = getElements();
    if (!resultsList) return;
    const selectedEl = resultsList.children[selectedIndex];
    if (selectedEl) {
      selectedEl.scrollIntoView({ block: 'nearest' });
    }
  }

  // Robust Setup using global handler tracking
  document.addEventListener('astro:page-load', () => {
    if (!searchItems || searchItems.length === 0) {
      console.error('Command Palette: No search items found.');
    }

    if (window.__cmdPaletteOpen) {
      document.removeEventListener('open-command-palette', window.__cmdPaletteOpen);
    }
    if (window.__cmdPaletteKey) {
      document.removeEventListener('keydown', window.__cmdPaletteKey);
    }

    window.__cmdPaletteOpen = openPalette;
    window.__cmdPaletteKey = handleKeydown;

    document.addEventListener('open-command-palette', window.__cmdPaletteOpen);
    document.addEventListener('keydown', window.__cmdPaletteKey);

    const { input, backdrop } = getElements();
    if (input) input.oninput = (e) => filterItems(e.target.value);
    if (backdrop) backdrop.onclick = closePalette;

    isOpen = false;
  });
</script>

<style is:global>
  /* Global (not scoped): result rows are injected via JS innerHTML and would not
     receive Astro's scoped cid, so scoped rules would never reach them. All
     selectors here are uniquely namespaced .palette-* so global is safe. */

  /* Warm dark scrim over the warm paper */
  .palette-scrim {
    background: oklch(0.2 0.01 70 / 0.5);
    backdrop-filter: blur(2px);
  }

  /* Paper panel: hairline border, soft warm shadow, minimal radius */
  .palette-panel {
    --gutter-x: 1.25rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    box-shadow: 0 28px 70px -32px oklch(0.2 0.01 70 / 0.45);
  }

  /* Search field row */
  .palette-field {
    border-bottom: 1px solid var(--line);
  }
  .palette-mark {
    font-size: 1rem;
    letter-spacing: 0.05em;
  }
  .palette-input {
    padding-left: calc(var(--gutter-x) + 1.1rem);
    font-family: 'Hanken Grotesk', system-ui, sans-serif;
    font-size: var(--step-0);
    line-height: 1;
    outline: none;
  }
  .palette-input::placeholder { font-family: 'Spline Sans Mono', ui-monospace, monospace; font-size: 0.85em; letter-spacing: 0.02em; }
  .palette-input:focus-visible { box-shadow: none; }

  /* Keyboard hint chips */
  .palette-kbd {
    font-family: 'Spline Sans Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    line-height: 1;
    color: var(--ink-faint);
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.2rem 0.4rem;
    min-width: 1.4rem;
    text-align: center;
  }
  .palette-hint {
    font-family: 'Spline Sans Mono', ui-monospace, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  /* Results list */
  .palette-results {
    padding: 0.4rem;
    list-style: none;
    margin: 0;
  }

  /* Result option: catalogue row, ochre marker on active (no side-stripe border) */
  .palette-option {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    padding: 0.65rem 1rem 0.65rem 1.5rem;
    border-radius: var(--radius);
    cursor: default;
    user-select: none;
    color: var(--ink-soft);
    transition: background-color var(--t-fast) ease, color var(--t-fast) ease;
  }
  .palette-option__marker {
    position: absolute;
    left: 0.55rem;
    top: 0.95rem;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--ochre);
    opacity: 0;
    transform: scale(0.4);
    transition: opacity var(--t-fast) ease, transform var(--t-fast) var(--ease-out);
  }
  .palette-option__index {
    flex: none;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--ink-ghost);
    padding-top: 0.1rem;
    transition: color var(--t-fast) ease;
  }
  .palette-option__body {
    flex: auto;
    min-width: 0;
  }
  .palette-option__title {
    display: block;
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .palette-option__desc {
    display: block;
    font-size: 0.8rem;
    color: var(--ink-faint);
    line-height: 1.4;
    margin-top: 0.1rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .palette-option__type {
    flex: none;
    color: var(--ink-ghost);
    transition: color var(--t-fast) ease;
  }

  /* Active / selected row: recessed panel + ochre marker */
  .palette-option.is-active {
    background: var(--panel);
    color: var(--ink);
  }
  .palette-option.is-active .palette-option__marker {
    opacity: 1;
    transform: scale(1);
  }
  .palette-option.is-active .palette-option__index { color: var(--ochre); }
  .palette-option.is-active .palette-option__type { color: var(--ink-faint); }

  /* Footer hint bar */
  .palette-foot {
    padding: 0.65rem 1.25rem;
    background: var(--paper-sink);
    border-top: 1px solid var(--line);
  }

  /* Custom scrollbar within results */
  .palette-results::-webkit-scrollbar { width: 8px; }
  .palette-results::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }

  @media (prefers-reduced-motion: reduce) {
    .palette-option__marker { transition: none; }
  }
</style>
