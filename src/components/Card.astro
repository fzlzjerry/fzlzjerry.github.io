---
interface Props {
	title: string;
	body: string;
	href: string;
	variant?: 'default' | 'featured';
	tags?: string[];
	meta?: string;
}

const { href, title, body, variant = 'default', tags, meta } = Astro.props;
---

<a
	href={href}
	class:list={['card group', variant === 'featured' && 'card-feature']}
>
	<div class="card-head">
		{meta && <span class="label card-meta">{meta}</span>}
		<h2 class="card-title font-display">{title}</h2>
	</div>

	<p class="card-body text-ink-soft">{body}</p>

	{tags && tags.length > 0 && (
		<ul class="tag-list card-tags" role="list">
			{tags.map((tag) => <li class="tag">{tag}</li>)}
		</ul>
	)}

	<span class="card-arrow" aria-hidden="true">→</span>
</a>

<style>
	.card {
		position: relative;
		height: 100%;
	}

	/* Featured: a stronger top hairline for emphasis. No side-stripe, no ochre flood. */
	.card-feature {
		border-top: 2px solid var(--line-strong);
	}

	.card-head {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.card-title {
		font-size: var(--step-2);
		line-height: 1.1;
		color: var(--ink);
		transition: color var(--t-base) ease;
	}
	.card:hover .card-title {
		color: var(--ochre);
	}

	.card-body {
		margin-top: 0.85rem;
		line-height: 1.55;
		max-width: 56ch;
	}

	.card-tags {
		margin-top: 1.25rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--line);
	}

	.card-arrow {
		position: absolute;
		top: clamp(1.5rem, 1rem + 2vw, 2.5rem);
		right: clamp(1.5rem, 1rem + 2vw, 2.5rem);
		font-size: 1.25rem;
		line-height: 1;
		color: var(--ink-ghost);
		transition: transform var(--t-base) var(--ease-out), color var(--t-base) ease;
	}
	.card:hover .card-arrow {
		transform: translate(4px, -4px);
		color: var(--ochre);
	}
</style>
