---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Windows 12 Web',
    description: 'A web-based Windows 12 concept UI built with modern web technologies. A realistic Windows-like interface with multi-window management and a set of working system apps.',
    tech: ['HTML', 'CSS', 'JS'],
    github: 'https://github.com/tjy-gitnub/win12',
    year: '2024',
    featured: true,
  },
  {
    title: 'WeChat Anti-Recall',
    description: 'A SwiftPM command-line tool for macOS WeChat 4 that patches supported builds to preserve recalled messages, add a tip mode, and block auto-updates.',
    tech: ['Swift', 'SwiftPM', 'Mach-O', 'macOS'],
    github: 'https://github.com/fzlzjerry/wechat-antirecall',
    year: '2025',
    featured: false,
  },
];
---

<Layout
  title="Projects · Morax Cheng"
  description="Explore the projects developed by Morax Cheng, including Windows 12 Web and WeChat Anti-Recall. View code on GitHub and see his development skills in action."
  fullWidth={true}
>
  <div class="container">
    <header class="page-head">
      <span class="label" data-scramble>Projects</span>
      <h1 class="page-title" data-reveal-lines data-flux>Selected work</h1>
      <p class="page-lead" data-reveal>
        A collection of open-source projects and experiments, from web applications to desktop software.
      </p>
    </header>

    <section class="section" aria-label="Projects">
      <ol class="proj-list" data-draw-rule>
        {projects.map((p, i) => (
          <li
            class:list={['proj-row', p.featured && 'proj-row--featured']}
            data-reveal
          >
            <span class="proj-row__num index-num" data-scramble>{String(i + 1).padStart(2, '0')}</span>

            <div class="proj-row__main">
              <div class="proj-row__head">
                <h2 class="proj-row__title">{p.title}</h2>
                {p.featured && <span class="proj-row__flag label">Featured</span>}
              </div>

              <p class="proj-row__desc">{p.description}</p>

              <ul class="tag-list proj-row__tags" role="list">
                {p.tech.map((t) => <li class="tag">{t}</li>)}
              </ul>

              <a
                class="proj-row__link link-underline"
                href={p.github}
                target="_blank"
                rel="noopener"
              >
                View on GitHub
                <span class="proj-row__arrow" aria-hidden="true">↗</span>
              </a>
            </div>

            <span class="proj-row__year mono">{p.year}</span>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  /* ---------- Projects index (typographic, no media) ---------- */
  .proj-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .proj-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: clamp(1rem, 0.5rem + 2vw, 3rem);
    padding-block: clamp(2.25rem, 1.5rem + 3vw, 4rem);
    border-bottom: 1px solid var(--line);
  }

  .proj-row__num {
    padding-top: 0.5rem;
    font-size: var(--step-0);
  }

  .proj-row__main { min-width: 0; }

  .proj-row__head {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.75rem 1.1rem;
  }

  .proj-row__title {
    font-size: var(--step-3);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .proj-row__flag { color: var(--ochre); }

  .proj-row__desc {
    margin-top: clamp(0.85rem, 0.5rem + 1vw, 1.4rem);
    color: var(--ink-soft);
    max-width: 58ch;
    line-height: 1.6;
    font-size: var(--step-0);
  }

  .proj-row__tags { margin-top: clamp(1rem, 0.75rem + 1vw, 1.6rem); }

  .proj-row__link {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    margin-top: clamp(1.25rem, 1rem + 1vw, 2rem);
    font-size: var(--step-0);
  }

  .proj-row__arrow {
    font-size: 1.05em;
    transition: transform var(--t-base) var(--ease-out);
  }
  .proj-row__link:hover .proj-row__arrow { transform: translate(3px, -3px); }

  .proj-row__year {
    padding-top: 0.55rem;
    color: var(--ink-faint);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* Featured: more weight via scale + breathing room, never a colored stripe */
  .proj-row--featured {
    padding-block: clamp(3rem, 2rem + 4vw, 5.5rem);
  }
  .proj-row--featured .proj-row__title { font-size: var(--step-4); }
  .proj-row--featured .proj-row__desc {
    font-size: var(--step-1);
    color: var(--ink);
    max-width: 50ch;
  }

  @media (max-width: 600px) {
    .proj-row { grid-template-columns: auto 1fr; }
    .proj-row__year {
      grid-column: 2;
      padding-top: 0.25rem;
    }
  }
</style>
