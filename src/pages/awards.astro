---
import Layout from '../layouts/Layout.astro';
import ImageModal from '../components/ImageModal.astro';

const awardCategories = [
  {
    index: '01',
    name: 'USACO 2025-2026',
    description:
      'USA Computing Olympiad (USACO). Promoted to the Gold division.',
    issuer: 'Administered by USACO',
    awards: [
      {
        title: 'Gold Division',
        date: '2025-2026',
        category: 'Individual Achievement',
        division: 'Gold Division',
        level: 'Competitive Programming',
      },
    ],
  },
  {
    index: '02',
    name: 'HiMCM 2025',
    description:
      'High School Mathematical Contest in Modeling (HiMCM) 2025',
    issuer: 'Administered by COMAP',
    awards: [
      {
        title: 'Meritorious Award',
        date: '2025',
        category: 'Team Achievement',
        contest: 'High School Mathematical Contest in Modeling',
        teamNumber: '16400',
        school: 'BASIS International School Park Lane Harbour',
        advisor: 'Shazaib Ramzan Nauman',
        teamMembers: [
          { name: 'Yixuan Cheng', role: 'Team Member' },
          { name: 'Lan Jocelyn Bai', role: 'Team Member' },
          { name: 'Sibo Huang', role: 'Team Member' },
        ],
        certPdf: '/certificates/16400.pdf',
      },
    ],
  },
];
---

<Layout
  title="Awards · Morax Cheng"
  description="Morax Cheng's academic achievements: USACO 2025-2026 Gold division and the HiMCM 2025 modeling contest."
  fullWidth={true}
>
  <div class="container">
    <header class="page-head">
      <span class="label" data-scramble>Awards</span>
      <h1 class="page-title" data-reveal-lines data-flux>Academic achievements</h1>
      <p class="page-lead" data-reveal>
        Recognitions and awards from academic competitions.
      </p>
    </header>

    {awardCategories.map((cat) => (
      <section class="section" aria-labelledby={`cat-${cat.index}`}>
        <div class="section-head section-head--split">
          <div>
            <span class="index-num" data-scramble>{cat.index}</span>
            <h2 class="section-title" id={`cat-${cat.index}`} data-reveal-lines data-flux>
              {cat.name}
            </h2>
          </div>
          <span class="section-link mono">
            {cat.awards.length} {cat.awards.length === 1 ? 'award' : 'awards'}
          </span>
        </div>

        <p class="cat-desc" data-reveal>{cat.description}</p>

        <ol class="award-list" data-stagger data-draw-rule>
          {cat.awards.map((award, i) => (
            <li class="award-entry">
              <div class="award-entry__body">
                <span class="award-entry__num index-num" data-scramble>
                  {String(i + 1).padStart(2, '0')}
                </span>

                <div class="award-entry__main">
                  <span class="award-entry__date label">{award.date}</span>
                  <h3 class="award-entry__title font-display">{award.title}</h3>

                  <ul class="tag-list award-entry__tags" role="list">
                    <li class="tag">{award.category}</li>
                    {award.division && <li class="tag">{award.division}</li>}
                    {award.contest && <li class="tag">{award.contest}</li>}
                    {award.level && <li class="tag">{award.level}</li>}
                    {award.score && (
                      <li class="tag tag--accent">Score {award.score}</li>
                    )}
                    {award.certificateId && (
                      <li class="tag tag--id">ID {award.certificateId}</li>
                    )}
                    {award.teamNumber && (
                      <li class="tag tag--id">Team {award.teamNumber}</li>
                    )}
                  </ul>

                  {(award.school || award.advisor) && (
                    <dl class="award-entry__meta">
                      {award.school && (
                        <div>
                          <dt class="label">School</dt>
                          <dd>{award.school}</dd>
                        </div>
                      )}
                      {award.advisor && (
                        <div>
                          <dt class="label">Faculty Advisor</dt>
                          <dd>{award.advisor}</dd>
                        </div>
                      )}
                    </dl>
                  )}

                  {award.teamMembers && (
                    <div class="award-entry__group">
                      <span class="label">Team</span>
                      <ul class="member-list" role="list">
                        {award.teamMembers.map((member) => (
                          <li class="member">
                            <span class="member__name">{member.name}</span>
                            <span class="member__role mono">{member.role}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {award.criteria && (
                    <div class="award-entry__group">
                      <span class="label">Criteria</span>
                      <ul class="criteria-list" role="list">
                        {award.criteria.map((criterion) => (
                          <li class="criterion">{criterion}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>

                <div class="award-entry__cert">
                  {award.certImage && (
                    <a
                      href={award.certImage}
                      data-modal="certificate-modal"
                      class="cert-thumb media-frame"
                      data-reveal-clip
                      aria-label={`View ${award.title} certificate, full size`}
                    >
                      <img
                        data-zoom
                        src={award.certImage}
                        alt={`Certificate: ${award.title}`}
                        loading="lazy"
                      />
                      <figcaption class="wall-label wall-label--hover">
                        <span class="index-num">Pl.</span>
                        <span>View full size</span>
                      </figcaption>
                    </a>
                  )}
                  {award.certPdf && (
                    <a
                      href={award.certPdf}
                      class="cert-pdf link-underline"
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`View ${award.title} certificate, PDF`}
                    >
                      View certificate (PDF)
                      <span class="cert-pdf__arrow" aria-hidden="true">↗</span>
                    </a>
                  )}
                  <span class="cert-issuer mono">{cat.issuer}</span>
                </div>
              </div>
            </li>
          ))}
        </ol>
      </section>
    ))}
  </div>

  <ImageModal id="certificate-modal" />
</Layout>

<style>
  /* ---------- category intro ---------- */
  .cat-desc {
    color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.5;
    max-width: 52ch;
    margin: -0.5rem 0 clamp(1.75rem, 1rem + 2vw, 2.75rem);
  }

  /* ---------- award list ---------- */
  .award-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .award-entry {
    border-bottom: 1px solid var(--line);
  }
  .award-entry__body {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 0.5rem + 2vw, 2.5rem);
    padding-block: clamp(2rem, 1.25rem + 2.5vw, 3.25rem);
    align-items: start;
  }
  .award-entry__num {
    padding-top: 0.45rem;
  }

  .award-entry__main {
    min-width: 0;
  }
  .award-entry__date {
    display: block;
    margin-bottom: 0.65rem;
  }
  .award-entry__title {
    font-size: var(--step-2);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.1rem;
    max-width: 22ch;
  }

  .award-entry__tags {
    margin-bottom: 1.4rem;
  }
  .tag--accent {
    color: var(--ochre);
    border-color: var(--ochre-faint);
  }
  .tag--id {
    color: var(--ink-soft);
  }

  /* school / advisor meta */
  .award-entry__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    margin: 0 0 1.4rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line);
  }
  .award-entry__meta dt {
    margin-bottom: 0.3rem;
  }
  .award-entry__meta dd {
    margin: 0;
    color: var(--ink);
    font-size: 0.95rem;
  }

  /* shared group (team / criteria) */
  .award-entry__group {
    padding-top: 1.25rem;
    margin-top: 1.4rem;
    border-top: 1px solid var(--line);
  }
  .award-entry__group > .label {
    display: block;
    margin-bottom: 0.85rem;
  }

  /* team members */
  .member-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-width: 40ch;
  }
  .member {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--line);
  }
  .member:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .member__name {
    color: var(--ink);
    font-size: 0.95rem;
  }
  .member__role {
    color: var(--ink-faint);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* criteria */
  .criteria-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 56ch;
  }
  .criterion {
    position: relative;
    padding-left: 1.4rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }
  .criterion::before {
    content: '';
    position: absolute;
    left: 0.1rem;
    top: 0.62em;
    width: 0.4rem;
    height: 1px;
    background: var(--ochre);
  }

  /* ---------- certificate column ---------- */
  .award-entry__cert {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    width: 100%;
  }
  .cert-thumb {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--line);
    transition: border-color var(--t-base) ease;
  }
  .cert-thumb:hover {
    border-color: var(--line-strong);
  }
  .cert-pdf {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    font-size: 0.95rem;
    color: var(--ink);
  }
  .cert-pdf__arrow {
    color: var(--ink-ghost);
    transition: transform var(--t-base) var(--ease-out), color var(--t-base) ease;
  }
  .cert-pdf:hover .cert-pdf__arrow {
    transform: translate(3px, -3px);
    color: var(--ochre);
  }
  .cert-issuer {
    color: var(--ink-faint);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }

  /* ---------- responsive: certificate sits beside content on wide screens ---------- */
  @media (min-width: 860px) {
    .award-entry__body {
      grid-template-columns: auto 1fr 280px;
    }
    .award-entry__cert {
      align-self: start;
    }
  }
  @media (max-width: 520px) {
    .award-entry__body {
      grid-template-columns: 1fr;
    }
    .award-entry__num {
      padding-top: 0;
    }
  }
</style>
