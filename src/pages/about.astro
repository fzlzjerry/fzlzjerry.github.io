---
import Layout from '../layouts/Layout.astro';

const skillCategories = [
  {
    category: "Programming Languages",
    skills: ["C", "C++", "JavaScript", "Python", "Rust"]
  },
  {
    category: "Web Technologies",
    skills: ["HTML5", "CSS3", "React", "Vue", "Node.js"]
  },
  {
    category: "AI/ML & Data Science",
    skills: ["TensorFlow", "PyTorch", "Scikit-learn", "NumPy", "Pandas", "OpenCV", "SciPy"]
  },
  {
    category: "Cloud Platforms",
    skills: ["AWS", "Google Cloud", "Azure"]
  },
  {
    category: "Development Tools",
    skills: ["Git", "Docker", "Linux", "MySQL", "Matlab"]
  },
  {
    category: "CMS & Static Site Generators",
    skills: ["Hexo", "Hugo", "Jekyll"]
  }
];
---

<Layout
  title="About - Morax Cheng"
  description="Learn more about Morax Cheng, a teenage open-source enthusiast and developer from China. Discover his skills in programming (Python, C++, Rust), AI/ML, web technologies, and his passion for learning."
  fullWidth={true}
>
  <div class="container">
    <!-- ===================== PAGE HEAD ===================== -->
    <header class="page-head">
      <span class="label" data-scramble>About</span>
      <h1 class="page-title" data-reveal-lines data-flux>A teenager who builds.</h1>
      <p class="page-lead" data-reveal>
        A teenage open-source enthusiast and developer from China, passionate about coding,
        mathematics, and artificial intelligence.
      </p>
    </header>

    <hr class="rule" />

    <!-- ===================== 01 · PROFILE ===================== -->
    <section class="section" aria-labelledby="profile-h">
      <div class="section-head">
        <span class="index-num" data-scramble>01</span>
        <span class="label" data-scramble>Profile</span>
      </div>

      <div class="profile">
        <figure class="profile__portrait media-frame" data-reveal-clip data-tilt="6">
          <picture>
            <source srcset="/Morax.webp" type="image/webp" />
            <img data-zoom src="/Morax.JPG" alt="Portrait of Morax Cheng" loading="eager" decoding="async" width="920" height="921" />
          </picture>
          <figcaption class="wall-label">
            <span>Morax Cheng</span>
            <span class="text-ink-faint">China</span>
          </figcaption>
        </figure>

        <div class="profile__text">
          <h2 class="profile__title" id="profile-h" data-reveal-lines data-flux>Hello, I'm Morax.</h2>
          <div class="profile__body">
            <p data-reveal>
              Hello! I'm Morax Cheng. I love to explore new technologies and apply them to solve
              real-world problems. When I'm not coding, you can find me reading sci-fi novels or
              playing chess.
            </p>
            <p data-reveal>
              I'm looking to collaborate on
              <a class="link-underline" href="https://github.com/lanbinshijie/bili2text" target="_blank" rel="noopener noreferrer">bili2text</a>
              and other exciting open-source projects.
            </p>
          </div>

          <dl class="profile__facts" data-stagger>
            <div class="fact">
              <dt class="label">Currently working on</dt>
              <dd><a class="link-underline" href="https://github.com/tjy-gitnub/win12" target="_blank" rel="noopener noreferrer">Windows 12 Web</a></dd>
            </div>
            <div class="fact">
              <dt class="label">Currently learning</dt>
              <dd>MATLAB &amp; Machine Learning Algorithms</dd>
            </div>
            <div class="fact">
              <dt class="label">Ask me about</dt>
              <dd>Python, C++, Machine Learning, and Data Analysis</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <hr class="rule" />

    <!-- ===================== 02 · SKILLS ===================== -->
    <section class="section" aria-labelledby="skills-h">
      <div class="section-head">
        <span class="index-num" data-scramble>02</span>
        <h2 class="section-title" id="skills-h" data-reveal-lines data-flux>Skills</h2>
      </div>

      <dl class="skills" data-stagger data-draw-rule>
        {skillCategories.map((c, i) => (
          <div class="skill-row">
            <dt class="skill-row__head">
              <span class="skill-row__num index-num" data-scramble>{String(i + 1).padStart(2, '0')}</span>
              <span class="skill-row__name">{c.category}</span>
            </dt>
            <dd class="skill-row__skills">
              <ul class="tag-list" role="list">
                {c.skills.map((s) => <li class="tag">{s}</li>)}
              </ul>
            </dd>
          </div>
        ))}
      </dl>
    </section>
  </div>
</Layout>

<style>
  /* ---------- 01 PROFILE ---------- */
  .profile {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1rem + 4vw, 4rem);
    align-items: start;
    perspective: 1200px;
  }
  .profile__portrait {
    aspect-ratio: 4 / 5;
    transform-style: preserve-3d;
    will-change: transform;
    transition: box-shadow var(--t-base) var(--ease-out);
  }
  .profile__portrait:hover { box-shadow: var(--shadow-3); }
  .profile__title { font-size: var(--step-3); margin-bottom: 1.5rem; max-width: 16ch; }
  .profile__body { display: flex; flex-direction: column; gap: 1.1rem; max-width: 56ch; }
  .profile__body p { font-size: var(--step-1); color: var(--ink-soft); line-height: 1.55; }
  .profile__facts {
    display: flex;
    flex-direction: column;
    margin: 2.5rem 0 0;
    border-top: 1px solid var(--line);
  }
  .profile__facts .fact {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.35rem;
    padding-block: 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .profile__facts dt { margin: 0; }
  .profile__facts dd { margin: 0; color: var(--ink); font-size: var(--step-0); }
  @media (min-width: 560px) {
    .profile__facts .fact {
      grid-template-columns: 14rem 1fr;
      align-items: baseline;
      gap: 1.5rem;
    }
  }
  @media (min-width: 880px) {
    .profile {
      grid-template-columns: 0.8fr 1.2fr;
      gap: clamp(2rem, 1rem + 5vw, 5rem);
    }
  }

  /* ---------- 02 SKILLS ---------- */
  .skills {
    margin: 0;
    padding: 0;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    padding-block: clamp(1.5rem, 1rem + 1.5vw, 2.25rem);
    border-bottom: 1px solid var(--line);
  }
  .skill-row__head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin: 0;
  }
  .skill-row__num { flex: none; padding-top: 0.1rem; }
  .skill-row__name {
    font-family: 'Bricolage Grotesque', Georgia, serif;
    font-size: var(--step-2);
    color: var(--ink);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .skill-row__skills { margin: 0; }
  @media (min-width: 820px) {
    .skill-row {
      grid-template-columns: 18rem 1fr;
      align-items: baseline;
      gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    }
    .skill-row__skills { padding-top: 0.4rem; }
  }
</style>
