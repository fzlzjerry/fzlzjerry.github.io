---
import Layout from '../layouts/Layout.astro';

const photos = [
  // Paris — Landmarks & Cityscape
  { src: '/gallery/Paris_Eiffel-Tower-Dusk-Seine.webp', title: 'Eiffel Tower at Dusk', category: 'Landmark', location: 'Seine River, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'large' },
  { src: '/gallery/Paris_Arc-de-Triomphe-Up-Close.webp', title: 'Arc de Triomphe', category: 'Landmark', location: 'Place Charles de Gaulle, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Sacre-Coeur-Basilica.webp', title: 'Sacré-Cœur Basilica', category: 'Architecture', location: 'Montmartre, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Montmartre-Panoramic-View.webp', title: 'Montmartre Panoramic View', category: 'Cityscape', location: 'Montmartre, Paris', date: 'Oct 2025', aspect: 'landscape', size: 'medium' },
  { src: '/gallery/Paris_Champs-Elysees-Arc-de-Triomphe.webp', title: 'Champs-Élysées', category: 'Street', location: 'Champs-Élysées, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Musee-dOrsay-from-Seine.webp', title: "Musée d'Orsay", category: 'Architecture', location: 'Seine River, Paris', date: 'Oct 2025', aspect: 'landscape', size: 'medium' },
  { src: '/gallery/Paris_Seine-River-Quay-and-Boats.webp', title: 'Seine River Quay', category: 'Cityscape', location: 'Seine River, Paris', date: 'Oct 2025', aspect: 'landscape', size: 'medium' },

  // Paris — Louvre Museum
  { src: '/gallery/Paris_Louvre-Mona-Lisa.webp', title: 'Mona Lisa', category: 'Art', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Louvre-Coronation-of-Napoleon.webp', title: 'The Coronation of Napoleon', category: 'Art', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'landscape', size: 'large' },
  { src: '/gallery/Paris_Louvre-Winged-Victory-of-Samothrace.webp', title: 'Winged Victory of Samothrace', category: 'Sculpture', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Louvre-Venus-de-Milo.webp', title: 'Venus de Milo', category: 'Sculpture', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Louvre-Diana-of-Versailles.webp', title: 'Diana of Versailles', category: 'Sculpture', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Louvre-Apollo-Gallery-Ceiling-Fresco.webp', title: 'Apollo Gallery Fresco', category: 'Art', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'landscape', size: 'large' },
  { src: '/gallery/Paris_Louvre-Apollo-Gallery-Gilded-Ceiling.webp', title: 'Apollo Gallery Ceiling', category: 'Architecture', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },

  // Paris — Notre-Dame & Sacred Art
  { src: '/gallery/Paris_Louvre-Salle-des-Caryatides.webp', title: 'Salle des Caryatides', category: 'Sculpture', location: 'Louvre Museum, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Notre-Dame-Apse-Stained-Glass.webp', title: 'Apse Stained Glass', category: 'Architecture', location: 'Notre-Dame, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Notre-Dame-High-Altar-and-Pieta.webp', title: 'High Altar & Pietà', category: 'Architecture', location: 'Notre-Dame, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Notre-Dame-Annunciation-Painting.webp', title: 'The Annunciation', category: 'Art', location: 'Notre-Dame, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Notre-Dame-Virgin-and-Child-Marble.webp', title: 'Virgin and Child', category: 'Sculpture', location: 'Notre-Dame, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },

  // Paris — Street & River
  { src: '/gallery/Paris_Eiffel-Tower-Night-Cruise-Ticket.webp', title: 'Seine Night Cruise', category: 'Landmark', location: 'Seine River, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Rolls-Royce-Ghost-Champs-Elysees.webp', title: 'Rolls-Royce Ghost', category: 'Street', location: 'Champs-Élysées, Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },
  { src: '/gallery/Paris_Religious-Procession-Float.webp', title: 'Religious Procession', category: 'Street', location: 'Paris', date: 'Oct 2025', aspect: 'portrait', size: 'medium' },

  // Skiing
  { src: '/gallery/Skiing_Chairlift-Mountain-View.webp', title: 'Chairlift Ascent', category: 'Landscape', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'large' },
  { src: '/gallery/Skiing_Helmet-Selfie-Ski-Mountain.webp', title: 'Summit Selfie', category: 'Portrait', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'medium' },
  { src: '/gallery/Skiing_Red-Suit-Sunny-Carving.webp', title: 'Sunny Carving', category: 'Action', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'medium' },
  { src: '/gallery/Skiing_Red-Suit-Carving-Among-Trees.webp', title: 'Tree Line Carving', category: 'Action', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'medium' },
  { src: '/gallery/Skiing_Skis-Resting-on-Snow-Sunny.webp', title: 'Skis in the Sun', category: 'Still Life', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'portrait', size: 'small' },
  { src: '/gallery/Skiing_Snowy-Run-Trees-Blue-Sky.webp', title: 'Snowy Trail', category: 'Landscape', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'large' },
  { src: '/gallery/Skiing_Summit-Mountain-Panorama.webp', title: 'Mountain Summit Panorama', category: 'Landscape', location: 'Beidahu Ski Resort, Jilin', date: 'Feb 2026', aspect: 'landscape', size: 'large' },
];

// Split into movements but keep one continuous lightbox sequence.
// The global index (page order) is what the viewer navigates.
const parisCount = photos.filter((p) => p.location.includes('Paris')).length;
const groups = [
  { id: '01', title: 'Paris', meta: 'October 2025', start: 0, items: photos.slice(0, parisCount) },
  { id: '02', title: 'Skiing, Jilin', meta: 'February 2026', start: parisCount, items: photos.slice(parisCount) },
];
---

<Layout
  title="Gallery - Morax Cheng"
  description="A curated collection of photography by Morax Cheng. Exploring architecture, landscapes, street photography, and more through a cinematic lens."
  fullWidth={true}
>
  <header class="page-head gx-head">
    <div class="container">
      <span class="label" data-scramble>Photography</span>
      <h1 class="page-title" data-reveal-lines data-flux>Through the lens</h1>
      <p class="page-lead" data-reveal>A curated selection of moments across landscapes, architecture, and the quiet beauty of everyday life.</p>
      <p class="gx-count mono" data-reveal><span data-count={photos.length}>{photos.length}</span> photographs</p>
    </div>
  </header>

  <hr class="rule" />

  {groups.map((group) => (
    <section class="section gx-section" aria-label={group.title}>
      <div class="container">
        <div class="section-head section-head--split">
          <div>
            <span class="index-num" data-scramble>{group.id}</span>
            <h2 class="section-title" data-reveal-lines data-flux>{group.title}</h2>
          </div>
          <span class="section-link mono gx-section__meta">{group.meta}</span>
        </div>

        <div class="gx-grid">
          {group.items.map((photo, i) => {
            const idx = group.start + i;
            return (
              <div class={`gx-cell gx-cell--${photo.aspect} gx-cell--${photo.size}`}>
                <button
                  class="gx-trigger media-frame"
                  type="button"
                  aria-label={`View ${photo.title}`}
                  data-reveal-clip
                  data-tilt="5"
                  data-photo
                  data-src={photo.src}
                  data-title={photo.title}
                  data-category={photo.category}
                  data-location={photo.location}
                  data-date={photo.date}
                  data-index={idx}
                >
                  <img
                    data-zoom
                    src={photo.src}
                    alt={photo.title}
                    loading="lazy"
                    decoding="async"
                    class="gx-img"
                  />
                  <span class="gx-plate mono" aria-hidden="true">Pl. {String(idx + 1).padStart(2, '0')}</span>
                  <span class="wall-label wall-label--hover">
                    <span class="index-num">{photo.category}</span>
                    <span>{photo.location}</span>
                    <span class="text-ink-faint">{photo.date}</span>
                  </span>
                </button>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  ))}

  <!-- Lightbox / viewer -->
  <div id="lightbox" class="gx-lb" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
    <div class="gx-lb__scrim"></div>
    <div class="gx-lb__frame">
      <div class="gx-lb__topbar">
        <span class="gx-lb__num mono" id="lightbox-number">01</span>
        <button class="gx-lb__close" aria-label="Close viewer">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="gx-lb__stage">
        <button class="gx-lb__arrow gx-lb__arrow--prev" id="lightbox-prev" aria-label="Previous photo">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M19 12H5m7-7-7 7 7 7" />
          </svg>
        </button>
        <img id="lightbox-img" class="gx-lb__image" src="" alt="" />
        <button class="gx-lb__arrow gx-lb__arrow--next" id="lightbox-next" aria-label="Next photo">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path d="M5 12h14m-7-7 7 7-7 7" />
          </svg>
        </button>
      </div>

      <div class="gx-lb__caption">
        <div class="gx-lb__caption-main">
          <span class="gx-lb__category mono" id="lightbox-category">Category</span>
          <h2 class="gx-lb__title" id="lightbox-title">Title</h2>
        </div>
        <dl class="gx-lb__meta">
          <div>
            <dt class="label">Location</dt>
            <dd id="lightbox-location">Location</dd>
          </div>
          <div>
            <dt class="label">Date</dt>
            <dd id="lightbox-date">Date</dd>
          </div>
          <div>
            <dt class="label">Plate</dt>
            <dd class="mono" id="lightbox-counter">01 / {String(photos.length).padStart(2, '0')}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* ============================================================
     Gallery page: editorial exhibition wall.
     Page-unique layout only; global atoms live in Layout.astro.
     ============================================================ */

  .gx-head { padding-bottom: clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .gx-head .page-lead { margin-top: 1.1rem; }
  .gx-count { color: var(--ink-faint); margin-top: 1.25rem; letter-spacing: 0.08em; }

  .gx-section { padding-block: clamp(2.5rem, 1.8rem + 4vw, 5.5rem); }
  .gx-section__meta { color: var(--ink-faint); letter-spacing: 0.08em; }

  /* ---- Exhibition wall: balanced masonry columns. Aspect-boxed plates so the
     columns pack with no ragged row gaps and no load-time layout shift. ---- */
  .gx-grid {
    column-count: 3;
    column-gap: clamp(0.85rem, 0.5rem + 1.1vw, 1.5rem);
  }
  .gx-cell {
    break-inside: avoid;
    margin: 0 0 clamp(0.85rem, 0.5rem + 1.1vw, 1.5rem);
    perspective: 1200px;
  }

  .gx-trigger {
    display: block;
    width: 100%;
    padding: 0;
    margin: 0;
    border: 1px solid var(--line);
    background: var(--paper-edge);
    cursor: pointer;
    aspect-ratio: 3 / 2;
    transform-style: preserve-3d;
    will-change: transform;
    transition: border-color var(--t-base) ease, box-shadow var(--t-base) var(--ease-out);
  }
  .gx-trigger:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-3);
  }
  .gx-trigger:focus-visible { box-shadow: var(--focus-ring); }

  /* Orientation sets plate proportions; columns handle the packing */
  .gx-cell--portrait .gx-trigger { aspect-ratio: 4 / 5; }
  .gx-cell--portrait.gx-cell--large .gx-trigger { aspect-ratio: 3 / 4; }
  .gx-cell--landscape .gx-trigger { aspect-ratio: 3 / 2; }

  .gx-img { width: 100%; height: 100%; object-fit: cover; }

  /* Plate number, top-left, paper chip */
  .gx-plate {
    position: absolute;
    top: 0; left: 0;
    padding: 0.3rem 0.6rem;
    background: var(--paper);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    border-bottom-right-radius: 2px;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--ochre);
    opacity: 0;
    transition: opacity var(--t-base) ease;
  }
  .gx-trigger:hover .gx-plate,
  .gx-trigger:focus-visible .gx-plate { opacity: 1; }

  .gx-cell .wall-label { gap: 0.7rem; flex-wrap: wrap; max-width: calc(100% - 1px); }
  .gx-cell .wall-label .index-num { color: var(--ochre); }

  @media (max-width: 900px) { .gx-grid { column-count: 2; } }
  @media (max-width: 480px) {
    .gx-grid { column-count: 2; column-gap: 0.7rem; }
    .gx-cell { margin-bottom: 0.7rem; }
  }

  /* ============================================================
     Lightbox: warm near-black scrim so photos pop
     ============================================================ */
  .gx-lb {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    grid-template-rows: 1fr;
    place-items: stretch;
  }
  .gx-lb[hidden] { display: none; }

  .gx-lb__scrim {
    position: absolute;
    inset: 0;
    background: oklch(0.18 0.01 70 / 0.94);
    animation: gxLbFade var(--t-base) ease forwards;
  }

  .gx-lb__frame {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    width: min(94vw, 1180px);
    height: 100%;
    max-height: 100vh;
    margin-inline: auto;
    padding: clamp(1rem, 0.5rem + 2vw, 2.5rem) 0;
    gap: clamp(0.75rem, 0.5rem + 1.5vw, 1.5rem);
  }

  .gx-lb__topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .gx-lb__num {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--paper);
    opacity: 0.62;
  }
  .gx-lb__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid color-mix(in oklch, var(--paper) 22%, transparent);
    background: transparent;
    border-radius: var(--radius);
    color: var(--paper);
    cursor: pointer;
    transition: border-color var(--t-fast) ease, color var(--t-fast) ease;
  }
  .gx-lb__close:hover { color: var(--ochre); border-color: var(--ochre); }

  .gx-lb__stage {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 0;
    gap: clamp(0.5rem, 0.25rem + 1vw, 1.5rem);
  }
  .gx-lb__image {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    min-width: 0;
    min-height: 0;
    object-fit: contain;
    animation: gxLbRise var(--t-slow) var(--ease-out) forwards;
  }

  .gx-lb__arrow {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border: 1px solid color-mix(in oklch, var(--paper) 22%, transparent);
    background: oklch(0.18 0.01 70 / 0.4);
    border-radius: 999px;
    color: var(--paper);
    cursor: pointer;
    transition: border-color var(--t-fast) ease, color var(--t-fast) ease, background-color var(--t-fast) ease;
  }
  .gx-lb__arrow:hover { color: var(--ochre); border-color: var(--ochre); }

  .gx-lb__caption {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    padding-top: clamp(0.5rem, 0.25rem + 1vw, 1rem);
    border-top: 1px solid color-mix(in oklch, var(--paper) 16%, transparent);
  }
  .gx-lb__category {
    display: block;
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ochre);
  }
  .gx-lb__title {
    margin-top: 0.4rem;
    font-size: var(--step-2);
    color: var(--paper);
    line-height: 1.05;
  }
  .gx-lb__meta {
    display: flex;
    gap: clamp(1.25rem, 0.75rem + 2vw, 2.75rem);
    margin: 0;
  }
  .gx-lb__meta div { display: flex; flex-direction: column; gap: 0.3rem; }
  .gx-lb__meta dt { color: color-mix(in oklch, var(--paper) 50%, transparent); margin: 0; }
  .gx-lb__meta dd {
    margin: 0;
    font-size: 0.92rem;
    color: color-mix(in oklch, var(--paper) 88%, transparent);
  }

  @keyframes gxLbFade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes gxLbRise {
    from { opacity: 0; transform: translateY(10px) scale(0.985); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 600px) {
    .gx-lb__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
    }
    .gx-lb__arrow--prev { left: 0; }
    .gx-lb__arrow--next { right: 0; }
    .gx-lb__caption { justify-content: flex-start; }
    .gx-lb__meta { gap: 1.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .gx-lb__scrim,
    .gx-lb__image { animation: none; }
  }
</style>

<script>
  function initGallery() {
    const previousCleanup = (window as any).__galleryCleanup;
    if (typeof previousCleanup === 'function') {
      previousCleanup();
    }

    // All photos, page-wide, in document order, one continuous sequence
    // even though the wall is split into movements (Paris / Skiing).
    const triggers = Array.from(
      document.querySelectorAll<HTMLElement>('[data-photo]')
    );
    const lightbox = document.getElementById('lightbox') as HTMLElement | null;
    if (!lightbox || triggers.length === 0) {
      (window as any).__galleryCleanup = null;
      return;
    }

    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lightboxTitle = document.getElementById('lightbox-title');
    const lightboxCategory = document.getElementById('lightbox-category');
    const lightboxLocation = document.getElementById('lightbox-location');
    const lightboxDate = document.getElementById('lightbox-date');
    const lightboxNumber = document.getElementById('lightbox-number');
    const lightboxCounter = document.getElementById('lightbox-counter');
    const lightboxClose = lightbox.querySelector('.gx-lb__close') as HTMLElement | null;
    const lightboxScrim = lightbox.querySelector('.gx-lb__scrim') as HTMLElement | null;
    const lightboxStage = lightbox.querySelector('.gx-lb__stage') as HTMLElement | null;
    const lightboxPrev = document.getElementById('lightbox-prev');
    const lightboxNext = document.getElementById('lightbox-next');

    const total = triggers.length;
    let current = 0;

    function updateLightbox() {
      const trigger = triggers[current];
      if (!trigger) return;

      const src = trigger.getAttribute('data-src') || '';
      const title = trigger.getAttribute('data-title') || '';
      const category = trigger.getAttribute('data-category') || '';
      const location = trigger.getAttribute('data-location') || '';
      const date = trigger.getAttribute('data-date') || '';

      if (lightboxImg) {
        // restart the rise animation on each navigation
        lightboxImg.style.animation = 'none';
        lightboxImg.src = src;
        lightboxImg.alt = title;
        void lightboxImg.offsetWidth;
        lightboxImg.style.animation = '';
      }
      if (lightboxTitle) lightboxTitle.textContent = title;
      if (lightboxCategory) lightboxCategory.textContent = category;
      if (lightboxLocation) lightboxLocation.textContent = location;
      if (lightboxDate) lightboxDate.textContent = date;
      if (lightboxNumber) lightboxNumber.textContent = String(current + 1).padStart(2, '0');
      if (lightboxCounter) lightboxCounter.textContent = `${String(current + 1).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
    }

    function openLightbox(index: number) {
      current = index;
      updateLightbox();
      lightbox!.hidden = false;
      document.body.style.overflow = 'hidden';
      setTimeout(() => lightboxClose?.focus(), 80);
    }

    function closeLightbox() {
      lightbox!.hidden = true;
      document.body.style.overflow = '';
    }

    function nextPhoto() {
      current = (current + 1) % total;
      updateLightbox();
    }

    function prevPhoto() {
      current = (current - 1 + total) % total;
      updateLightbox();
    }

    const triggerHandlers: Array<() => void> = [];
    triggers.forEach((trigger, index) => {
      const handler = () => openLightbox(index);
      trigger.addEventListener('click', handler);
      triggerHandlers.push(() => trigger.removeEventListener('click', handler));
    });

    // Clicking the dark void around the photo (not the image or an arrow) closes too.
    function onStageClick(e: MouseEvent) {
      if (e.target === lightboxStage) closeLightbox();
    }

    lightboxClose?.addEventListener('click', closeLightbox);
    lightboxScrim?.addEventListener('click', closeLightbox);
    lightboxStage?.addEventListener('click', onStageClick);
    lightboxPrev?.addEventListener('click', prevPhoto);
    lightboxNext?.addEventListener('click', nextPhoto);

    function handleKeydown(e: KeyboardEvent) {
      if (lightbox!.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowRight') nextPhoto();
      else if (e.key === 'ArrowLeft') prevPhoto();
    }
    document.addEventListener('keydown', handleKeydown);

    (window as any).__galleryCleanup = () => {
      document.removeEventListener('keydown', handleKeydown);
      lightboxClose?.removeEventListener('click', closeLightbox);
      lightboxScrim?.removeEventListener('click', closeLightbox);
      lightboxStage?.removeEventListener('click', onStageClick);
      lightboxPrev?.removeEventListener('click', prevPhoto);
      lightboxNext?.removeEventListener('click', nextPhoto);
      triggerHandlers.forEach((off) => off());
      document.body.style.overflow = '';
    };
  }

  if ((window as any).__galleryPageLoadHandler) {
    document.removeEventListener('astro:page-load', (window as any).__galleryPageLoadHandler);
  }
  (window as any).__galleryPageLoadHandler = initGallery;
  document.addEventListener('astro:page-load', (window as any).__galleryPageLoadHandler);

  initGallery();
</script>
