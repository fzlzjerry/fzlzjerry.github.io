---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPost = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)[0];

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const projects = [
  {
    title: 'Windows 12 Web',
    description: 'A web-based Windows 12 concept UI built with modern web technologies. A realistic Windows-like interface with multi-window management and a set of working system apps.',
    tech: ['HTML', 'CSS', 'JS'],
    github: 'https://github.com/tjy-gitnub/win12',
    year: '2024',
  },
  {
    title: 'WeChat Anti-Recall',
    description: 'A SwiftPM command-line tool for macOS WeChat 4 that patches supported builds to preserve recalled messages, add a tip mode, and block auto-updates.',
    tech: ['Swift', 'SwiftPM', 'Mach-O', 'macOS'],
    github: 'https://github.com/fzlzjerry/wechat-antirecall',
    year: '2025',
  },
];

const stats = [
  { value: '29', suffix: '', label: 'Photographs' },
  { value: '2', suffix: '', label: 'Awards' },
  { value: '6', suffix: '+', label: 'Languages' },
  { value: '2', suffix: '', label: 'Projects' },
];

const awards = [
  { title: 'Gold Division', event: 'USACO 2025–2026' },
  { title: 'Meritorious Award', event: 'HiMCM 2025' },
];

const galleryTeaser = [
  { src: '/gallery/Paris_Louvre-Coronation-of-Napoleon.webp', alt: 'The Coronation of Napoleon hanging in the Louvre', place: 'Louvre, Paris', span: 'wide' },
  { src: '/gallery/Paris_Sacre-Coeur-Basilica.webp', alt: 'Sacré-Cœur Basilica above Montmartre', place: 'Montmartre, Paris', span: 'tall' },
  { src: '/gallery/Skiing_Summit-Mountain-Panorama.webp', alt: 'Mountain summit panorama under blue sky', place: 'Beidahu, Jilin', span: 'wide' },
  { src: '/gallery/Paris_Eiffel-Tower-Dusk-Seine.webp', alt: 'The Eiffel Tower at dusk over the Seine', place: 'Seine, Paris', span: 'tall' },
];
---

<Layout
  title="Morax Cheng — Student Developer & Economics Enthusiast"
  description="Morax Cheng: student developer and economics enthusiast. Software, markets, and a camera. Projects, writing, awards, and a photo gallery."
  fullWidth={true}
>
  <span id="top" aria-hidden="true"></span>

  <!-- ===================== HERO ===================== -->
  <section class="hero" data-hero aria-labelledby="hero-title">
    <div class="container">
      <div class="hero__top">
        <span class="label" data-hero-item>Morax Cheng · Portfolio, Edition 2026</span>
        <span class="label" data-hero-item>Shenzhen, China · Open source</span>
      </div>
      <hr class="rule" data-hero-item />

      <h1 class="hero__title" id="hero-title" data-hero-headline>Morax Cheng</h1>

      <div class="hero__row">
        <div class="hero__lead">
          <p data-hero-item>
            Student developer and economics enthusiast. I build software, study how
            markets move, and carry a camera for everything in between.
          </p>
          <div class="hero__cta" data-hero-item>
            <a class="btn btn-primary" href="/projects">View projects<span class="btn-arrow" aria-hidden="true">&rarr;</span></a>
            <a class="btn btn-ghost" href="/about">About me</a>
          </div>
        </div>
        <dl class="hero__meta" data-hero-item>
          <div><dt class="label">Disciplines</dt><dd>Software · Economics · Photography</dd></div>
          <div><dt class="label">Currently</dt><dd>BASIS International School, Park Lane Harbour</dd></div>
          <div><dt class="label">Learning</dt><dd>MATLAB &amp; ML algorithms</dd></div>
        </dl>
      </div>

      <figure class="hero__media media-frame" data-hero-media>
        <img data-parallax="6" src="/gallery/Paris_Montmartre-Panoramic-View.webp" alt="The rooftops of Paris seen from the steps of Montmartre" loading="eager" />
        <figcaption class="wall-label">
          <span class="index-num">Pl. 01</span>
          <span>Montmartre, Paris</span>
          <span class="text-ink-faint">Oct 2025</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ===================== 01 · PROFILE ===================== -->
  <section class="section" aria-labelledby="profile-h">
    <div class="container">
      <div class="section-head">
        <span class="index-num">01</span>
        <span class="label">Profile</span>
      </div>
      <div class="profile">
        <div class="profile__text">
          <h2 class="profile__title" id="profile-h" data-reveal-lines>Curious, by default.</h2>
          <div class="profile__body">
            <p data-reveal>
              I'm Morax Cheng, a high-school student at BASIS International School Park Lane Harbour.
              I write software, dig into economic theory, and gravitate toward problems that sit
              where the two meet.
            </p>
            <p data-reveal>
              Away from the editor you'll find me reading science fiction, playing chess, or out
              with a camera. Most of what I make ends up open source.
            </p>
          </div>
          <dl class="profile__facts" data-stagger>
            <div>
              <dt class="label">Currently building</dt>
              <dd><a class="link-underline" href="https://github.com/tjy-gitnub/win12" target="_blank" rel="noopener noreferrer">Windows 12 Web</a></dd>
            </div>
            <div>
              <dt class="label">Currently learning</dt>
              <dd>MATLAB &amp; machine-learning algorithms</dd>
            </div>
            <div>
              <dt class="label">Based in</dt>
              <dd>China</dd>
            </div>
          </dl>
        </div>
        <figure class="profile__portrait media-frame" data-reveal>
          <img data-zoom src="/Morax.JPG" alt="Portrait of Morax Cheng" loading="lazy" />
          <figcaption class="wall-label">
            <span>Morax Cheng</span>
            <span class="text-ink-faint">Open-source contributor</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- keyword marquee -->
  <div class="marquee strip" aria-hidden="true">
    <div class="marquee__track" data-marquee="36">
      {Array.from({ length: 2 }).map(() => (
        <span class="strip__inner">
          {['Developer', 'Economics', 'Open Source', 'Machine Learning', 'Mathematics', 'Python', 'C++', 'Rust', 'Photography'].map((w) => (
            <span class="strip__item">{w}<span class="strip__dot">✦</span></span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- ===================== 02 · SELECTED WORK ===================== -->
  <section class="section" aria-labelledby="work-h">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num">02</span>
          <h2 class="section-title" id="work-h" data-reveal-lines>Selected work</h2>
        </div>
        <a class="section-link link-underline" href="/projects">All projects →</a>
      </div>

      <ol class="work-list">
        {projects.map((p, i) => (
          <li class="work-row" data-reveal>
            <a class="work-row__link" href={p.github} target="_blank" rel="noopener noreferrer">
              <span class="work-row__num index-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="work-row__main">
                <h3 class="work-row__title">{p.title}</h3>
                <p class="work-row__desc">{p.description}</p>
                <ul class="work-row__tech" role="list">
                  {p.tech.map((t) => <li>{t}</li>)}
                </ul>
              </div>
              <span class="work-row__year mono">{p.year}</span>
              <span class="work-row__arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== 03 · RECOGNITION ===================== -->
  <section class="section" aria-labelledby="rec-h">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num">03</span>
          <h2 class="section-title" id="rec-h" data-reveal-lines>On the record</h2>
        </div>
        <a class="section-link link-underline" href="/awards">All awards →</a>
      </div>

      <dl class="stats" data-stagger>
        {stats.map((s) => (
          <div class="stat">
            <dd class="stat__value">
              <span class="counter" data-count={s.value}>{s.value}</span><span class="stat__suffix">{s.suffix}</span>
            </dd>
            <dt class="stat__label label">{s.label}</dt>
          </div>
        ))}
      </dl>

      <ul class="awards" role="list">
        {awards.map((a) => (
          <li class="award" data-reveal>
            <span class="award__title">{a.title}</span>
            <span class="award__event mono">{a.event}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ===================== 04 · THROUGH THE LENS ===================== -->
  <section class="section" aria-labelledby="lens-h">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num">04</span>
          <h2 class="section-title" id="lens-h" data-reveal-lines>Through the lens</h2>
        </div>
        <a class="section-link link-underline" href="/gallery">Full gallery →</a>
      </div>
      <p class="lens-intro" data-reveal>Twenty-nine frames across Paris and the slopes of Jilin.</p>

      <div class="lens-grid" data-stagger>
        {galleryTeaser.map((g) => (
          <a href="/gallery" class:list={['lens-cell media-frame', `lens-cell--${g.span}`]} aria-label={`Gallery: ${g.place}`}>
            <img data-zoom src={g.src} alt={g.alt} loading="lazy" />
            <figcaption class="wall-label wall-label--hover">
              <span>{g.place}</span>
            </figcaption>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== 05 · LATEST WRITING ===================== -->
  {latestPost && (
    <section class="section" aria-labelledby="write-h">
      <div class="container">
        <div class="section-head section-head--split">
          <div>
            <span class="index-num">05</span>
            <h2 class="section-title" id="write-h" data-reveal-lines>Latest writing</h2>
          </div>
          <a class="section-link link-underline" href="/blog">All posts →</a>
        </div>

        <a class="feature-post" href={`/blog/${latestPost.slug}`} data-reveal>
          <div class="feature-post__meta">
            <time class="mono" datetime={latestPost.data.date}>{fmtDate(latestPost.data.date)}</time>
            {latestPost.data.category && <span class="feature-post__cat label">{latestPost.data.category}</span>}
          </div>
          <h3 class="feature-post__title">{latestPost.data.title}</h3>
          {latestPost.data.excerpt && <p class="feature-post__excerpt">{latestPost.data.excerpt}</p>}
          <span class="feature-post__cta link-underline">Read the piece →</span>
        </a>
      </div>
    </section>
  )}

  <!-- ===================== 06 · CONTACT ===================== -->
  <section class="section contact" aria-labelledby="contact-h">
    <div class="container">
      <div class="section-head">
        <span class="index-num">06</span>
        <span class="label">Contact</span>
      </div>
      <h2 class="contact__title" id="contact-h" data-reveal-lines>Let's build something.</h2>
      <p class="contact__body" data-reveal>
        I'm always up for collaborating on open source, talking economics, or comparing notes on
        code and cameras.
      </p>
      <div class="contact__cta" data-reveal>
        <a class="btn btn-primary" href="mailto:james20081204@gmail.com">Get in touch<span class="btn-arrow" aria-hidden="true">&rarr;</span></a>
        <a class="btn btn-ghost" href="https://github.com/fzlzjerry" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero { padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem); padding-bottom: clamp(2rem, 1rem + 3vw, 4rem); }
  .hero__top { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .hero .rule { margin-bottom: clamp(1rem, 0.5rem + 2vw, 2.5rem); }
  .hero__title {
    font-size: var(--step-6);
    line-height: 0.86;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin-bottom: clamp(1.5rem, 1rem + 3vw, 3.5rem);
  }
  .hero__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    margin-bottom: clamp(2rem, 1.5rem + 3vw, 4rem);
  }
  .hero__lead p { font-size: var(--step-1); color: var(--ink); max-width: 34ch; line-height: 1.4; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }
  .hero__meta { display: flex; flex-direction: column; gap: 1rem; }
  .hero__meta dt { margin-bottom: 0.3rem; }
  .hero__meta dd { color: var(--ink); font-size: 0.95rem; }
  .hero__media { aspect-ratio: 4 / 3; }
  @media (min-width: 900px) {
    .hero__row { grid-template-columns: 1.1fr 0.9fr; align-items: end; }
    .hero__title { font-size: var(--step-6); }
    .hero__media { aspect-ratio: 16 / 8; }
  }

  /* ---------- 01 PROFILE ---------- */
  .profile { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .profile__title { font-size: var(--step-4); margin-bottom: 1.5rem; max-width: 14ch; }
  .profile__body { display: flex; flex-direction: column; gap: 1.1rem; max-width: 52ch; }
  .profile__body p { font-size: var(--step-1); color: var(--ink-soft); line-height: 1.55; }
  .profile__facts { display: flex; flex-direction: column; gap: 1rem; margin-top: 2.25rem; padding-top: 2rem; border-top: 1px solid var(--line); }
  .profile__facts dt { margin-bottom: 0.3rem; }
  .profile__facts dd { color: var(--ink); }
  .profile__portrait { aspect-ratio: 4 / 5; }
  @media (min-width: 880px) {
    .profile { grid-template-columns: 1.2fr 0.8fr; }
  }

  /* ---------- marquee strip ---------- */
  .strip { border-block: 1px solid var(--line); padding-block: 1.1rem; }
  .strip__inner { display: inline-flex; align-items: center; }
  .strip__item {
    display: inline-flex; align-items: center;
    font-family: 'Bricolage Grotesque', serif;
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: var(--ink);
    padding-inline: 1.4rem;
    white-space: nowrap;
  }
  .strip__dot { color: var(--ochre); margin-left: 2.8rem; font-size: 0.7em; }

  /* ---------- 02 SELECTED WORK ---------- */
  .work-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .work-row { border-bottom: 1px solid var(--line); }
  .work-row__link {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: start;
    gap: clamp(1rem, 0.5rem + 2vw, 2.5rem);
    padding-block: clamp(1.75rem, 1rem + 2vw, 2.75rem);
  }
  .work-row__num { padding-top: 0.45rem; }
  .work-row__title { font-size: var(--step-2); transition: color var(--t-base) ease; }
  .work-row__desc { margin-top: 0.6rem; color: var(--ink-soft); max-width: 60ch; line-height: 1.55; }
  .work-row__tech { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; list-style: none; padding: 0; }
  .work-row__tech li {
    font-family: 'Spline Sans Mono', monospace; font-size: 0.7rem; letter-spacing: 0.03em;
    color: var(--ink-faint); border: 1px solid var(--line); border-radius: 999px; padding: 0.2rem 0.65rem;
  }
  .work-row__year { color: var(--ink-faint); font-size: 0.8rem; padding-top: 0.5rem; }
  .work-row__arrow { font-size: 1.25rem; color: var(--ink-ghost); padding-top: 0.35rem; transition: transform var(--t-base) var(--ease-out), color var(--t-base) ease; }
  .work-row__link:hover .work-row__title { color: var(--ochre); }
  .work-row__link:hover .work-row__arrow { transform: translate(4px, -4px); color: var(--ochre); }
  @media (max-width: 640px) {
    .work-row__link { grid-template-columns: auto 1fr; }
    .work-row__year, .work-row__arrow { display: none; }
  }

  /* ---------- 03 RECOGNITION ---------- */
  .stats {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px;
    background: var(--line); border: 1px solid var(--line); margin: 0 0 clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  .stat { background: var(--paper); padding: clamp(1.25rem, 1rem + 2vw, 2.5rem) 1.25rem; }
  .stat__value { font-family: 'Bricolage Grotesque', serif; font-size: var(--step-4); line-height: 1; color: var(--ink); font-weight: 500; margin: 0; }
  .stat__suffix { color: var(--ochre); font-size: 0.5em; }
  .stat__label { margin-top: 0.6rem; }
  @media (min-width: 760px) { .stats { grid-template-columns: repeat(4, 1fr); } }

  .awards { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .award { display: flex; justify-content: space-between; align-items: baseline; gap: 1.5rem; flex-wrap: wrap; padding-block: 1.15rem; border-bottom: 1px solid var(--line); }
  .award__title { font-family: 'Bricolage Grotesque', serif; font-size: var(--step-1); color: var(--ink); }
  .award__event { color: var(--ink-faint); font-size: 0.78rem; white-space: nowrap; }

  /* ---------- 04 THROUGH THE LENS ---------- */
  .lens-intro { color: var(--ink-soft); font-size: var(--step-1); max-width: 40ch; margin: -1rem 0 clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .lens-grid { display: grid; grid-template-columns: 1fr; gap: clamp(0.75rem, 0.5rem + 1vw, 1.25rem); }
  .lens-cell { display: block; aspect-ratio: 3 / 2; }
  .lens-cell--tall { aspect-ratio: 4 / 5; }
  @media (min-width: 720px) {
    .lens-grid { grid-template-columns: repeat(6, 1fr); grid-auto-rows: 1fr; }
    .lens-cell--wide { grid-column: span 4; aspect-ratio: 16 / 10; }
    .lens-cell--tall { grid-column: span 2; aspect-ratio: 3 / 4; }
  }

  /* ---------- 05 WRITING ---------- */
  .feature-post { display: block; border: 1px solid var(--line); border-radius: var(--radius); padding: clamp(1.75rem, 1rem + 3vw, 3.5rem); transition: border-color var(--t-base) ease, background-color var(--t-base) ease; }
  .feature-post:hover { border-color: var(--line-strong); background: var(--panel); }
  .feature-post__meta { display: flex; align-items: center; gap: 1rem; color: var(--ink-faint); font-size: 0.8rem; }
  .feature-post__cat { color: var(--ochre); }
  .feature-post__title { font-size: var(--step-3); margin: 1rem 0; max-width: 22ch; }
  .feature-post__excerpt { color: var(--ink-soft); max-width: 62ch; line-height: 1.6; margin-bottom: 1.5rem; }
  .feature-post__cta { font-size: 0.95rem; color: var(--ink); }

  /* ---------- 06 CONTACT ---------- */
  .contact__title { font-size: var(--step-5); max-width: 12ch; margin-bottom: 1.5rem; }
  .contact__body { font-size: var(--step-1); color: var(--ink-soft); max-width: 46ch; margin-bottom: 2rem; }
  .contact__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; }
</style>
