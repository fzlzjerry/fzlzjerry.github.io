---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPost = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)[0];

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const projects = [
  {
    title: 'Windows 12 Web',
    description: 'A web-based Windows 12 concept UI built with modern web technologies. A realistic Windows-like interface with multi-window management and a set of working system apps.',
    tech: ['HTML', 'CSS', 'JS'],
    github: 'https://github.com/tjy-gitnub/win12',
    year: '2024',
  },
  {
    title: 'WeChat Anti-Recall',
    description: 'A SwiftPM command-line tool for macOS WeChat 4 that patches supported builds to preserve recalled messages, add a tip mode, and block auto-updates.',
    tech: ['Swift', 'SwiftPM', 'Mach-O', 'macOS'],
    github: 'https://github.com/fzlzjerry/wechat-antirecall',
    year: '2025',
  },
];

const stats = [
  { value: '29', suffix: '', label: 'Photographs' },
  { value: '2', suffix: '', label: 'Awards' },
  { value: '6', suffix: '+', label: 'Languages' },
  { value: '2', suffix: '', label: 'Projects' },
];

// Specimen-ledger entries. Fields are pulled verbatim from src/pages/awards.astro
// (body, discipline, year, document) so nothing here is fabricated.
const awards = [
  {
    num: '01',
    title: 'Gold Division',
    year: '2025-2026',
    body: 'USACO',
    discipline: 'Competitive programming',
    doc: null,
    docLabel: 'On file',
  },
  {
    num: '02',
    title: 'Meritorious Award',
    year: '2025',
    body: 'COMAP · HiMCM',
    discipline: 'Mathematical modeling · Team 16400',
    doc: '/certificates/16400.pdf',
    docLabel: 'Doc. 16400',
  },
];

const galleryTeaser = [
  { src: '/gallery/Paris_Louvre-Coronation-of-Napoleon.webp', alt: 'The Coronation of Napoleon hanging in the Louvre', place: 'Louvre, Paris', span: 'wide' },
  { src: '/gallery/Paris_Sacre-Coeur-Basilica.webp', alt: 'Sacré-Cœur Basilica above Montmartre', place: 'Montmartre, Paris', span: 'tall' },
  { src: '/gallery/Skiing_Summit-Mountain-Panorama.webp', alt: 'Mountain summit panorama under blue sky', place: 'Beidahu, Jilin', span: 'wide' },
  { src: '/gallery/Paris_Eiffel-Tower-Dusk-Seine.webp', alt: 'The Eiffel Tower at dusk over the Seine', place: 'Seine, Paris', span: 'tall' },
];

// Cursor image-trail: real frames that flick out as the pointer sweeps the hero.
const trailImages = [
  '/gallery/Paris_Eiffel-Tower-Dusk-Seine.webp',
  '/gallery/Paris_Louvre-Coronation-of-Napoleon.webp',
  '/gallery/Skiing_Summit-Mountain-Panorama.webp',
  '/gallery/Paris_Louvre-Mona-Lisa.webp',
  '/gallery/Paris_Sacre-Coeur-Basilica.webp',
  '/gallery/Paris_Louvre-Winged-Victory-of-Samothrace.webp',
  '/gallery/Skiing_Red-Suit-Sunny-Carving.webp',
  '/gallery/Paris_Notre-Dame-Apse-Stained-Glass.webp',
  '/gallery/Paris_Arc-de-Triomphe-Up-Close.webp',
  '/gallery/Paris_Musee-dOrsay-from-Seine.webp',
  '/gallery/Skiing_Snowy-Run-Trees-Blue-Sky.webp',
  '/gallery/Paris_Louvre-Venus-de-Milo.webp',
  '/gallery/Paris_Seine-River-Quay-and-Boats.webp',
  '/gallery/Paris_Louvre-Apollo-Gallery-Gilded-Ceiling.webp',
];

// Pinned horizontal filmstrip plates (section 04).
const filmstripPlates = [
  { src: '/gallery/Paris_Eiffel-Tower-Dusk-Seine.webp', alt: 'The Eiffel Tower at dusk over the Seine', place: 'Seine, Paris' },
  { src: '/gallery/Paris_Louvre-Coronation-of-Napoleon.webp', alt: 'The Coronation of Napoleon in the Louvre', place: 'Louvre, Paris' },
  { src: '/gallery/Paris_Sacre-Coeur-Basilica.webp', alt: 'Sacré-Cœur Basilica above Montmartre', place: 'Montmartre, Paris' },
  { src: '/gallery/Paris_Louvre-Winged-Victory-of-Samothrace.webp', alt: 'The Winged Victory of Samothrace in the Louvre', place: 'Louvre, Paris' },
  { src: '/gallery/Paris_Notre-Dame-Apse-Stained-Glass.webp', alt: 'Stained glass in the apse of Notre-Dame', place: 'Notre-Dame, Paris' },
  { src: '/gallery/Skiing_Summit-Mountain-Panorama.webp', alt: 'Mountain summit panorama under a blue sky', place: 'Beidahu, Jilin' },
  { src: '/gallery/Skiing_Red-Suit-Sunny-Carving.webp', alt: 'Carving a sunlit slope in a red suit', place: 'Beidahu, Jilin' },
  { src: "/gallery/Paris_Musee-dOrsay-from-Seine.webp", alt: "The Musée d'Orsay seen from the Seine", place: "Seine, Paris" },
];
---

<Layout
  title="Morax Cheng · Student Developer & Economics Enthusiast"
  description="Morax Cheng: student developer and economics enthusiast. Software, markets, and a camera. Projects, writing, awards, and a photo gallery."
  fullWidth={true}
>
  <!-- Hero photo is the LCP element; front-load it so the develop starts immediately -->
  <link slot="head" rel="preload" as="image" href="/gallery/Paris_Montmartre-Panoramic-View.webp" fetchpriority="high" />

  <span id="top" aria-hidden="true"></span>

  <!-- Catalogue movement indicator (you-are-here tab; desktop + motion only) -->
  <aside class="movement-index" aria-hidden="true" data-movement-index>
    <span class="movement-index__count">
      <span class="movement-index__cur" data-movement-cur>01</span><span class="movement-index__total">/ 06</span>
    </span>
    <span class="movement-index__name" data-movement-name>Profile</span>
    <span class="movement-index__rail">
      <span class="movement-index__tick"></span>
      <span class="movement-index__tick"></span>
      <span class="movement-index__tick"></span>
      <span class="movement-index__tick"></span>
      <span class="movement-index__tick"></span>
      <span class="movement-index__tick"></span>
    </span>
  </aside>

  <!-- ===================== HERO ===================== -->
  <section class="hero" data-hero data-image-trail data-trail-images={JSON.stringify(trailImages)} aria-labelledby="hero-title">
    <div class="container">
      <div class="hero__top">
        <span class="label" data-hero-item>Morax Cheng · Portfolio, Edition 2026</span>
        <span class="label" data-hero-item>Shenzhen, China · Open source</span>
      </div>
      <hr class="rule" data-hero-item />

      <h1 class="hero__title" id="hero-title" data-hero-headline data-flux>Morax Cheng</h1>

      <div class="hero__row">
        <div class="hero__lead">
          <p data-hero-item>
            Student developer and economics enthusiast. I build software, study how
            markets move, and carry a camera for everything in between.
          </p>
          <div class="hero__cta" data-hero-item>
            <a class="btn btn-primary" href="/projects">View projects<span class="btn-arrow" aria-hidden="true">&rarr;</span></a>
            <a class="btn btn-ghost" href="/about">About me</a>
          </div>
        </div>
        <dl class="hero__meta" data-hero-item>
          <div><dt class="label">Disciplines</dt><dd>Software · Economics · Photography</dd></div>
          <div><dt class="label">Currently</dt><dd>BASIS International School, Park Lane Harbour</dd></div>
          <div><dt class="label">Learning</dt><dd>MATLAB &amp; ML algorithms</dd></div>
        </dl>
      </div>

      <figure class="hero__media media-frame" data-hero-media data-halftone>
        <img data-parallax="6" src="/gallery/Paris_Montmartre-Panoramic-View.webp" alt="The rooftops of Paris seen from the steps of Montmartre" loading="eager" />
        <figcaption class="wall-label">
          <span class="index-num">Cover</span>
          <span>Montmartre, Paris</span>
          <span class="text-ink-faint">Oct 2025</span>
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- ===================== 01 · PROFILE ===================== -->
  <section class="section" aria-labelledby="profile-h" data-movement="Profile">
    <div class="container">
      <div class="section-head">
        <span class="index-num" data-scramble>01</span>
        <span class="label" data-scramble>Profile</span>
      </div>
      <div class="profile">
        <div class="profile__text">
          <h2 class="profile__title" id="profile-h" data-reveal-lines data-flux>Curious, by default.</h2>
          <div class="profile__body">
            <p data-reveal>
              I'm Morax Cheng, a high-school student at BASIS International School Park Lane Harbour.
              I write software, dig into economic theory, and gravitate toward problems that sit
              where the two meet.
            </p>
            <p data-reveal>
              Away from the editor you'll find me reading science fiction, playing chess, or out
              with a camera. Most of what I make ends up open source.
            </p>
          </div>
          <dl class="profile__facts" data-stagger>
            <div>
              <dt class="label">Currently building</dt>
              <dd><a class="link-underline" href="https://github.com/tjy-gitnub/win12" target="_blank" rel="noopener noreferrer">Windows 12 Web</a></dd>
            </div>
            <div>
              <dt class="label">Currently learning</dt>
              <dd>MATLAB &amp; machine-learning algorithms</dd>
            </div>
            <div>
              <dt class="label">Based in</dt>
              <dd>China</dd>
            </div>
          </dl>
        </div>
        <figure class="profile__portrait media-frame" data-reveal>
          <picture>
            <source srcset="/Morax.webp" type="image/webp" />
            <img data-zoom data-parallax="5" src="/Morax.JPG" alt="Portrait of Morax Cheng" loading="lazy" decoding="async" width="920" height="921" />
          </picture>
          <figcaption class="wall-label">
            <span class="index-num">Pl. 00</span>
            <span>Morax Cheng</span>
            <span class="text-ink-faint">Open-source contributor</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- keyword marquee -->
  <div class="marquee strip" aria-hidden="true">
    <div class="marquee__track" data-marquee="36">
      {Array.from({ length: 2 }).map(() => (
        <span class="strip__inner">
          {['Developer', 'Economics', 'Open Source', 'Machine Learning', 'Mathematics', 'Python', 'C++', 'Rust', 'Photography'].map((w) => (
            <span class="strip__item" data-velocity-skew>{w}<span class="strip__dot">✦</span></span>
          ))}
        </span>
      ))}
    </div>
  </div>

  <!-- ===================== 02 · SELECTED WORK ===================== -->
  <section class="section" aria-labelledby="work-h" data-movement="Selected work">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num" data-scramble>02</span>
          <h2 class="section-title" id="work-h" data-reveal-lines data-flux>Selected work</h2>
        </div>
        <a class="section-link link-underline" href="/projects">All projects →</a>
      </div>

      <ol class="work-list" data-work-list data-draw-rule>
        {projects.map((p, i) => (
          <li class="work-row" data-reveal>
            <span class="work-row__ghost" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <a class="work-row__link" href={p.github} target="_blank" rel="noopener noreferrer">
              <span class="work-row__num index-num">{String(i + 1).padStart(2, '0')}</span>
              <div class="work-row__main">
                <h3 class="work-row__title">{p.title}</h3>
                <p class="work-row__desc">{p.description}</p>
                <ul class="work-row__tech" role="list">
                  {p.tech.map((t) => <li>{t}</li>)}
                </ul>
              </div>
              <span class="work-row__year mono">{p.year}</span>
              <span class="work-row__arrow" aria-hidden="true">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== 03 · RECOGNITION ===================== -->
  <section class="section" aria-labelledby="rec-h" data-movement="On the record">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num" data-scramble>03</span>
          <h2 class="section-title" id="rec-h" data-reveal-lines data-flux>On the record</h2>
        </div>
        <a class="section-link link-underline" href="/awards">All awards →</a>
      </div>

      <dl class="census" data-stagger data-draw-rule>
        {stats.map((s, i) => (
          <div class="census__row">
            <span class="census__num index-num" data-scramble>{String(i + 1).padStart(2, '0')}</span>
            <dt class="census__label label">{s.label}</dt>
            <span class="census__leader" aria-hidden="true"></span>
            <dd class="census__value">
              <span class="counter" data-count={s.value}>{s.value}</span><span class="census__suffix">{s.suffix}</span>
            </dd>
          </div>
        ))}
      </dl>

      <ol class="ledger" data-stagger data-draw-rule>
        {awards.map((a) => (
          <li class="ledger__row">
            <div class="ledger__index">
              <span class="ledger__num index-num" data-scramble>{a.num}</span>
              <span class="ledger__year mono">{a.year}</span>
            </div>
            <div class="ledger__main">
              <h3 class="ledger__title font-display">{a.title}</h3>
              <p class="ledger__caption mono">{a.body} · {a.discipline}</p>
            </div>
            {a.doc ? (
              <a class="ledger__doc mono link-ochre" href={a.doc} target="_blank" rel="noopener noreferrer">{a.docLabel} ↗</a>
            ) : (
              <span class="ledger__doc ledger__doc--quiet mono">{a.docLabel}</span>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ===================== 04 · THROUGH THE LENS ===================== -->
  <aside class="chapter" aria-hidden="true" data-chapter>
    <span class="chapter__ghost">04</span>
    <div class="container chapter__body">
      <span class="chapter__kicker label">Movement</span>
      <span class="chapter__title">The photographs</span>
    </div>
  </aside>

  <section class="section section--lens" aria-labelledby="lens-h" data-movement="Through the lens">
    <div class="container">
      <div class="section-head section-head--split">
        <div>
          <span class="index-num" data-scramble>04</span>
          <h2 class="section-title" id="lens-h" data-reveal-lines data-flux>Through the lens</h2>
        </div>
        <a class="section-link link-underline" href="/gallery">Full gallery →</a>
      </div>
      <p class="lens-intro" data-reveal>Twenty-nine frames across Paris and the slopes of Jilin. Scroll to flip through the plates.</p>
    </div>

    <div class="filmstrip" data-pin-section>
      <ol class="filmstrip__track" data-pin-track>
        {filmstripPlates.map((g, i) => (
          <li class="filmstrip__plate" data-velocity-skew data-place={g.place}>
            <a href="/gallery" class="media-frame" data-tilt="7" aria-label={`Gallery: ${g.place}`}>
              <img data-zoom src={g.src} alt={g.alt} loading="lazy" decoding="async" />
              <figcaption class="wall-label">
                <span class="index-num">{`Pl. ${String(i + 1).padStart(2, '0')}`}</span>
                <span>{g.place}</span>
              </figcaption>
            </a>
          </li>
        ))}
      </ol>
      <!-- Guided-walk caption; shown only while the strip is pinned (desktop + motion) -->
      <div class="filmstrip__hud" aria-hidden="true" data-strip-hud>
        <span class="filmstrip__hud-num index-num"><span data-strip-cur>01</span> / {String(filmstripPlates.length).padStart(2, '0')}</span>
        <span class="filmstrip__hud-place" data-strip-place>{filmstripPlates[0].place}</span>
      </div>
    </div>
  </section>

  <!-- ===================== 05 · LATEST WRITING ===================== -->
  {latestPost && (
    <section class="section" aria-labelledby="write-h" data-movement="Latest writing">
      <div class="container">
        <div class="section-head section-head--split">
          <div>
            <span class="index-num" data-scramble>05</span>
            <h2 class="section-title" id="write-h" data-reveal-lines data-flux>Latest writing</h2>
          </div>
          <a class="section-link link-underline" href="/blog">All posts →</a>
        </div>

        <a class="feature-post" href={`/blog/${latestPost.slug}`} data-reveal data-draw-rule>
          <div class="feature-post__rail">
            <span class="feature-post__fraction index-num">01 / 01</span>
            <time class="feature-post__date mono" datetime={latestPost.data.date}>{fmtDate(latestPost.data.date)}</time>
            {latestPost.data.category && <span class="feature-post__cat label">{latestPost.data.category}</span>}
          </div>
          <div class="feature-post__main">
            <h3 class="feature-post__title">{latestPost.data.title}</h3>
            {latestPost.data.excerpt && <p class="feature-post__excerpt">{latestPost.data.excerpt}</p>}
            <span class="feature-post__cta link-underline">Read the piece →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ===================== 06 · CONTACT ===================== -->
  <aside class="chapter" aria-hidden="true" data-chapter>
    <span class="chapter__ghost">06</span>
    <div class="container chapter__body">
      <span class="chapter__kicker label">Movement</span>
      <span class="chapter__title">In closing</span>
    </div>
  </aside>

  <section class="section contact" aria-labelledby="contact-h" data-movement="Contact">
    <div class="container">
      <div class="section-head">
        <span class="index-num" data-scramble>06</span>
        <span class="label" data-scramble>Contact</span>
      </div>
      <h2 class="contact__title" id="contact-h" data-reveal-lines data-flux>Let's build something.</h2>
      <svg class="contact__underline" viewBox="0 0 320 22" fill="none" aria-hidden="true" preserveAspectRatio="none">
        <path data-draw-svg d="M5 13 C 60 4, 120 19, 175 11 S 270 5, 315 13" stroke-width="3" stroke-linecap="round" />
      </svg>
      <p class="contact__body" data-reveal>
        One inbox, always open. Send a project worth building, a market worth arguing about, or a
        photograph worth chasing.
      </p>
      <a class="contact__email link-underline" href="mailto:james20081204@gmail.com" data-reveal aria-label="Email Morax Cheng">
        <span data-scramble>james20081204@gmail.com</span>
      </a>
      <div class="contact__cta" data-reveal>
        <a class="btn btn-primary" href="mailto:james20081204@gmail.com" data-magnetic="0.25">Get in touch<span class="btn-arrow" aria-hidden="true">&rarr;</span></a>
        <a class="btn btn-ghost" href="https://github.com/fzlzjerry" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <p class="contact__signoff mono" data-reveal>End of catalogue · Edition 2026 · Shenzhen</p>
    </div>
  </section>
</Layout>

<style>
  /* ---------- HERO ---------- */
  .hero { position: relative; padding-top: clamp(2.5rem, 1.5rem + 4vw, 5rem); padding-bottom: clamp(2rem, 1rem + 3vw, 4rem); }
  .hero__top { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .hero .rule { margin-bottom: clamp(1rem, 0.5rem + 2vw, 2.5rem); }
  .hero__title {
    font-size: var(--step-6);
    line-height: 0.86;
    letter-spacing: -0.04em;
    font-weight: 500;
    margin-bottom: clamp(1.5rem, 1rem + 3vw, 3.5rem);
  }
  .hero__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 1rem + 2vw, 3rem);
    margin-bottom: clamp(2rem, 1.5rem + 3vw, 4rem);
  }
  .hero__lead p { font-size: var(--step-1); color: var(--ink); max-width: 34ch; line-height: 1.4; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem; }
  .hero__meta { display: flex; flex-direction: column; gap: 1rem; }
  .hero__meta dt { margin-bottom: 0.3rem; }
  .hero__meta dd { color: var(--ink); font-size: 0.95rem; }
  .hero__media { aspect-ratio: 4 / 3; }
  @media (min-width: 900px) {
    /* On large screens the hero would otherwise overrun the viewport: a giant
       title plus a 16:8 image ~620px tall pushes the fold well past one screen.
       Tighten the vertical rhythm and bound the image band to viewport HEIGHT
       (the real constraint) so the whole hero fits a single screen. */
    .hero { padding-top: clamp(1.75rem, 1rem + 2vw, 3rem); padding-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem); }
    .hero .rule { margin-bottom: clamp(0.75rem, 0.25rem + 1.5vw, 1.75rem); }
    .hero__row { grid-template-columns: 1.1fr 0.9fr; align-items: end; margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem); }
    .hero__title { font-size: var(--step-6); margin-bottom: clamp(1rem, 0.5rem + 1.5vw, 2rem); }
    .hero__media { aspect-ratio: 16 / 8; max-height: min(44vh, 32rem); }
  }

  /* ---------- 01 PROFILE ---------- */
  .profile { display: grid; grid-template-columns: 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .profile__title { font-size: var(--step-4); margin-bottom: 1.5rem; max-width: 14ch; }
  .profile__body { display: flex; flex-direction: column; gap: 1.1rem; max-width: 52ch; }
  .profile__body p { font-size: var(--step-1); color: var(--ink-soft); line-height: 1.55; }
  .profile__facts { display: flex; flex-direction: column; gap: 1rem; margin-top: 2.25rem; padding-top: 2rem; border-top: 1px solid var(--line); }
  .profile__facts dt { margin-bottom: 0.3rem; }
  .profile__facts dd { color: var(--ink); }
  .profile__portrait { aspect-ratio: 4 / 5; }
  @media (min-width: 880px) {
    .profile { grid-template-columns: 1.2fr 0.8fr; }
  }

  /* ---------- marquee strip ---------- */
  .strip {
    border-block: 1px solid var(--line); padding-block: 1.1rem;
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
    mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
  }
  .strip__inner { display: inline-flex; align-items: center; }
  .strip__item {
    display: inline-flex; align-items: center;
    font-family: 'Bricolage Grotesque', serif;
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.8rem);
    color: var(--ink);
    padding-inline: 1.4rem;
    white-space: nowrap;
  }
  .strip__dot { color: var(--ochre); margin-left: 2.8rem; font-size: 0.7em; }

  /* The self-drawing hairline primitive ([data-draw-rule]) is defined globally in
     Layout.astro so every page can use it; this page just opts in via the attribute. */

  /* Catalogue movement indicator: a small fixed paper tab (bottom-left) that tracks
     the current movement with a tick rail. Hidden by default; JS adds .is-visible
     once you scroll past the hero. The paper backing keeps it legible over the
     full-bleed filmstrip. Desktop + motion only. */
  .movement-index {
    position: fixed; left: clamp(1rem, 1.5vw, 2.25rem); bottom: clamp(1.25rem, 2.5vh, 2.25rem);
    z-index: 40; display: flex; flex-direction: column; gap: 0.45rem;
    padding: 0.7rem 0.85rem; background: var(--paper); border: 1px solid var(--line);
    font-family: 'Spline Sans Mono', monospace; pointer-events: none;
    opacity: 0; transform: translateY(10px);
