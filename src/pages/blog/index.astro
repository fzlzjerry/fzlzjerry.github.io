---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];
const tags = [...new Set(allPosts.flatMap(post => post.data.tags))];

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Blog - Morax Cheng"
  description="Browse Morax Cheng's blog for articles on programming, technology, economics, and personal reflections."
  fullWidth={true}
>
  <div class="container">
    <header class="page-head">
      <span class="label">Writing</span>
      <h1 class="page-title" data-reveal-lines>Blog</h1>
      <p class="page-lead" data-reveal>Thoughts, tutorials, and notes on technology and economics.</p>
    </header>

    <section class="section-sm" aria-label="Filter writing">
      <hr class="rule" />
      <div class="filters" data-reveal>
        {categories.length > 0 && (
          <div class="filters__row">
            <span class="label filters__key">Categories</span>
            <ul class="tag-list">
              {categories.map(category => (
                <li>
                  <a class="tag tag-link" href={`/blog/category/${category?.toLowerCase()}`}>{category}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {tags.length > 0 && (
          <div class="filters__row">
            <span class="label filters__key">Popular tags</span>
            <ul class="tag-list">
              {tags.slice(0, 8).map(tag => (
                <li>
                  <a class="tag tag-link" href={`/blog/tag/${tag?.toLowerCase()}`}>#{tag}</a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
      <hr class="rule" />
    </section>

    <section class="section-sm" aria-label="All posts">
      <ol class="post-list" data-stagger>
        {sortedPosts.map((post) => (
          <li class="post-row">
            <article>
              <div class="post-row__meta">
                <time class="mono" datetime={post.data.date}>{fmtDate(post.data.date)}</time>
                {post.data.category && (
                  <a class="post-row__cat label" href={`/blog/category/${post.data.category.toLowerCase()}`}>{post.data.category}</a>
                )}
              </div>
              <h2 class="post-row__title">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && (
                <p class="post-row__excerpt">{post.data.excerpt}</p>
              )}
              {post.data.tags && post.data.tags.length > 0 && (
                <ul class="tag-list post-row__tags">
                  {post.data.tags.map(tag => (
                    <li>
                      <a class="tag tag-link" href={`/blog/tag/${tag.toLowerCase()}`}>#{tag}</a>
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  /* ---------- filter row ---------- */
  .filters { display: flex; flex-direction: column; gap: 1.25rem; padding-block: clamp(1.25rem, 1rem + 1vw, 2rem); }
  .filters__row { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.75rem 1rem; }
  .filters__key { flex: 0 0 auto; padding-top: 0.2rem; }
  @media (min-width: 640px) { .filters__key { min-width: 9rem; } }

  .tag-link { transition: color var(--t-base) ease, border-color var(--t-base) ease; }
  .tag-link:hover { color: var(--ochre); border-color: var(--ochre-faint); }

  /* ---------- post list ---------- */
  .post-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .post-row { border-bottom: 1px solid var(--line); padding-block: clamp(1.75rem, 1.25rem + 2vw, 3rem); }
  .post-row__meta { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; color: var(--ink-faint); font-size: 0.78rem; }
  .post-row__cat { color: var(--ochre); transition: color var(--t-base) ease; }
  .post-row__cat:hover { color: var(--ochre-deep); }
  .post-row__title { font-size: var(--step-3); margin: 0.85rem 0 0; max-width: 24ch; }
  .post-row__title a { transition: color var(--t-base) ease; }
  .post-row__title a:hover { color: var(--ochre); }
  .post-row__excerpt { color: var(--ink-soft); max-width: 62ch; line-height: 1.6; margin-top: 1rem; }
  .post-row__tags { margin-top: 1.25rem; }
</style>
