---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];
const tags = [...new Set(allPosts.flatMap(post => post.data.tags))];

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const [latest, ...earlier] = sortedPosts;
const total = String(sortedPosts.length).padStart(2, '0');

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Blog - Morax Cheng"
  description="Browse Morax Cheng's blog for articles on programming, technology, economics, and personal reflections."
  fullWidth={true}
>
  <div class="container">
    <header class="page-head">
      <span class="label" data-scramble>Writing</span>
      <h1 class="page-title" data-reveal-lines data-flux>Blog</h1>
      <p class="page-lead" data-reveal>Thoughts, tutorials, and notes on technology and economics.</p>
    </header>

    {latest && (
      <section class="section-sm" aria-label="Latest post">
        <article class="lead-post" data-reveal data-draw-rule>
          <div class="lead-post__rail">
            <span class="lead-post__fraction index-num" data-scramble>{`01 / ${total}`}</span>
            <time class="lead-post__date mono" datetime={latest.data.date}>{fmtDate(latest.data.date)}</time>
            {latest.data.category && (
              <a class="lead-post__cat label" href={`/blog/category/${latest.data.category.toLowerCase()}`}>{latest.data.category}</a>
            )}
          </div>
          <div class="lead-post__main">
            <h2 class="lead-post__title">
              <a href={`/blog/${latest.slug}`}>{latest.data.title}</a>
            </h2>
            {latest.data.excerpt && <p class="lead-post__excerpt">{latest.data.excerpt}</p>}
            <a class="lead-post__cta link-underline" href={`/blog/${latest.slug}`}>Read the piece →</a>
            {latest.data.tags && latest.data.tags.length > 0 && (
              <ul class="tag-list lead-post__tags" role="list">
                {latest.data.tags.map(tag => (
                  <li>
                    <a class="tag tag-link" href={`/blog/tag/${tag.toLowerCase()}`}>#{tag}</a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </article>
      </section>
    )}

    {earlier.length > 0 && (
      <section class="section-sm" aria-label="Earlier posts">
        <ol class="post-list" data-stagger data-draw-rule>
          {earlier.map((post, i) => (
            <li class="post-row">
              <article class="post-row__grid">
                <span class="post-row__num index-num" data-scramble>{String(i + 2).padStart(2, '0')}</span>
                <div class="post-row__main">
                  <div class="post-row__meta">
                    <time class="mono" datetime={post.data.date}>{fmtDate(post.data.date)}</time>
                    {post.data.category && (
                      <a class="post-row__cat label" href={`/blog/category/${post.data.category.toLowerCase()}`}>{post.data.category}</a>
                    )}
                  </div>
                  <h2 class="post-row__title">
                    <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                  </h2>
                  {post.data.excerpt && (
                    <p class="post-row__excerpt">{post.data.excerpt}</p>
                  )}
                </div>
              </article>
            </li>
          ))}
        </ol>
      </section>
    )}

    {(categories.length > 0 || tags.length > 0) && (
      <section class="section-sm" aria-label="Browse the index">
        <hr class="rule" />
        <div class="browse" data-reveal>
          <span class="label browse__key">Browse</span>
          <ul class="tag-list" role="list">
            {categories.map(category => (
              <li>
                <a class="tag tag-link" href={`/blog/category/${category?.toLowerCase()}`}>{category}</a>
              </li>
            ))}
            {tags.slice(0, 8).map(tag => (
              <li>
                <a class="tag tag-link" href={`/blog/tag/${tag?.toLowerCase()}`}>#{tag}</a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  /* ---------- The latest entry is a full catalogue plate ---------- */
  .lead-post {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(0.9rem, 0.5rem + 1.5vw, 2.25rem);
    padding-block: clamp(2rem, 1.25rem + 3vw, 3.75rem);
    border-bottom: 1px solid var(--line);
  }
  .lead-post__rail { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.55rem 1.1rem; }
  @media (min-width: 820px) { .lead-post__rail { flex-direction: column; align-items: flex-start; } }
  .lead-post__fraction { color: var(--ochre); }
  .lead-post__date { color: var(--ink-faint); font-size: 0.8rem; }
  .lead-post__cat { color: var(--ochre); transition: color var(--t-base) ease; }
  .lead-post__cat:hover { color: var(--ochre-deep); }
  .lead-post__title {
    font-size: var(--step-4);
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin: 0 0 1.1rem;
    max-width: 22ch;
  }
  .lead-post__title a { transition: color var(--t-base) ease; }
  .lead-post__title a:hover { color: var(--ochre); }
  .lead-post__excerpt { color: var(--ink-soft); max-width: 58ch; line-height: 1.65; font-size: var(--step-1); margin-bottom: 1.5rem; }
  .lead-post__cta { font-size: 0.95rem; color: var(--ink); }
  .lead-post__tags { margin-top: 1.5rem; }
  @media (min-width: 820px) {
    .lead-post { grid-template-columns: minmax(8rem, 0.22fr) 1fr; align-items: start; }
  }

  /* ---------- Earlier entries: ruled catalogue rows ---------- */
  .post-list { list-style: none; margin: 0; padding: 0; }
  .post-row { border-bottom: 1px solid var(--line); padding-block: clamp(1.75rem, 1.25rem + 2vw, 3rem); }
  .post-row__grid { display: grid; grid-template-columns: auto 1fr; gap: clamp(1rem, 0.5rem + 2vw, 2.5rem); align-items: start; }
  .post-row__num { padding-top: 0.3rem; }
  .post-row__meta { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; color: var(--ink-faint); font-size: 0.78rem; }
  .post-row__cat { color: var(--ochre); transition: color var(--t-base) ease; }
  .post-row__cat:hover { color: var(--ochre-deep); }
  .post-row__title { font-size: var(--step-2); margin: 0.75rem 0 0; max-width: 28ch; }
  .post-row__title a { transition: color var(--t-base) ease; }
  .post-row__title a:hover { color: var(--ochre); }
  .post-row__excerpt { color: var(--ink-soft); max-width: 62ch; line-height: 1.6; margin-top: 0.9rem; }

  /* ---------- Back-matter: browse the index ---------- */
  .browse {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem 1.25rem;
    padding-block: clamp(1.25rem, 1rem + 1vw, 2rem);
  }
  .browse__key { flex: 0 0 auto; }
  .tag-link { transition: color var(--t-base) ease, border-color var(--t-base) ease; }
  .tag-link:hover { color: var(--ochre); border-color: var(--ochre-faint); }
</style>
