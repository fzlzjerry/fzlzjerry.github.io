---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(post => post.data.tags))];

  return tags.map(tag => ({
    params: { tag: tag?.toLowerCase() },
    props: {
      tag,
      posts: posts.filter(post => post.data.tags?.includes(tag))
    },
  }));
}

const { tag, posts } = Astro.props;
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`#${tag} - Blog Tag - Morax Cheng`} fullWidth={true}>
  <div class="container">
    <header class="page-head">
      <span class="label">Tag</span>
      <h1 class="page-title" data-reveal-lines>#{tag}</h1>
      <p class="page-lead" data-reveal>
        {posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with #{tag}.
      </p>
      <a class="link-underline filter-back" href="/blog" data-reveal>All writing</a>
    </header>

    <section class="section-sm" aria-label="Posts with tag">
      <ol class="post-list" data-stagger>
        {sortedPosts.map((post) => (
          <li class="post-row">
            <article>
              <div class="post-row__meta">
                <time class="mono" datetime={post.data.date}>{fmtDate(post.data.date)}</time>
                {post.data.category && (
                  <a class="post-row__cat label" href={`/blog/category/${post.data.category.toLowerCase()}`}>{post.data.category}</a>
                )}
              </div>
              <h2 class="post-row__title">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h2>
              {post.data.excerpt && (
                <p class="post-row__excerpt">{post.data.excerpt}</p>
              )}
              {post.data.tags && post.data.tags.length > 0 && (
                <ul class="tag-list post-row__tags">
                  {post.data.tags.map(t => (
                    <li>
                      <a class:list={['tag tag-link', t === tag && 'tag-link--active']} href={`/blog/tag/${t.toLowerCase()}`}>#{t}</a>
                    </li>
                  ))}
                </ul>
              )}
            </article>
          </li>
        ))}
      </ol>
    </section>
  </div>
</Layout>

<style>
  .filter-back { display: inline-block; margin-top: 1.5rem; font-size: 0.9rem; }

  .tag-link { transition: color var(--t-base) ease, border-color var(--t-base) ease, background-color var(--t-base) ease; }
  .tag-link:hover { color: var(--ochre); border-color: var(--ochre-faint); }
  .tag-link--active { color: var(--paper); background: var(--ochre); border-color: var(--ochre); }
  .tag-link--active:hover { color: var(--paper); background: var(--ochre-deep); border-color: var(--ochre-deep); }

  .post-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line); }
  .post-row { border-bottom: 1px solid var(--line); padding-block: clamp(1.75rem, 1.25rem + 2vw, 3rem); }
  .post-row__meta { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; color: var(--ink-faint); font-size: 0.78rem; }
  .post-row__cat { color: var(--ochre); transition: color var(--t-base) ease; }
  .post-row__cat:hover { color: var(--ochre-deep); }
  .post-row__title { font-size: var(--step-3); margin: 0.85rem 0 0; max-width: 24ch; }
  .post-row__title a { transition: color var(--t-base) ease; }
  .post-row__title a:hover { color: var(--ochre); }
  .post-row__excerpt { color: var(--ink-soft); max-width: 62ch; line-height: 1.6; margin-top: 1rem; }
  .post-row__tags { margin-top: 1.25rem; }
</style>
