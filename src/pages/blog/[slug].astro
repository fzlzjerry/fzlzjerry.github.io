---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Contents index: section + subsection titles (h2/h3). Shown only when the piece
// is long enough to navigate (a two-or-three-entry post does not need an index).
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showToc = toc.length >= 3;

const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const { title, category, authors, professor, institution, department, tags } = post.data;
const hasByline = (authors && authors.length) || institution || department || professor;
---

<Layout
  title={`${post.data.title} - Morax Cheng`}
  description={post.data.excerpt}
  ogType="article"
  image={post.data.ogImage}
  imageAlt={post.data.title}
  publishedTime={post.data.date}
>
  <!-- KaTeX is only needed for math in long-form posts, so it loads here, not site-wide -->
  <link
    slot="head"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
    crossorigin="anonymous"
  />
  <article class="container">
    <header class="page-head post-head">
      <div class="post-head__meta">
        <time class="mono post-head__date" datetime={post.data.date}>{formattedDate}</time>
        {category && <span class="label post-head__cat" data-scramble>{category}</span>}
      </div>

      <h1 class="post-title" data-reveal-lines data-flux>{title}</h1>

      {hasByline && (
        <dl class="post-byline" data-reveal>
          {authors && authors.length > 0 && (
            <div class="post-byline__row">
              <dt class="label">By</dt>
              <dd>{authors.join(', ')}</dd>
            </div>
          )}
          {institution && (
            <div class="post-byline__row">
              <dt class="label">Institution</dt>
              <dd>{institution}</dd>
            </div>
          )}
          {department && (
            <div class="post-byline__row">
              <dt class="label">Department</dt>
              <dd>{department}</dd>
            </div>
          )}
          {professor && (
            <div class="post-byline__row">
              <dt class="label">Advisor</dt>
              <dd>{professor}</dd>
            </div>
          )}
        </dl>
      )}
    </header>

    <hr class="rule post-rule" />

    {showToc ? (
      <div class="post-layout">
        <TableOfContents headings={toc} />
        <div class="prose prose-lg post-body" data-reveal>
          <Content />
        </div>
      </div>
    ) : (
      <div class="prose prose-lg post-body" data-reveal>
        <Content />
      </div>
    )}

    <footer class="post-foot">
      <hr class="rule" />
      {tags && tags.length > 0 && (
        <ul class="tag-list post-foot__tags" role="list">
          {tags.map(tag => (
            <li>
              <a class="tag post-tag" href={`/blog/tag/${tag.toLowerCase()}`}>#{tag}</a>
            </li>
          ))}
        </ul>
      )}
      <a class="section-link link-underline post-foot__back" href="/blog">← All writing</a>
    </footer>
  </article>
</Layout>

<style>
  /* Constrained reading column for the article */
  .post-head { max-width: var(--container-text); }
  .post-head__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: clamp(1.25rem, 1rem + 1.5vw, 2rem);
  }
  .post-head__date { font-size: 0.8rem; color: var(--ink-faint); letter-spacing: 0.02em; }
  .post-head__cat { color: var(--ochre); }

  .post-title {
    font-size: var(--step-4);
    line-height: 1.02;
    letter-spacing: -0.03em;
    max-width: 18ch;
  }

  .post-byline {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: clamp(1.75rem, 1.25rem + 2vw, 2.75rem) 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .post-byline__row {
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .post-byline__row dt { flex: 0 0 auto; min-width: 7rem; }
  .post-byline__row dd { margin: 0; color: var(--ink); font-size: 0.95rem; }

  .post-rule { margin-block: clamp(2rem, 1.5rem + 2vw, 3.5rem); }

  /* Constrain the reading column to the text measure (overrides prose's 68ch) */
  .post-body { max-width: var(--container-text); margin-inline: 0; }

  /* Article + contents rail. The reading column keeps its left-aligned text measure;
     the contents index takes the wide right margin on desktop and, below 70rem,
     collapses to a disclosure stacked above the body (natural DOM order). */
  .post-layout { display: block; }
  @media (min-width: 70rem) {
    .post-layout {
      display: grid;
      grid-template-columns: minmax(0, var(--container-text)) minmax(0, 1fr);
      column-gap: clamp(2rem, 1rem + 3vw, 4.5rem);
      align-items: start;
    }
    .post-layout .post-body { grid-column: 1; grid-row: 1; }
    .post-layout :global(.post-toc) { grid-column: 2; grid-row: 1; }
  }

  .post-foot {
    max-width: var(--container-text);
    margin-top: clamp(3rem, 2rem + 4vw, 5rem);
  }
  .post-foot .rule { margin-bottom: clamp(1.5rem, 1rem + 2vw, 2.5rem); }
  .post-foot__tags { margin-bottom: 2rem; }
  .post-tag:hover { color: var(--ochre); border-color: var(--ochre-faint); }
  .post-foot__back { font-size: 0.95rem; color: var(--ink); }
</style>
