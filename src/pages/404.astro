---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found · Morax Cheng"
  description="This page could not be found. Return to the homepage."
  fullWidth={true}
>
  <section class="notfound">
    <div class="container">
      <div class="notfound__top">
        <span class="index-num" data-scramble>Err. 404</span>
        <span class="label" data-scramble>Off the catalogue</span>
      </div>
      <hr class="rule" />

      <div class="notfound__grid">
        <div class="notfound__text">
          <h1 class="notfound__title" data-reveal-lines data-flux>Page not found</h1>
          <p class="notfound__lead" data-reveal>
            This plate isn't in the collection. The link may have moved, or it
            never hung here at all.
          </p>
          <div class="notfound__cta" data-reveal>
            <a class="btn btn-primary" href="/" data-magnetic="0.25">Return to home<span class="btn-arrow" aria-hidden="true">&rarr;</span></a>
          </div>
        </div>

        <figure class="notfound__media media-frame" data-reveal-clip>
          <video
            class="notfound__video"
            autoplay
            loop
            muted
            playsinline
            aria-label="A short looping animation marking a missing page"
          >
            <source src="/404.webm" type="video/webm" />
          </video>
          <figcaption class="wall-label">
            <span class="index-num">Pl. 404</span>
            <span>Missing plate</span>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    padding-block: clamp(3.5rem, 2.5rem + 6vw, 8rem);
  }
  .notfound__top {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .notfound .rule {
    margin-bottom: clamp(2rem, 1.5rem + 3vw, 4rem);
  }

  .notfound__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1.5rem + 4vw, 4.5rem);
    align-items: center;
  }

  .notfound__title {
    font-size: var(--step-5);
    line-height: 0.92;
    letter-spacing: -0.03em;
    max-width: 12ch;
  }
  .notfound__lead {
    margin-top: clamp(1.25rem, 1rem + 1.5vw, 2rem);
    font-size: var(--step-1);
    color: var(--ink-soft);
    max-width: 38ch;
    line-height: 1.5;
  }
  .notfound__cta {
    margin-top: clamp(1.75rem, 1.5rem + 1.5vw, 2.5rem);
  }

  .notfound__media {
    aspect-ratio: 4 / 3;
    width: 100%;
    max-width: 32rem;
  }
  /* Global .media-frame styles target `img`; the video needs its own fill rule. */
  .notfound__video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (min-width: 860px) {
    .notfound__grid {
      grid-template-columns: 1fr 0.85fr;
    }
    .notfound__media {
      margin-left: auto;
    }
  }
</style>
